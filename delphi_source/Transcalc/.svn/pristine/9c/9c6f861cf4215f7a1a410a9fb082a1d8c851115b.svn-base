<!DOCTYPE html>

<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <title>Shear - Square Web</title>
</head>
<body>
    <table width="900" style="table-layout:fixed; font-size: 20px" align="center">
        <colgroup>
            <col width="50" />
            <col width="12" />
            <col width="38" />
        </colgroup>
        <tr>
            <th colspan="3" style="font-size:30px">
                Shear - Square Web
            </th>
        </tr>
        <tr><td height="20"></td></tr>
        <tr>
            <td align="right">Applied Force, F:</td>
            <td align="right">$af1</td>
            <td align="left">$af2</td>
        </tr>
        <tr>
            <td align="right"><b>Shear Section Dimensions</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Width, w:</td>
            <td align="right">$bw1</td>
            <td align="left">$bw2</td>
        </tr>
        <tr>
            <td align="right">Height, h:</td>
            <td align="right">$bh1</td>
            <td align="left">$bh2</td>
        </tr>
        <tr>
            <td align="right">Web Thickness t:</td>
            <td align="right">$wt1</td>
            <td align="left">$wt2</td>
        </tr>
        <tr>
            <td align="right">Web Height e:</td>
            <td align="right">$wh1</td>
            <td align="left">$wh2</td>
        </tr>
        <tr>
            <td align="right"><b>Material Properties</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Poisson's Ration:</td>
            <td align="right">$pr1</td>
        </tr>
        <tr>
            <td align="right">Modulus of Elasticity:</td>
            <td align="right">$me1</td>
            <td align="left">$me2</td>
        </tr>
        <tr>
            <td align="right"><b>Gage Parameters</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Gage Factor:</td>
            <td align="right">$gf1</td>
            <td align="left"></td>
        </tr>
        <tr><td height="20"></td></tr>
        <tr>
            <td align="right"><b>Calculated Values</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Nominal Gage Strain:</td>
            <td align="right">$gs1</td>
            <td align="left">&micro;&epsilon;</td>
        </tr>
        <tr>
            <td align="right">Span at Applied Force:</td>
            <td align="right">$sf1</td>
            <td align="left">mV&frasl;V</td>
        </tr>
        <tr><td height="20"></td></tr>
    </table>
    <center>
        <img src="data:image/jpg;base64," />
    </center>
</body>
</html>