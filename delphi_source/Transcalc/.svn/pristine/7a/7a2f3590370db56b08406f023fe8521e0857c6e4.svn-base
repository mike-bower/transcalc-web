<!DOCTYPE html>

<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <title>Bending-Reverse Bending</title>
</head>
<body>
    <table width="900" style="table-layout:fixed; font-size: 20px" align="center">
        <colgroup>
            <col width="50" />
            <col width="12" />
            <col width="38" />
        </colgroup>
        <tr>
            <th colspan="3" style="font-size:30px">
                Bending-Reverse Bending
            </th>
        </tr>
        <tr><td height="20"></td></tr>
        <tr>
            <td align="right">Applied Force, F:</td>
            <td align="right">$af1</td>
            <td align="left">$af2</td>
        </tr>
        <tr>
            <td align="right"><b>Beam Parameters</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Beam Width, w:</td>
            <td align="right">$bw1</td>
            <td align="left">$bw2</td>
        </tr>
        <tr>
            <td align="right">Thickness t:</td>
            <td align="right">$bt1</td>
            <td align="left">$bt2</td>
        </tr>
        <tr>
            <td align="right">Distance between Gage CL's, L:</td>
            <td align="right">$cl1</td>
            <td align="left">$cl2</td>
        </tr>
        <tr>
            <td align="right">Modulus of Elasticity:</td>
            <td align="right">$me1</td>
            <td align="left">$me2</td>
        </tr>
        <tr>
            <td align="right"><b>Gage Parameters</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Gage Length:</td>
            <td align="right">$gl1</td>
            <td align="left">$gl2</td>
        </tr>
        <tr>
            <td align="right">Gage Factor:</td>
            <td align="right">$gf1</td>
            <td align="left"></td>
        </tr>
        <tr><td height="20"></td></tr>
        <tr>
            <td align="right"><b>Calculated Values</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Nominal Gage Strain:</td>
            <td align="right">$gs1</td>
            <td align="left">&micro;&epsilon;</td>
        </tr>
        <tr>
            <td align="right">Strain Variation</td>
            <td align="right">$sv1</td>
            <td align="left">&percnt;</td>
        </tr>
        <tr>
            <td align="right">Span at Applied Force</td>
            <td align="right">$sf1</td>
            <td align="left">mV&frasl;V</td>
        </tr>
        <tr><td height="20"></td></tr>
    </table>
    <center>
        <img src="data:image/jpg;base64," />
    </center>
</body>
</html>