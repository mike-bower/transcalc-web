<!DOCTYPE html>

<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <title>Span Shift with Temperature Change, Optimum Shunt</title>
</head>
<body>
    <table width="900" style="table-layout:fixed; font-size: 20px" align="center">
        <colgroup>
            <col width="50" />
            <col width="12" />
            <col width="38" />
        </colgroup>
        <tr>
            <th colspan="3" style="font-size:30px">
                Span Shift with Temperature Change, Optimum Shunt
            </th>
        </tr>
        <tr><td height="20"></td></tr>
        <tr>
            <td align="right"><b>Low Temperature</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Span:</td>
            <td align="right">$ls1</td>
            <td align="left">mV&frasl;V</td>
        </tr>
        <tr>
            <td align="right">Rbridge:</td>
            <td align="right">$lb1</td>
            <td align="left">ohms</td>
        </tr>
        <tr>
            <td align="right">Rmod:</td>
            <td align="right">$lm1</td>
            <td align="left">ohms</td>
        </tr>
        <tr>
            <td align="right"><b>Ambient Temperature</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Span:</td>
            <td align="right">$as1</td>
            <td align="left">mV&frasl;V</td>
        </tr>
        <tr>
            <td align="right">Rbridge:</td>
            <td align="right">$ab1</td>
            <td align="left">ohms</td>
        </tr>
        <tr>
            <td align="right">Rmod:</td>
            <td align="right">$am1</td>
            <td align="left">ohms</td>
        </tr>
        <tr>
            <td align="right"><b>High Temperature</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Span:</td>
            <td align="right">$hs1</td>
            <td align="left">mV&frasl;V</td>
        </tr>
        <tr>
            <td align="right">Rbridge:</td>
            <td align="right">$hb1</td>
            <td align="left">ohms</td>
        </tr>
        <tr>
            <td align="right">Rmod:</td>
            <td align="right">$hm1</td>
            <td align="left">ohms</td>
        </tr>
        <tr><td height="20"></td></tr>
        <tr>
            <td align="right"><b>Calculated Values</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Rshunt:</td>
            <td align="right">$rs1</td>
            <td align="left">ohms</td>
        </tr>
        <tr>
            <td align="right">Span:</td>
            <td align="right">$sl1</td>
            <td align="left">mV&frasl;V (low temperature)</td>
        </tr>
        <tr>
            <td align="right">Span:</td>
            <td align="right">$sa1</td>
            <td align="left">mV&frasl;V (ambient temperature)</td>
        </tr>
        <tr>
            <td align="right">Span:</td>
            <td align="right">$sh1</td>
            <td align="left">mV&frasl;V (high temperature)</td>
        </tr>
        <tr><td height="20"></td></tr>
    </table>
    <center>
        <img src="data:image/jpg;base64," />
    </center>
</body>
</html>