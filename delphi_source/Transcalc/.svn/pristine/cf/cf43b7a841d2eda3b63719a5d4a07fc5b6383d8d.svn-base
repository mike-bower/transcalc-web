<!DOCTYPE html>

<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <title>Zero Shift with Temperature Change</title>
</head>
<body>
    <table width="900" style="table-layout:fixed; font-size: 20px" align="center">
        <colgroup>
            <col width="50" />
            <col width="12" />
            <col width="38" />
        </colgroup>
        <tr>
            <th colspan="3" style="font-size:30px">
                Zero Shift with Temperature Change
            </th>
        </tr>
        <tr><td height="20"></td></tr>
        <tr>
            <td align="right"><b>Low Temperature</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Temperature:</td>
            <td align="right">$lt1</td>
            <td align="left">$lt2</td>
        </tr>
        <tr>
            <td align="right">V out:</td>
            <td align="right">$lv1</td>
            <td align="left">mV&frasl;V</td>
        </tr>
        <tr>
            <td align="right"><b>High Temperature</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Temperature:</td>
            <td align="right">$ht1</td>
            <td align="left">$ht2</td>
        </tr>
        <tr>
            <td align="right">V out:</td>
            <td align="right">$hv1</td>
            <td align="left">mV&frasl;V</td>
        </tr>
        <tr>
            <td align="right"><b>Compensation Resistor</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Material:</td>
            <td align="right">$rm1</td>
        </tr>
        <tr>
            <td align="right"><b>TCR</b></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Resistor TCR:</td>
            <td align="right">$rt1</td>
            <td align="left">$rt2</td>
        </tr>
        <tr>
            <td align="right">Bridge Resistance:</td>
            <td align="right">$br1</td>
            <td align="left">ohms</td>
        </tr>

        <tr><td height="20"></td></tr>
        <tr>
            <td align="right"><b>Calculated Values</b></td>
            <td align="right"></td>
            <td align="left"></td>
        </tr>
        <tr>
            <td align="right">Compensation Resistor:</td>
            <td align="right">$cr1</td>
            <td align="left">ohms</td>
        </tr>
        <tr>
            <td align="right">Bridge Arm:</td>
            <td align="right">$ba1</td>
        </tr>
        <tr><td height="20"></td></tr>
    </table>
    <center>
        <img src="data:image/jpg;base64," />
    </center>
</body>
</html>