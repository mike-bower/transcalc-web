(***********************************************)
(*  Dual Bending Beam Unit                     *)
(***********************************************)
unit Dualbb;

interface

uses
  SysUtils, WinTypes, WinProcs, Messages, Classes, Graphics, Controls,
  StdCtrls, ExtCtrls, Forms, Buttons, acStream, acList, Log, LogItem, LogStrm,
  Printers;

const
  MAXTEXTLENGTH   = 40;
  MAXERRORLENGTH  = 255;

type
  RealType = double;

(***********************************************)
(*  TDual bending beam Object                  *)
(***********************************************)
type TDualBendingBeam = class(TLogItem)
private
  FAppliedLoad      : string;
  FBeamWidth        : string;
  FThickness        : string;
  FGageDistance     : string;
  FDistanceLoad     : string;
  FModulus          : string;
  FGageLength       : string;
  FGageFactor       : string;
  FAverage          : string;
  FGradient         : string;
  FFullSpan         : string;
  TheString         : string;
protected
  procedure AssignTo(Dest: TPersistent); override;
  procedure InitFields; override;
  procedure SaveToStream(Stream : TacObjStream); override;
  procedure ReadFromStream(Stream: TacObjStream); override;
  procedure ShowTheForm; override;
  procedure PrintTheForm; override;
  function GetAsString: String; override;
public
  constructor create;
  destructor destroy; override ;
  property AppliedLoad: string read FAppliedLoad write FAppliedLoad;
  property BeamWidth: string read FBeamWidth write FBeamWidth;
  property Thickness: string read FThickness write FThickness;
  property GageDistance: string read FGageDistance write FGageDistance;
  property DistanceLoad: string read FDistanceLoad write FDistanceLoad;
  property Modulus: string read FModulus write FModulus;
  property GageLength: string read FGageLength write FGageLength;
  property GageFactor: string read FGageFactor write FGageFactor;
  property Average: string read FAverage write FAverage;
  property Gradient: string read FGradient write FGradient;
  property FullSpan: string read FFullSpan write FFullSpan;
  property TheStringText: string read TheString write TheString;
end;

(***********************************************)
(*  TDualBBFrm Form Object                     *)
(***********************************************)
type
  TDualBBFrm = class(TForm)
    BN_OK: TBitBtn;
    BN_Cancel: TBitBtn;
    Panel1: TPanel;
    GroupBox1: TGroupBox;
    EB_AppliedLoad: TEdit;
    GroupBox2: TGroupBox;
    Label1: TLabel;
    Label2: TLabel;
    Label3: TLabel;
    EB_BeamWidth: TEdit;
    EB_Thickness: TEdit;
    EB_DistancebtGage: TEdit;
    GroupBox4: TGroupBox;
    EB_GageLength: TEdit;
    ST_LoadUnit: TLabel;
    ST_WidthUnit: TLabel;
    ST_ThicknessUnit: TLabel;
    ST_DistanceUnit: TLabel;
    ST_LengthUnit: TLabel;
    Panel3: TPanel;
    GroupBox5: TGroupBox;
    Label6: TLabel;
    Label7: TLabel;
    ST_AvgStrain: TLabel;
    ST_Gradient: TLabel;
    Label14: TLabel;
    Label15: TLabel;
    Label29: TLabel;
    Label30: TLabel;
    ST_FullSpan: TLabel;
    Label32: TLabel;
    EB_GageFactor: TEdit;
    Label31: TLabel;
    BN_Compute: TBitBtn;
    BN_Help: TBitBtn;
    ST_KGFUnit: TLabel;
    ST_KGF: TLabel;
    BN_Print: TBitBtn;
    ST_ModulusUnits: TLabel;
    EB_Modulus: TEdit;
    Image1: TImage;
//    Sheet1: TSheet;
    procedure FormCreate(Sender: TObject);
    procedure BN_ComputeClick(Sender: TObject);
    procedure BN_CancelClick(Sender: TObject);
    procedure FormActivate(Sender: TObject);
    procedure BN_OKClick(Sender: TObject);
    function Min_StrainA: RealType;
    function Min_StrainB: RealType;
    function Min_StrainC: RealType;
    function Min_StrainD: RealType;
    function Max_StrainA: RealType;
    function Max_StrainB: RealType;
    function Max_StrainC: RealType;
    function Max_StrainD: RealType;
    function Avg_StrainA: RealType;
    function Avg_StrainB: RealType;
    function Avg_StrainC: RealType;
    function Avg_StrainD: RealType;
    function CalculateGradientA: RealType;
    function CalculateGradientB: RealType;
    function CalculateGradientC: RealType;
    function CalculateGradientD: RealType;
    function FullBridgeSensitivity: RealType;
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure EB_AppliedLoadExit(Sender: TObject);
    procedure BN_PrintClick(Sender: TObject);
    procedure BN_HelpClick(Sender: TObject);
  private
    Old_AppliedLoad  : string;
    Old_BeamWidth    : string;
    Old_Thickness    : string;
    Old_Height       : string;
    Old_GageDistance : string;
    Old_DistanceLoad : string;
    Old_Modulus      : string;
    Old_GageLength   : string;
    Old_GageFactor   : string;
    Old_AvgStrain    : string;
    Old_Gradient     : string;
    Old_FullSpan     : string;
    AvgStrainText    : string;
    GradientText     : string;
    SensitiveText    : string;
    IsThereAnError   : boolean;
    ExceptionRaised  : boolean;
    Load             : RealType;
    Width            : RealType;
    Thick            : RealType;
    TheHeight        : RealType;
    GageDist         : RealType;
    DistLoad         : RealType;
    Elasticity       : RealType;
    Length           : RealType;
    Factor           : RealType;
    EMinA            : RealType;
    EMinB            : RealType;
    EMinC            : RealType;
    EMinD            : RealType;
    EMaxA            : RealType;
    EMaxB            : RealType;
    EMaxC            : RealType;
    EMaxD            : RealType;
    EAvgA            : RealType;
    EAvgB            : RealType;
    EAvgC            : RealType;
    EAvgD            : RealType;
    EAvg             : RealType;
    TheGradientA     : RealType;
    TheGradientB     : RealType;
    TheGradientC     : RealType;
    TheGradientD     : RealType;
    TheGradient      : RealType;
    FullSensitivity  : RealType;
  public
    DualBendingObject : TDualBendingBeam;
    DualBBeamChosen   : boolean;
  end;

var
  DualBBFrm: TDualBBFrm;

implementation
uses MainMenu, Convert, Design;
{$R *.DFM}

(***********************************************)
(*  DualBEndingBeam Object Methods             *)
(***********************************************)

(***********************************************************************)
{TDualBendingBeam.create}
constructor TDualBendingBeam.create;
begin
  {...creating object}
  inherited create;
  {...associating string with object}
  TheString := 'Bending - Dual Beam';
end;

(***********************************************************************)
{TDualBendingBeam.destroy}
destructor TDualBendingBeam.destroy;
begin
  {...destroying object}
  inherited destroy;
end;

(***********************************************************************)
{TDualBendingBeam.GetAsString}
function TDualBendingBeam.GetAsString: string;
begin
  Result := TheString;
end;

(***********************************************************************)
{TDualBendingBeam.ShowTheForm}
procedure TDualBendingBeam.ShowTheForm;
begin
  Application.CreateForm(TDualBBFrm, DualBBFrm);
  DualBBFrm.showmodal;
end;

(***********************************************************************)
{TDualBendingBeam.PrintTheForm}
procedure TDualBendingBeam.PrintTheForm;
var
  Sender : TObject;
begin
  sender := self ;
  Application.CreateForm(TDualBBFrm, DualBBFrm);
  DualBBFrm.visible := false;
  DualBBFrm.FormActivate(sender);
  DualBBFrm.BN_PrintClick(sender);
  DualBBFrm.BN_CancelClick(Sender);
end;

(***********************************************************************)
{TDualBendingBeam.AssignTo}
procedure TDualBendingBeam.AssignTo(Dest: TPersistent);
begin
  if (Dest is TDualBendingBeam) and (Self is Dest.ClassType) then begin
    inherited AssignTo(TLogItem(Dest));
    with Dest as TDualBendingBeam do begin
      FAppliedLoad := self.FAppliedLoad;
      FBeamWidth := self.FBeamWidth;
      FThickness := self.FThickness;
      FGageDistance := self.FGageDistance;
      FDistanceLoad := self.DistanceLoad;
      FModulus := self.FModulus;
      FGageLength := self.FGageLength;
      FGageFactor := self.FGageFactor;
      FAverage := self.FAverage;
      FGradient := self.FGradient;
      FFullSpan := self.FFullSpan;
      TheString := self.TheString;
    end;
  end
  else begin
    inherited AssignTo(Dest);
  end;
end;

(***********************************************************************)
{TDualBendingBeam.InitFields}
procedure TDualBendingBeam.InitFields;
begin
  inherited InitFields;
end;

(***********************************************************************)
{TDualBendingBeam.SaveToStream}
procedure TDualBendingBeam.SaveToStream(Stream: TacObjStream);
begin
  inherited SaveToStream(Stream);
  Stream.SaveBuffer(FAppliedLoad, sizeof(string));
  Stream.SaveBuffer(FBeamWidth, sizeof(string));
  Stream.SaveBuffer(FThickness, sizeof(string));
  Stream.SaveBuffer(FGageDistance, sizeof(string));
  Stream.SaveBuffer(FDistanceLoad, sizeof(string));
  Stream.SaveBuffer(FModulus, sizeof(string));
  Stream.SaveBuffer(FGageLength, sizeof(string));
  Stream.SaveBuffer(FGageFactor, sizeof(string));
  Stream.SaveBuffer(FAverage, sizeof(string));
  Stream.SaveBuffer(FGradient, sizeof(string));
  Stream.SaveBuffer(FFullSpan, sizeof(string));
  Stream.SaveBuffer(TheString, sizeof(string));
end;

(***********************************************************************)
{TDualBendingBeam.ReadFromStream}
procedure TDualBendingBeam.ReadFromStream(Stream: TacObjStream);
begin
  inherited ReadFromStream(Stream);
  Stream.ReadBuffer(FAppliedLoad, sizeof(string));
  Stream.ReadBuffer(FBeamWidth, sizeof(string));
  Stream.ReadBuffer(FThickness, sizeof(string));
  Stream.ReadBuffer(FGageDistance, sizeof(string));
  Stream.ReadBuffer(FDistanceLoad, sizeof(string));
  Stream.ReadBuffer(FModulus, sizeof(string));
  Stream.ReadBuffer(FGageLength, sizeof(string));
  Stream.ReadBuffer(FGageFactor, sizeof(string));
  Stream.ReadBuffer(FAverage, sizeof(string));
  Stream.ReadBuffer(FGradient, sizeof(string));
  Stream.ReadBuffer(FFullSpan, sizeof(string));
  Stream.ReadBuffer(TheString, sizeof(string));
end;

(***********************************************)
(*  Dual Bending Beam Form Methods             *)
(***********************************************)

(***********************************************************************)
{ TDualBBFrm.Min_StrainA}
function TDualBBFrm.Min_StrainA: RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  FirstTerm      : RealType;
  SecondTerm     : RealType;
  ThirdTerm      : RealType ;
  StrainResult   : RealType;
  Button         : integer;
begin
  FirstTerm := 0.0 ;
  SecondTerm := 0.0 ;
  ThirdTerm := 0.0 ;
  StrainResult := 0.0 ;
  ExceptionRaised := false;
  try
    FirstTerm := Load/(Elasticity * Width);
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoMinStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  try
    ThirdTerm := (3*((-GageDist/2) + (Length/2)))/sqr(Thick);
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoMinStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  try
    StrainResult :=  (FirstTerm * (- ThirdTerm)) * 1e6;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoMinStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  Min_StrainA := StrainResult;
end;

