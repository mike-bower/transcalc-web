(************************************************)
(*  Span vs Temp 3pt C12-10ohm Resistor Unit    *)
(************************************************)
unit Spn31210;

interface
uses
  SysUtils, WinTypes, WinProcs, Messages, Classes, Graphics, Controls,
  StdCtrls, ExtCtrls, Forms, Buttons, acList, acStream, Log, LogItem,
  LogStrm, Dialogs, Resistor, Printers;

type
  RealType = double;

(************************************************)
(*  TRung Object                                *)
(************************************************)
type
  TRung = class(TLogItem)
  private
    CuttingArea : TRect;
  public
    RungIsCut   : Boolean;
    constructor create(left, top, right, bottom : integer);
    destructor done; virtual;
    function IsClicked(p : TPoint):boolean;
    function IsCut: integer;
    procedure Cut(TheCanvas: TCanvas);
    procedure Fix(TheCanvas: TCanvas);
    procedure SaveToStream(Stream : TacObjStream); override;
    procedure ReadFromStream(Stream : TacObjStream); override;
    procedure Redraw(TheCanvas: TCanvas);
end;

(************************************************)
(*  TC1210 Resistor Object                      *)
(************************************************)
type
  TC1210Span3ptResist = class(TResistor)
  private
   FStartResistance : shortstring;
   TheString : shortstring;
  protected
    procedure AssignTo(Dest: TPersistent); override;
    procedure ShowTheForm; override;
    function GetAsString : string; override;
    procedure InitFields; override;
    procedure SaveToStream(Stream: TacObjStream); override;
    procedure ReadFromStream(Stream: TacObjStream); override;
  public
 {property and functions here}
    FA1, FA2, FA3, FA4, FA5, FA6, FA7, FA8, FA9, FA10 : TRung;
    SA1, SA2, SA3, SA4, SA5, SA6, SA7, SA8, SA9, SA10 : TRung;
    B1, B2, B3, B4                                    : TRung;
    C1, C2, C3, C4                                    : TRung;
    constructor create;
    destructor destroy; override;
    property StartResistance : shortstring read FStartResistance write FStartResistance;
    property TheStringText: shortstring read TheString write TheString;
end;

(************************************************)
(*  TC1210 Resistor Form Object                 *)
(************************************************)
type
  TSpan3ptC1210Form = class(TForm)
    Image1: TImage;
    BN_OK: TBitBtn;
    BN_Cancel: TBitBtn;
    BN_Restore: TBitBtn;
    BN_Help: TBitBtn;
    BN_Print: TBitBtn;
    GroupBox1: TGroupBox;
    Label2: TLabel;
    EB_StartingRes: TEdit;
    GroupBox2: TGroupBox;
    ST_CalculatedRes: TLabel;
    Label1: TLabel;
    procedure Image1MouseDown(Sender: TObject; Button: TMouseButton;
      Shift: TShiftState; X, Y: Integer);
    procedure BN_RestoreClick(Sender: TObject);
    procedure BN_OKClick(Sender: TObject);
    procedure FormActivate(Sender: TObject);
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure FormCreate(Sender: TObject);
    procedure ReCalculate;
    procedure PrintForm;
    function GotFormImage: TBitmap;
    procedure BN_PrintClick(Sender: TObject);
    procedure EB_StartingResExit(Sender: TObject);
    procedure BN_HelpClick(Sender: TObject);
  public
    C1210Span3ptResist : TC1210Span3ptResist;
  private
end;

var
  Span3ptC1210Form: TSpan3ptC1210Form;

implementation
uses MainMenu;
{$R *.DFM}

(***********************************************)
(*              TRung Methods                  *)
(***********************************************)

(***********************************************************************)
{TRung.create}
constructor TRung.create(left, top, right, bottom : integer);
begin
  inherited create;
  {...creating the TRung object setting the cutting area and intializing RungIsCut}
  RungIsCut := false;
  CuttingArea.left := left;
  CuttingArea.top := top;
  CuttingArea.right := right;
  CuttingArea.bottom := bottom;
end;

(***********************************************************************)
{TRung.done}
destructor TRung.done;
begin
  {...destroying the object}
  Done;
end;

(***********************************************************************)
{TRung.Redraw}
procedure TRung.Redraw(TheCanvas: TCanvas);
begin
  {..deciding whether to cut or fix the rung depending on whether it was fixed or cut}
  with TheCanvas do begin
    if RungIsCut = False then begin {...we need to restore the rung}
      pen.Color := clGray;
      brush.color := clGray;
    end
    else begin          {...we need to cut rung}
      pen.Color := clYellow;
      brush.color := clYellow;
    end;
    {...setting pen and  brush attributes}
    brush.Style := bsSolid;
    pen.style := psSolid;
    Rectangle(CuttingArea.Left, CuttingArea.top, CuttingArea.right, CuttingArea.Bottom);
  end;
end;

(***********************************************************************)
{TRung.SaveToStream}
procedure TRung.SaveToStream(Stream : TacObjStream);
begin
  inherited SaveToStream(Stream);
  Stream.SaveTRect(CuttingArea);
  Stream.SaveBuffer(RungIsCut, sizeof(Boolean));
end;

(***********************************************************************)
{TRung.ReadFromStream}
procedure TRung.ReadFromStream(Stream : TacObjStream);
begin
  inherited ReadFromStream(Stream);
  Stream.ReadTRect(CuttingArea);
  Stream.ReadBuffer(RungIsCut, sizeof(Boolean));
end;

(***********************************************************************)
{TRung.IsClicked}
function TRung.IsClicked(p : TPoint): boolean;
begin
  {...determines if the point clicked is in which rectangle}
  Result := PtInRect(CuttingArea, p);
end;

(***********************************************************************)
{TRung.IsCut}
function TRung.IsCut: integer;
begin
  if RungIsCut then begin
    IsCut := 0;
  end
  else begin
    IsCut  := 1;
  end;
end;

(***********************************************************************)
{TRung.Cut}
procedure TRung.Cut(TheCanvas: TCanvas);
begin
  {...setting the RungIsCut Value}
  RungIsCut := true;
  {...Cutting the rung}
  Redraw(TheCanvas);
end;

(***********************************************************************)
{TRung.Fix}
procedure TRung.Fix(TheCanvas: TCanvas);
begin
  {...setting RungIsCut}
  RungIsCut := false;
  {...fixing the rung}
  Redraw(TheCanvas);
end;

(***********************************************)
(*    TC11OptShuntResist Methods               *)
(***********************************************)

(***********************************************************************)
{TC1210Span3ptResist.create}
constructor TC1210Span3ptResist.create;
begin
  inherited create;
  {...setting the string so can identify which object it is}
  TheString := 'C12 10 ohm Resistor';
  {...setting the cutting area of each rung}
  FA10 := TRung.Create(36, 213, 55, 219);
  FA9  := TRung.Create(36, 193, 55, 199);
  FA8  := TRung.Create(36, 173, 55, 179);
  FA7  := TRung.Create(36, 153, 55, 159);
  FA6  := TRung.Create(36, 133, 55, 139);
  FA5  := TRung.Create(36, 113, 55, 119);
  FA4  := TRung.Create(36, 93, 55, 99);
  FA3  := TRung.Create(36, 73, 55, 79);
  FA2  := TRung.Create(36, 53, 55, 59);
  FA1  := TRung.Create(36, 33, 55, 39);
  SA10 := TRung.Create(96, 213, 117, 219);
  SA9  := TRung.Create(96, 193, 117, 199);
  SA8  := TRung.Create(96, 173, 117, 179);
  SA7  := TRung.Create(96, 153, 117, 159);
  SA6  := TRung.Create(96, 133, 117, 139);
  SA5  := TRung.Create(96, 113, 117, 119);
  SA4  := TRung.Create(96, 93, 117, 99);
  SA3  := TRung.Create(96, 73, 117, 79);
  SA2  := TRung.Create(96, 53, 117, 59);
  SA1  := TRung.Create(96, 33, 117, 39);
  B4  := TRung.Create(222, 100, 226, 110);
  B3  := TRung.Create(222, 76, 226, 85);
  B2  := TRung.Create(222, 50, 226, 62);
  B1  := TRung.Create(222, 27, 226, 36);
  C4  := TRung.Create(222, 198, 226, 212);
  C3  := TRung.Create(222, 174, 226, 183);
  C2  := TRung.Create(222, 149, 226, 159);
  C1  := TRung.Create(222, 124, 226, 134);
end;

(***********************************************************************)
{TC1210Span3ptResist.destroy}
destructor TC1210Span3ptResist.destroy;
begin
  {...destroying object}
  inherited destroy;
end;

(***********************************************************************)
{TC1210Span3ptResist.GetAsString}
function TC1210Span3ptResist.GetAsString : string;
begin
  Result := TheString;
end;

(***********************************************************************)
{TC1210Span3ptResist.ShowTheForm}
procedure TC1210Span3ptResist.ShowTheForm;
begin
  Application.CreateForm(TSpan3ptC1210Form, Span3ptC1210Form);
  Span3ptC1210Form.showmodal;
end;

(***********************************************************************)
{TC1210Span2ptResist.AssignTo}
procedure TC1210Span3ptResist.AssignTo(Dest: TPersistent);
begin
  if ((Dest is TC1210Span3ptResist) and (Self is Dest.ClassType)) then begin
    inherited AssignTo(TLogItem(Dest));
    with Dest as TC1210Span3ptResist do begin
      FStartResistance := self.FStartResistance;
      TheString := self.TheString;
      FA1  := self.FA1;
      FA2  := self.FA2;
      FA3  := self.FA3;
      FA4  := self.FA4;
      FA5  := self.FA5;
      FA6  := self.FA6;
      FA7  := self.FA7;
      FA8  := self.FA8;
      FA9  := self.FA9;
      FA10 := self.FA10;
      SA1  := self.SA1;
      SA2  := self.SA2;
      SA3  := self.SA3;
      SA4  := self.SA4;
      SA5  := self.SA5;
      SA6  := self.SA6;
      SA7  := self.SA7;
      SA8  := self.SA8;
      SA9  := self.SA9;
      SA10 := self.SA10;
      B1  := self.B1;
      B2  := self.B2;
      B3  := self.B3;
      B4  := self.B4;
      C1  := self.C1;
      C2  := self.C2;
      C3  := self.C3;
      C4  := self.C4;
    end;
  end
  else begin
    inherited AssignTo(Dest);
  end;
end;

(***********************************************************************)
