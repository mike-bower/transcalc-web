(***********************************************************************)
{TSpan3ptC1210Form.BN_RestoreClick}
procedure TSpan3ptC1210Form.ReCalculate;
const
  {FOIL SQUARES - SEE JRW's B.S.}
  S1  = 1.6;
  S2  = 1.0;
  S3  = 1.8;
  S4  = 1.0;
  S5  = 0.26;
  S6  = 2.7;
  S7  = 1.0;
  S8  = 6.375;
  S9  = 0.0;
  S10 = 1.0;
  S11 = 0.0;
  S12 = 1.5;
  S13 = 26.1;
  S14 = 52.3;
  S15 = 0.0;
  S16 = 0.0;
  S17 = 2.0;
  S18 = 2.0;
  S19 = 0.0;
  S20 = 195.3;
  S21 = 6.9;
  S22 = 1.5;
  S23 = 1.5;
  TOTALSQUARES = 220.0;
var
  ErrorMsg      : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption  : array[0..MAXERRORLENGTH-1] of char;
  ErrorAnd      : array[0..MAXERRORLENGTH-1] of char;
  ErrorUnit     : array[0..MAXERRORLENGTH-1] of char;
  cs            : array[0..255] of char;
  EditStrings   : string;
  s             : string;
  StrMsg        : string;
  StrUnit       : string;
  StrAnd        : string;
  C             : RealType;
  CFA           : RealType;
  CSA           : RealType;
  CB1           : RealType;
  CB2           : RealType;
  CB3           : RealType;
  CB4           : RealType;
  CC1           : RealType;
  CC2           : RealType;
  CC3           : RealType;
  CC4           : RealType;
  Squares       : RealType;
  Rtotal        : RealType;
  RStart        : RealType;
  OhmsPerSquare : RealType;
  code          : Integer;
  Button        : integer;
begin
  OhmsPerSquare := 0.0 ;
    { Read Starting Resistance}
  s := EB_StartingRes.text;
  val(s, Rstart, code);
  if code <> 0 then begin
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes.caption := '';
    exit;
  end
  else if (Rstart < 7) or (RStart > 13) then begin
    LoadString(hinstance, ID_SZ_WrongResistor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    EditStrings := StrMsg + ' ' + '7.0' + ' ' + StrAnd + ' ' + '13.0' + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes.caption := '';
    exit;
  end;
  if RStart > 0 then begin
    OhmsPerSquare := Rstart/TOTALSQUARES;
  end;
  {Calculate Ladder "A"}
  C  := (C1210Span3ptResist.FA1.IsCut / S3) + (1 / (2 * S7 + S6));
  C  := (C1210Span3ptResist.FA2.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.FA3.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.FA4.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.FA5.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.FA6.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.FA7.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.FA8.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.FA9.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  CFA := (C1210Span3ptResist.FA10.IsCut / S10) + (1 / (2 * S2 + 1/C));
  {Calculate Ladder "SA"}
  C  := (C1210Span3ptResist.SA1.IsCut / S3) + (1 / (2 * S7 + S6));
  C  := (C1210Span3ptResist.SA2.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.SA3.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.SA4.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.SA5.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.SA6.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.SA7.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.SA8.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1210Span3ptResist.SA9.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  CSA := (C1210Span3ptResist.SA10.IsCut / S10) + (1 / (2 * S2 + 1/C));
  {Calculate Ladder "B"}
  CB1 := (C1210Span3ptResist.B1.IsCut / S12) + (1 / S13);
  CB2 := (C1210Span3ptResist.B2.IsCut / S12) + (1 / S13);
  CB3 := (C1210Span3ptResist.B3.IsCut / S12) + (1 / S13);
  CB4 := (C1210Span3ptResist.B4.IsCut / S12) + (1 / S13);
  {Calculate Ladder "C"}
  CC1  := (C1210Span3ptResist.C1.IsCut / S12) + (1 / S14);
  CC2  := (C1210Span3ptResist.C2.IsCut / S12) + (1 / S14);
  CC3  := (C1210Span3ptResist.C3.IsCut / S12) + (1 / S14);
  CC4  := (C1210Span3ptResist.C4.IsCut / S12) + (1 / S14);
  { Calculate total resistance}
  Squares := 1/CFA + 1/CSA + 1/CB1 + 1/CB2 + 1/CB3 + 1/CB4 + 1/CC1 + + 1/CC2
             + 1/CC3 + 1/CC4 + S20 + S8 + S4 + S22 + S1 + S23;
  RTotal := OhmsPerSquare * Squares;
  {Display}
  if RTotal > 0 then begin
//    Str(Rtotal:7:1, s);
    s := format('%7.1f',[Rtotal]) ;
    StrPcopy(cs,s);
    ST_CalculatedRes.caption := s;
  end
  else
    ST_CalculatedRes.caption := s;
end;

