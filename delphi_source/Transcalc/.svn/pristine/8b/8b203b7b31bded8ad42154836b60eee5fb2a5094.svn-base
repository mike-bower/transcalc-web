program Xconfig;

uses                   
  Forms,
  Config in 'CONFIG.PAS' {XCalcConfigFrm},
  vcl.HtmlHelpViewer;
{$R *.RES}

begin
  Application.Title := 'TansCalc Configuration';
  Application.HelpFile := 'XCALC.HLP';
  Application.CreateForm(TXCalcConfigFrm, XCalcConfigFrm);
  Application.Run;
end.
