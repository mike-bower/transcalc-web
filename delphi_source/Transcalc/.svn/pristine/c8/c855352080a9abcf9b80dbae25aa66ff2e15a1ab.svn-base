begin
   Stream := TResourceStream.Create(HInstance, 'SqrCol', RT_RCDATA)  ;
   strstream := TStringStream.Create() ;

   try
     strstream.LoadFromStream(stream)     ;
     htmlText := strstream.DataString ;
   finally
     StrStream.Free() ;
     Stream.Free() ;
   end;
   htmlText := StringReplace(htmlText, '$af2',ST_LoadUnit.caption, [rfReplaceAll, rfIgnoreCase]) ;
   htmlText := StringReplace(htmlText, '$bw2',ST_WidthUnit.caption, [rfReplaceAll, rfIgnoreCase]) ;
   htmlText := StringReplace(htmlText, '$bd2',ST_DepthUnit.caption, [rfReplaceAll, rfIgnoreCase]) ;
   htmlText := StringReplace(htmlText, '$me2',ST_ModulusUnit.caption, [rfReplaceAll, rfIgnoreCase]) ;

