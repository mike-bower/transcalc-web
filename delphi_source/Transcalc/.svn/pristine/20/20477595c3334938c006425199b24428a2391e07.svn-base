  TRndShrWebFrm = class(TForm)
    BN_OK: TBitBtn;
    BN_Cancel: TBitBtn;
    Panel1: TPanel;
    GroupBox6: TGroupBox;
    ST_LoadUnit: TLabel;
    EB_AppliedLoad: TEdit;
    GroupBox7: TGroupBox;
    Label7: TLabel;
    Label8: TLabel;
    Label9: TLabel;
    Label10: TLabel;
    ST_WidthUnit: TLabel;
    ST_DiameterUnit: TLabel;
    ST_ThickUnit: TLabel;
    ST_HeightUnit: TLabel;
    EB_Width: TEdit;
    EB_Diameter: TEdit;
    EB_Thickness: TEdit;
    EB_Height: TEdit;
    GroupBox8: TGroupBox;
    EB_Poisson: TEdit;
    GroupBox10: TGroupBox;
    Panel2: TPanel;
    GroupBox1: TGroupBox;
    GroupBox2: TGroupBox;
    Label18: TLabel;
    Label3: TLabel;
    ST_Average: TLabel;
    Label21: TLabel;
    Label22: TLabel;
    ST_ModulusUnit: TLabel;
    Label25: TLabel;
    Label27: TLabel;
    ST_FullSpan: TLabel;
    Label29: TLabel;
    EB_Modulus: TEdit;
    EB_GageFactor: TEdit;
    BN_Compute: TBitBtn;
    BN_Help: TBitBtn;
    ST_KGF: TLabel;
    ST_KgfUnit: TLabel;
    BN_Print: TBitBtn;
    Image1: TImage;
//    Sheet1: TSheet;
    procedure FormCreate(Sender: TObject);
    procedure BN_ComputeClick(Sender: TObject);
    procedure BN_CancelClick(Sender: TObject);
    procedure FormActivate(Sender: TObject);
    procedure BN_OKClick(Sender: TObject);
{    function Min_Strain : RealType;  ---Removed CSS 12/1/97}
{    function Max_Strain : RealType;  ---Removed CSS 12/1/97}
    function Avg_Strain : RealType;
    function CalculateGradient : RealType;
    function FullBridgeSensitivity : RealType;
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure EB_AppliedLoadExit(Sender: TObject);
    procedure BN_PrintClick(Sender: TObject);
    procedure BN_HelpClick(Sender: TObject);
    function CalculateSpan: RealType;
    function Power(Base: realtype; Exponent: realtype): double;
  private
    Old_AppliedLoad     : string;
    Old_Width           : string;
    Old_Height          : string;
    Old_Thickness       : string;
    Old_Diameter        : string;
    Old_Poisson         : string;
    Old_Modulus         : string;
    Old_GageLength      : string;
    Old_GageFactor      : string;
    Old_AvgStrain       : string;
    Old_Gradient        : string;
    Old_FullSpan        : string;
    AvgStrainText       : string;
    GradientText        : string;
    SensitiveText       : string;
    ExceptionRaised     : boolean;
    IsThereAnError      : boolean;
    Load                : RealType;
    ShrWidth            : RealType;
    ShrHeight           : RealType;
    ShrThickness        : RealType;
    ShrDiameter         : RealType;
    Ratio               : RealType;
    Elasticity          : RealType;
    Length              : RealType;
    Factor              : RealType;
    EMax                : RealType;
    EMin                : RealType;
    TheGradient         : RealType;
    EAvg                : RealType;
    FullSensitivity     : RealType;
  public
    RndShearObject  : TRndShear;
    RndShrWebChosen : boolean;
  end;

var
  RndShrWebFrm: TRndShrWebFrm;

implementation
uses MainMenu, Convert, Design;
{$R *.DFM}

(***********************************************)
(*  Round Shear Web Object Methods             *)
(***********************************************)

(***********************************************************************)
{TRndShear.create}
constructor TRndShear.create;
begin
  {...creating object}
  inherited create;
  {...associating string with object}
  TheString := 'Shear - Round Web';
end;

(***********************************************************************)
{TRndShear.destroy}
destructor TRndShear.destroy;
begin
  {...destroying object}
  inherited destroy;
end;

(***********************************************************************)
{TRndShear.GetAsString}
function TRndShear.GetAsString: string;
begin
  Result := TheString;
end;

(***********************************************************************)
{TRndShear.ShowTheForm}
procedure TRndShear.ShowTheForm;
begin
  Application.CreateForm(TRndShrWebFrm, RndShrWebFrm);
  RndShrWebFrm.showmodal;
end;

(***********************************************************************)
{TRndShear.PrintTheForm}
procedure TRndShear.PrintTheForm;
var
  Sender : TObject;
begin
  Sender := self ;
  Application.CreateForm(TRndShrWebFrm, RndShrWebFrm);
  RndShrWebFrm.visible := false;
  RndShrWebFrm.FormActivate(sender);
  RndShrWebFrm.BN_PrintClick(sender);
  RndShrWebFrm.BN_CancelClick(Sender);
end;

(***********************************************************************)
{TRndShear.AssignTo}
procedure TRndShear.AssignTo(Dest: TPersistent);
begin
  if (Dest is TRndShear) and (Self is Dest.ClassType) then begin
    inherited AssignTo(TLogItem(Dest));
    with Dest as TRndShear do begin
      FAppliedLoad := self.FAppliedLoad;
      FWidth := self.FWidth;
      FHeight := self.FHeight;
      FThickness := self.FThickness;
      FDiameter := self.FDiameter;
      FPoisson := self.FPoisson;
      FModulus := self.FModulus;
      FGageLength := self.FGageLength;
      FGageFactor := self.FGageFactor;
      FAvgStrain :=  self.FAvgStrain;
      FGradient  := self.FGradient;
      FFullSpan := self.FFullSpan;
      TheString := self.TheString;
    end;
  end
  else begin
    inherited AssignTo(Dest);
  end;
end;

(***********************************************************************)
{TRndShear.InitFields}
procedure TRndShear.InitFields;
begin
  inherited InitFields;
end;

(***********************************************************************)
{TRndShear.SaveToStream}
procedure TRndShear.SaveToStream(Stream: TacObjStream);
var
  dummy: string;
begin
  inherited SaveToStream(Stream);
  dummy := 'NO DATA';
  Stream.SaveBuffer(FAppliedLoad, sizeof(string));
  Stream.SaveBuffer(FWidth, sizeof(string));
  Stream.SaveBuffer(FHeight, sizeof(string));
  Stream.SaveBuffer(FThickness, sizeof(string));
  Stream.SaveBuffer(FDiameter, sizeof(string));
  Stream.SaveBuffer(FPoisson, sizeof(string));
  Stream.SaveBuffer(FModulus, sizeof(string));
  Stream.SaveBuffer(dummy, sizeof(string));
  Stream.SaveBuffer(FGageFactor, sizeof(string));
  Stream.SaveBuffer(FAvgStrain, sizeof(string));
  Stream.SaveBuffer(dummy, sizeof(string));
  Stream.SaveBuffer(FFullSpan, sizeof(string));
  Stream.SaveBuffer(TheString, sizeof(string));
end;

(***********************************************************************)
{TRndShear.ReadFromStream}
procedure TRndShear.ReadFromStream(Stream: TacObjStream);
var
  dummy: string;
begin
  inherited ReadFromStream(Stream);
  Stream.ReadBuffer(FAppliedLoad, sizeof(string));
  Stream.ReadBuffer(FWidth, sizeof(string));
  Stream.ReadBuffer(FHeight, sizeof(string));
  Stream.ReadBuffer(FThickness, sizeof(string));
  Stream.ReadBuffer(FDiameter, sizeof(string));
  Stream.ReadBuffer(FPoisson, sizeof(string));
  Stream.ReadBuffer(FModulus, sizeof(string));
  Stream.ReadBuffer(dummy, sizeof(string));
  Stream.ReadBuffer(FGageFactor, sizeof(string));
  Stream.ReadBuffer(FAvgStrain, sizeof(string));
  Stream.ReadBuffer(dummy, sizeof(string));
  Stream.ReadBuffer(FFullSpan, sizeof(string));
  Stream.ReadBuffer(TheString, sizeof(string));
end;

(***********************************************)
(*  Round Shear Web Form Methods               *)
(***********************************************)
function TRndShrWebFrm.CalculateSpan: RealType; {new 6/11/97 mjb}
var
  w  : realtype;
  F  : realtype;
  h  : realtype;
  d  : realtype;
  t  : realtype;
  E  : realtype;
  v  : realtype;
  Ao : realtype;
  id : realtype;
  x  : realtype;
  Term1 : realtype;
  Term2 : realtype;
  dh    : realtype;
  db    : realtype;
  dt    : realtype;
  dh2   : realtype;
  db2   : realtype;
  dt2   : realtype;
  Output : realtype;
  MaxStress : realtype;
  MaxStrain : realtype;
  GageFactor : realtype;
  Factor1 : realtype;
  Factor2 : realtype;
  Flange : realtype;
  i : realtype;
begin
  w  := shrWidth;
  F  := Load;
  h  := shrHeight;
  id  := shrDiameter;
  t  := shrThickness;
  E  := Elasticity;
  v  := Ratio;
  GageFactor := Factor;
  {...Calculate Area of Section, Added CSS 12/1/97}
  d := id / 2;
  x := h / 2;
  Flange := (h - id) / 2;
  Factor1 := Flange * w * (d - 2 * Flange / 2);
  Factor2 := t * d * (d / 2);
  i := (w * Power(2*x, 3)) / 12 - (((w - t) * Power(2*d, 3)) / 12);
  MaxStress := (F * (Factor1 + Factor2)) / (i * t);
  MaxStrain := MaxStress / E * (2 * (1 + v)) * 1000000 / 2;
  Output := MaxStrain * GageFactor * 0.001;
  Result := Output;
end;

{TRndShrWebfrm.Power}
function TRndShrWebFrm.Power(Base: realtype; Exponent: realtype): double;
var
  i : integer;
begin
{Returns value calculated from Base^Exponent -- Added CSS 12/1/97}
  try
    Result := 0;
    if (Base <> 0) then begin
      if ((Base < 0) and (Exponent = Trunc(Exponent))) then begin
        Result := 1;
        for i := 1 to Abs(Trunc(Exponent)) do Result := Result * Base;
        if (Exponent < 0) then Result := 1 / Result;
      end
      else Result := exp(ln(Base) * Exponent);
    end;
  except
    Result := 0;
  end;
end;

(*--------------------------Removed MJB/CSS, 12/1/97
{**********************************************************************}
{ TRndShrWebFrm.Min_Strain}
function TRndShrWebFrm.Min_Strain : RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  FirstTerm      : RealType;
  EffectiveLength: RealType;
  SecondTerm     : RealType;
  ThirdTerm      : RealType;
  StrainResult   : RealType;
  Button         : integer;
begin
  ExceptionRaised := false;
  try
    FirstTerm := (3/2) * (Load/(ShrHeight * ShrThickness)) * ((1 + Ratio)/Elasticity);
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  EffectiveLength := (0.07 * Length);
  try
    SecondTerm := (ShrWidth/ShrThickness) * (sqr(ShrHeight)/sqr(ShrDiameter)- 1) +
                   1 - (4/(3 * sqr(ShrDiameter))) * ((EffectiveLength *
                   EffectiveLength *EffectiveLength)/ (EffectiveLength));
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    ThirdTerm := (ShrWidth/ShrThickness) * (((ShrHeight * ShrHeight * ShrHeight)/
                  (ShrDiameter * ShrDiameter * ShrDiameter)) - 1) + 1;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    StrainResult :=  (FirstTerm * (SecondTerm/ThirdTerm)) *1e6;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  Min_Strain := StrainResult;
end;
-----------------------------------*)

