  end
  else if (ShrDiameter < MinDiameter) or (ShrDiameter > MaxDiameter) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_Diameter, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinDiameter, ffFixed, 8, 3);
    StrMax := floattostrf(MaxDiameter, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Diameter.setfocus;
    EB_Diameter.clearselection;
    exit;
  end;
  {...checking Thickness to see if valid}
  EditStrings := EB_Thickness.text;
  val(EditStrings, ShrThickness, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Thickness.setfocus;
    EB_Thickness.clearselection;
    exit;
  end
  else if (ShrThickness < MinThickness) or (ShrThickness > MaxThickness) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_WebThickness, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinThickness, ffFixed, 8, 3);
    StrMax := floattostrf(MaxThickness, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Thickness.setfocus;
    EB_Thickness.clearselection;
    exit;
  end;
  {...checking Height to see if valid}
  EditStrings := EB_Height.text;
  val(EditStrings, ShrHeight, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Height.setfocus;
    EB_Height.clearselection;
    exit;
  end
  else if (ShrHeight < MinHeight) or (ShrHeight > MaxHeight) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_Height, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinHeight, ffFixed, 8, 3);
    StrMax := floattostrf(MaxHeight, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Height.setfocus;
    EB_Height.clearselection;
    exit;
  end;
  {...checking to see if Poisson is valid}
  EditStrings := EB_Poisson.text;
  val(EditStrings, Ratio, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Poisson.setfocus;
    EB_Poisson.clearselection;
    exit;
  end
  else if (Ratio < MinPoisson) or (Ratio > MaxPoisson) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_Poisson, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinPoisson, ffFixed, 8, 3);
    StrMax := floattostrf(MaxPoisson, ffFixed, 8, 2);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Poisson.setfocus;
    EB_Poisson.clearselection;
    exit;
  end;
  {...checking to see if Modulus value is valid}
  EditStrings := EB_Modulus.text;
  val(EditStrings, elasticity, errorcode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Modulus.setfocus;
    EB_Modulus.clearselection;
    exit;
  end
  else if (elasticity < MinModulus) or (elasticity > MaxModulus) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_PSI, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_GPA, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_Modulus, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinModulus, ffFixed, 8, 3);
    StrMax := floattostrf(MaxModulus, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Modulus.setfocus;
    EB_Modulus.clearselection;
    exit;
  end;
  if MainForm.UnitsAreUS = false then begin
    Elasticity := Elasticity * 1000;
  end;
(*------------Removed MJB/CSS, 12/1/97
  {...checking to see if Gage Length is valid}
  EditStrings := EB_GageLength.text;
  val(EditStrings, length, errorcode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageLength.setfocus;
    EB_GageLength.clearselection;
    exit;
  end
  else if (length < MinGageLength) or (length > MaxGageLength) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_GageLength, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinGageLength, ffFixed, 8, 3);
    StrMax := floattostrf(MaxGageLength, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageLength.setfocus;
    EB_GageLength.clearselection;
    exit;
  end;
------------------------------------------*)
  {...checking to see if Gage Factor is valid}
  EditStrings := EB_GageFactor.text;
  val(EditStrings, Factor, errorcode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageFactor.setfocus;
    EB_GageFactor.clearselection;
    exit;
  end
  else if (Factor < MinGageFactor) or (Factor > MaxGageFactor) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_GageFactor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinGageFactor, ffFixed, 8, 3);
    StrMax := floattostrf(MaxGageFactor, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageFactor.setfocus;
    EB_GageFactor.clearselection;
    exit;
  end;
  {...checking to ID does not exceed Height}
  if (ShrDiameter) >= (ShrHeight) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_ShrDiamterBeamHeight, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Height.setfocus;
    EB_Height.clearselection;
    exit;
  end;
  {...checking to make sure Web Thickness does not exceed beam width}
  if (ShrThickness) >= (ShrWidth) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_WEbTHickExceedWidth, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Thickness.setfocus;
    EB_Thickness.clearselection;
    exit;
  end;

(*------------Removed MJB/CSS, 12/1/97
  {...checking to make sure GL is not greater than Diameter/2}
  if (Length) >  (ShrDiameter/2) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_GLBiggerThanID, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageLength.setfocus;
    EB_GageLength.clearselection;
    exit;
  end;
---------------------------------------*)
  {...checking to make sure Diameter is less than 75% of Height}
  if (ShrDiameter/ShrHeight) < 0.70 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_WebDiameterBeamHeight, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Diameter.setfocus;
    EB_Diameter.clearselection;
    exit;
  end;

  {...doing calculations}
  if IsThereAnError = False then begin
(*------------Removed MJB/CSS, 12/1/97
    {...Minimum Strain}
    EMin := Min_Strain;
    if abs(EMin) > 5000 then begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ST_Average.caption := '';
      ST_Gradient.caption := '';
      ST_FullSpan.caption := '';
      ModalResult := 0;
      exit;
    end;
    {...Maximum Strain}
    EMax := Max_Strain;
    if abs(EMin) > 5000 then begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ST_Average.caption := '';
      ST_Gradient.caption := '';
      ST_FullSpan.caption := '';
      ModalResult := 0;
      exit;
    end;
    {..JIM'S DEBUG BOX}
    {...TAKE OUT}
    str(EMin, StrMin);
    str(EMax, StrMax);
    StrMsg := ('Min: ' + StrMin + '  Max: ' + StrMax);
    StrPCopy(ErrorMsg, StrMsg);
    StrMsg := 'Jim''s Debug Info';
    StrPCopy(ErrorCaption, StrMsg);
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    {...Average Strain}
    EAvg := Avg_Strain;
    if ExceptionRaised = false then begin
      AvgStrainText := floattostrf(EAvg, ffFixed, 4, 0);
      ST_Average.caption := AvgStrainText;
    end;
    {...Gradient}
    TheGradient := CalculateGradient;
    if ExceptionRaised = false then begin
      GradientText := floattostrf(TheGradient, ffFixed, 4, 1);
      ST_Gradient.caption := GradientText;
    end;
-------------------------------------------*)

    {...Full Bridge Sensitivity}
    {FullSensitivity := FullBridgeSensitivity;  ---Removed CSS}
    FullSensitivity := CalculateSpan;      {Added CSS, 12/1/97}
    if ExceptionRaised = false then begin
      SensitiveText := floattostrf(FullSensitivity, ffFixed, 4, 3);
      ST_FullSpan.caption := SensitiveText;
    end;
    {...Average Strain}
    EAvg := FullSensitivity / Factor * 1000;
    if ExceptionRaised = false then begin
      AvgStrainText := floattostrf(EAvg, ffFixed, 4, 0);
      ST_Average.caption := AvgStrainText;
    end;
    if abs(EAvg) > 1700 then begin
      LoadString(hinstance, ID_SZ_StrainExceeds1700, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ModalResult := 0;
    end;
  end;
end;

(***********************************************************************)
{TRndShrWebFrm.BN_CancelClick}
procedure TRndShrWebFrm.BN_CancelClick(Sender: TObject);
begin
  {...placing initial values in edit boxes}
  EB_AppliedLoad.text := Old_AppliedLoad;
  EB_Width.text := Old_Width;
  EB_Height.text := Old_Height;
  EB_Thickness.text := Old_Thickness;
  EB_Diameter.text := Old_Diameter;
  EB_Poisson.text := Old_Poisson;
  EB_Modulus.text := Old_Modulus;
  EB_GageFactor.text := Old_GageFactor;
  ST_Average.caption := Old_AvgStrain;
  ST_FullSpan.caption := Old_FullSpan;
  close;
end;

(***********************************************************************)
{TRndShrWebFrm.FormActivate}
procedure TRndShrWebFrm.FormActivate(Sender: TObject);
var
  EditStrings  : string;
  i            : integer;
  TheItem      : TacStreamable;
begin
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TRndShear then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  {...if there is an object then placing values in edit boxes}
  if TheItem <> nil then begin
    EB_AppliedLoad.text := (TheItem as TRndShear).AppliedLoad;
    EB_Width.text := (TheItem as TRndShear).Width;
    EB_Height.text := (TheItem as TRndShear).Height;
    EB_Thickness.text := (TheItem as TRndShear).Thickness;
    EB_Diameter.text := (TheItem as TRndShear).Diameter;
    EB_Poisson.text := (TheItem as TRndShear).Poisson;
    EB_Modulus.text := (TheItem as TRndShear).Modulus;
    EB_GageFactor.text := (TheItem as TRndShear).GageFactor;
    ST_Average.caption := (TheItem as TRndShear).AvgStrain;
    ST_FullSpan.caption := (TheItem as TRndShear).FullSpan;
  end;
  {...placing initial values in old variables, in case cancel clicked}
  Old_AppliedLoad := EB_AppliedLoad.text;
  Old_Width := EB_Width.text;
  Old_Height := EB_Height.text;
  Old_Thickness := EB_Thickness.text;
  Old_Diameter := EB_Diameter.text;
  Old_Poisson := EB_Poisson.text;
  Old_Modulus := EB_Modulus.text;
  Old_GageFactor := EB_GageFactor.text;
  Old_AvgStrain := ST_Average.caption;
  Old_FullSpan := ST_FullSpan.caption;
end;

(***********************************************************************)
{TRndShrWebFrm.BN_OKClick}
procedure TRndShrWebFrm.BN_OKClick(Sender: TObject);
var
  TheItem : TacStreamable;
  i       : integer;
  j       : integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = True then begin
    exit;
  end;
  MainForm.DesignChosen := true;
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TRndShear then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  {...if there is an object then placing values in edit boxes}
  if TheItem = nil then begin
    {...creating object and placing values in object}
    RndShearObject := TRndShear.create;
    RndShearObject.AppliedLoad := EB_AppliedLoad.text;;
    RndShearObject.Width := EB_Width.text;
    RndShearObject.Height := EB_Height.text;
    RndShearObject.Thickness := EB_Thickness.text;
    RndShearObject.Diameter := EB_Diameter.text;
    RndShearObject.Poisson := EB_Poisson.text;
    RndShearObject.Modulus := EB_Modulus.text;
    RndShearObject.GageFactor := EB_GageFactor.text;
    RndShearObject.AvgStrain :=  ST_Average.caption;
    RndShearObject.FullSpan := ST_FullSpan.caption;
    MainForm.AddToLog(RndShearObject);
    j := 0;
    {...placing string associated with object in outline}
    repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Design Verification') or (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, RndShearObject.GetAsString);
  end
  else begin
    (TheItem as TRndShear).AppliedLoad := EB_AppliedLoad.text;;
    (TheItem as TRndShear).Width := EB_Width.text;
    (TheItem as TRndShear).Height := EB_Height.text;
    (TheItem as TRndShear).Thickness := EB_Thickness.text;
    (TheItem as TRndShear).Diameter := EB_Diameter.text;
    (TheItem as TRndShear).Poisson := EB_Poisson.text;
    (TheItem as TRndShear).Modulus := EB_Modulus.text;
    (TheItem as TRndShear).GageFactor := EB_GageFactor.text;
    (TheItem as TRndShear).AvgStrain :=  ST_Average.caption;
    (TheItem as TRndShear).FullSpan := ST_FullSpan.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.DesignDlgShowing = True then begin
    DesignDlg.close;
  end;
end;

(***********************************************************************)
{TRndShrWebFrm.FormClose}
procedure TRndShrWebFrm.FormClose(Sender: TObject;
  var Action: TCloseAction);
begin
  Release;
end;

(***********************************************************************)
{TRndShrWebFrm.EB_AppliedLoadExit}
procedure TRndShrWebFrm.EB_AppliedLoadExit(Sender: TObject);
var
  ForceUnit  : array[0..MAXTEXTLENGTH-1] of char;
  ForceText  : string;
  ForceValue : double;
  ErrorCode  : integer;
begin
  if MainForm.UnitsAreUS = false then begin
    ForceText := EB_AppliedLoad.text;
    val(ForceText, ForceValue, ErrorCode);
    if ErrorCode <> 0 then begin
      exit;
    end;
    ForceValue := ForceValue * 0.101971;
 //   str(ForceValue:4:3, ForceText);
    ForceText := format('%4.3f',[ForceValue]) ;
    ST_KGF.caption := ForceText;
    Loadstring(hinstance, ID_SZ_MetricKg, ForceUnit, sizeof(ForceUnit));
    ST_KGFUnit.caption := ForceUnit;
  end
  else begin
    St_KGF.caption := '';
    ST_KGFUnit.caption := '';
  end;
end;

