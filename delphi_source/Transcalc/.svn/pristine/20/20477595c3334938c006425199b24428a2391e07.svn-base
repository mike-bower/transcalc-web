  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    SecondTerm := (ShrWidth/ShrThickness) * (sqr(ShrHeight)/sqr(ShrDiameter)- 1) +
                   1 ;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    ThirdTerm := (ShrWidth/ShrThickness) * (((ShrHeight * ShrHeight * ShrHeight)/
                  (ShrDiameter * ShrDiameter * ShrDiameter)) - 1) + 1;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    StrainResult :=  (FirstTerm * (SecondTerm/ThirdTerm)) *1e6;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  Max_Strain := StrainResult;
end;
---------------------------------*)

{***********************************************************************}
{ TRndShrWebFrm.Avg_Strain}
function TRndShrWebFrm.Avg_Strain : RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  FirstTerm      : RealType;
  StrainResult   : RealType;
  Button         : integer;
begin
  ExceptionRaised := false;
(*--------------------------Removed MJB/CSS, 12/1/97
  try
    FirstTerm := EMax + EMin;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoAvgStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    StrainResult :=  FirstTerm / 2;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoAvgStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  Avg_Strain := StrainResult;
-------------------------------------*)
  Result := CalculateSpan; {Added MJB/CSS}
end;

(***********************************************************************)
{TRndShrWebFrm.CalculateGradient}
function TRndShrWebFrm.CalculateGradient: RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  GradientResult : RealType;
  Button         : integer;
begin
  result := 0.0 ;
  ExceptionRaised := false;
  try
    GradientResult := ((EMax - EMin)/EMax) * 100;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoGradient, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  CalculateGradient := GradientResult;
end;

(***********************************************************************)
{TRndShrWebFrm.FullBridgeSensitivity}
function TRndShrWebFrm.FullBridgeSensitivity: RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  SpanResult     : RealType;
  Button         : integer;
begin
  Result := 0.0 ;
  ExceptionRaised := false;
  try
    SpanResult := EAvg * Factor * 1e-3;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoFullSpan, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  FullBridgeSensitivity := SpanResult;
end;

(***********************************************************************)
{TRndShrWebFrm.FormCreate}
procedure TRndShrWebFrm.FormCreate(Sender: TObject);
var
  LoadUnit      : array[0..MAXTEXTLENGTH-1] of char;
  DimensionUnit : array[0..MAXTEXTLENGTH-1] of char;
  ModulusUnit   : array[0..MAXTEXTLENGTH-1] of char;
begin
  {...determing whether to use Std. or SI units on form}
  if MainForm.UnitsAreUS = true then begin
    LoadString(hinstance, ID_SZ_USLBF, LoadUnit, sizeof(LoadUnit));
    LoadString(hinstance, ID_SZ_Inches, DimensionUnit, sizeof(DimensionUnit));
    LoadString(hinstance, ID_SZ_PSI, ModulusUnit, sizeof(ModulusUnit));
  end
  else begin
    LoadString(hinstance, ID_SZ_N, LoadUnit, sizeof(LoadUnit));
    LoadString(hinstance, ID_SZ_MM, DimensionUnit, sizeof(DimensionUnit));
    LoadString(hinstance, ID_SZ_GPa, ModulusUnit, sizeof(ModulusUnit));
  end;
  {...placing units on form}
  ST_LoadUnit.caption := LoadUnit;
  ST_WidthUnit.caption := DimensionUnit;
  ST_HeightUnit.caption := DimensionUnit;
  ST_ThickUnit.caption := DimensionUnit;
  ST_DiameterUnit.caption := DimensionUnit;
{  ST_LengthUnit.caption := DimensionUnit; deleted 6/12/97 mjb}
  ST_ModulusUnit.caption := ModulusUnit;
  Font.Name := 'MS Sans Serif';
  Font.Size := 8;
end;

(***********************************************************************)
{TRndShrWebFrm.BN_ComputeClick}
procedure TRndShrWebFrm.BN_ComputeClick(Sender: TObject);
const
  MINAPPLIEDLOAD_US        = 0.0000;
  MAXAPPLIEDLOAD_US        = 50000;
  MINWIDTH_US              = 0.20;
  MAXWIDTH_US              = 10;
  MINDIAMETER_US           = 0.20;
  MAXDIAMETER_US           = 10;
  MINTHICKNESS_US          = 0.010;
  MAXTHICKNESS_US          = 1;
  MINHEIGHT_US             = 0.20;
  MAXHEIGHT_US             = 10.0;
  MINPOISSON_US            = 0.1;
  MAXPOISSON_US            = 0.4;
  MINMODULUS_US            = 5000000;
  MAXMODULUS_US            = 50000000;
  MINGAGELENGTH_US         = 0.008;
  MAXGAGELENGTH_US         = 1;
  MINGAGEFACTOR_US         = 1.0;
  MAXGAGEFACTOR_US         = 5.0;

  var
  ErrorMsg         : array[0..MAXERRORLENGTH] of char;
  ErrorUnit        : array[0..MAXERRORLENGTH] of char;
  ErrorAnd         : array[0..MAXERRORLENGTH] of char;
  ErrorCaption     : array[0..MAXERRORLENGTH] of char;
  StrUnit          : string;
  StrAnd           : string;
  StrMsg           : string;
  StrMin           : string;
  strMax           : string;
  EditStrings      : string;
  MinAppliedLoad   : RealType;
  MaxAppliedLoad   : RealType;
  MinWidth         : RealType;
  MaxWidth         : RealType;
  MinDiameter      : RealType;
  MaxDiameter      : RealType;
  MinThickness     : RealType;
  MaxThickness     : RealType;
  MinHeight        : RealType;
  MaxHeight        : RealType;
  MinPoisson       : RealType;
  MaxPoisson       : RealType;
  MinModulus       : RealType;
  MaxModulus       : RealType;
(*------------Removed MJB/CSS, 12/1/97
  MinGageLength    : RealType;
  MaxGageLength    : RealType;
*)
  MinGageFactor    : RealType;
  MaxGageFactor    : RealType;
  ErrorCode        : integer;
  Button           : integer;
begin
  {...Determining which units to use std. or si for min and max values}
  if MainForm.UnitsAreUS = True then begin
    MinAppliedLoad   := MINAPPLIEDLOAD_US;
    MaxAppliedLoad   := MAXAPPLIEDLOAD_US;
    MinWidth         := MINWIDTH_US;
    MaxWidth         := MAXWIDTH_US;
    MinDiameter      := MINDIAMETER_US;
    MaxDiameter      := MAXDIAMETER_US;
    MinThickness     := MINTHICKNESS_US;
    MaxThickness     := MAXTHICKNESS_US;
    MinHeight        := MINHEIGHT_US;
    MaxHeight        := MAXHEIGHT_US;
    MinPoisson       := MINPOISSON_US;
    MaxPoisson       := MAXPOISSON_US;
    MinModulus       := MINMODULUS_US;
    MaxModulus       := MAXMODULUS_US;
(*------------Removed MJB/CSS, 12/1/97
    MinGageLength    := MINGAGELENGTH_US;
    MaxGageLength    := MAXGAGELENGTH_US;
*)
    MinGageFactor    := MINGAGEFACTOR_US;
    MaxgageFactor    := MAXGAGEFACTOR_US;
  end
  else begin
    MinAppliedLoad   := Lbf_To_N(MINAPPLIEDLOAD_US);
    MaxAppliedLoad   := Lbf_To_N(MAXAPPLIEDLOAD_US);
    MinWidth         := Inches_To_mm(MINWIDTH_US);
    MaxWidth         := Inches_To_mm(MAXWIDTH_US);
    MinDiameter      := Inches_To_mm(MINDIAMETER_US);
    MaxDiameter      := Inches_To_mm(MAXDIAMETER_US);
    MinThickness     := Inches_To_mm(MINTHICKNESS_US);
    MaxThickness     := Inches_To_mm(MAXTHICKNESS_US);
    MinHeight        := Inches_To_mm(MINHEIGHT_US);
    MaxHeight        := Inches_To_mm(MAXHEIGHT_US);
    MinPoisson       := MINPOISSON_US;
    MaxPoisson       := MAXPOISSON_US;
    MinModulus       := PSI_To_GPa(MINMODULUS_US);
    MaxModulus       := PSI_To_GPa(MAXMODULUS_US);
(*------------Removed MJB/CSS, 12/1/97
    MinGageLength    := Inches_To_mm(MINGAGELENGTH_US);
    MaxGageLength    := Inches_To_mm(MAXGAGELENGTH_US);
*)
    MinGageFactor    := MINGAGEFACTOR_US;
    MaxgageFactor    := MAXGAGEFACTOR_US;
  end;
  ST_Average.caption := '';
{ ST_Gradient.caption := ''; ----removed CSS/MJB}
  ST_FullSpan.caption := '';
  {...checking Applied Load to see if valid}
  IsThereAnError := False;
  EditStrings := EB_AppliedLoad.text;
  val(EditStrings, load, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AppliedLoad.setfocus;
    EB_AppliedLoad.clearselection;
    exit;
  end
  else if (Load < MinAppliedLoad) or (Load > MaxAppliedLoad) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_USlbf, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_N, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_AppliedLoad, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinAppliedLoad, ffFixed, 8, 3);
    StrMax := floattostrf(MaxAppliedLoad, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AppliedLoad.setfocus;
    EB_AppliedLoad.clearselection;
    exit;
  end;
  {...checking to see if Width is valid}
  EditStrings := EB_Width.text;
  val(EditStrings, ShrWidth, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Width.setfocus;
    EB_Width.clearselection;
    exit;
  end
  else if (ShrWidth < MinWidth) or (ShrWidth > MaxWidth) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_Width, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinWidth, ffFixed, 8, 3);
    StrMax := floattostrf(MaxWidth, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Width.setfocus;
    EB_Width.clearselection;
    exit;
  end;
  {...checking Diameter to see if valid}
  EditStrings := EB_Diameter.text;
  val(EditStrings, ShrDiameter, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Diameter.setfocus;
