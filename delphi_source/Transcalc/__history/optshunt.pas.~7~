  try
    strstream.LoadFromStream(Stream);
    htmlText := strstream.DataString;
  finally
    strstream.Free();
    Stream.Free();
  end;

  htmlText := StringReplace(htmlText, '$ls1', EB_LowSpan.text,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$lb1', EB_LowRbridge.text,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$lm1', EB_LowRMod.text,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$as1', EB_AmbientSpan.text,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$ab1', EB_AmbientRBridge.text,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$am1', EB_AmbientRMod.text,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$hs1', EB_HighSpan.text,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$hb1', EB_HighRBridge.text,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$hm1', EB_HighRMod.text,
    [rfReplaceAll, rfIgnoreCase]);

  htmlText := StringReplace(htmlText, '$rs1', St_RShunt.caption,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$sl1', ST_LowSpan.caption,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$sa1', ST_AmbientSpan.caption,
    [rfReplaceAll, rfIgnoreCase]);
  htmlText := StringReplace(htmlText, '$sh1', ST_HighSpan.caption,
    [rfReplaceAll, rfIgnoreCase]);
