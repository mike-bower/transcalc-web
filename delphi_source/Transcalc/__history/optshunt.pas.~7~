    ModalResult := 0;
    EB_LowRMod.setfocus;
    EB_LowRMod.clearselection;
    exit;
  end
  else if (TheLowRMod < MinRMod) or (TheLowRMod > MaxRMod) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_LowRMod, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
