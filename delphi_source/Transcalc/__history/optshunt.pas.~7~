{ TOptShuntForm.BN_OKClick }
procedure TOptShuntForm.BN_OKClick(Sender: TObject);
var
  TheItem: TacStreamable;
  i: integer;
  j: integer;
begin
  { ...placing values in object }
  BN_ComputeClick(Sender);
  if (IsThereAnError = true) or (ExceptionRaised = true) then
  begin
    exit;
  end;
  { ...getting the object if there is one }
  TheItem := nil;
  i := 0;
  Repeat
    If MainForm.Flog.AtIndex(i) is TOptimumShunt then
    begin
      TheItem := MainForm.Flog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  { ...if there is an object, then place values in edit boxes }
  if TheItem = nil then
  begin
    OptimumShuntObject := TOptimumShunt.create;
    OptimumShuntObject.LowSpan := EB_LowSpan.text;
    OptimumShuntObject.LowRBridge := EB_LowRbridge.text;
    OptimumShuntObject.LowRmod := EB_LowRMod.text;
    OptimumShuntObject.HighSpan := EB_HighSpan.text;
    OptimumShuntObject.HighRBridge := EB_HighRBridge.text;
    OptimumShuntObject.HighRmod := EB_HighRMod.text;
    OptimumShuntObject.AmbientSpan := EB_AmbientSpan.text;
    OptimumShuntObject.AmbientRBridge := EB_AmbientRBridge.text;
    OptimumShuntObject.AmbientRmod := EB_AmbientRMod.text;
    OptimumShuntObject.RShunt := St_RShunt.caption;
    OptimumShuntObject.SpanLow := ST_LowSpan.caption;
    OptimumShuntObject.SpanAmbient := ST_AmbientSpan.caption;
    OptimumShuntObject.SpanHigh := ST_HighSpan.caption;
    MainForm.AddToLog(OptimumShuntObject);
    j := 0;
    { ...placing object string in outline }
    Repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Circuit Refinements') or
      (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, OptimumShuntObject.GetAsString);
  end
  else
  begin
    (TheItem as TOptimumShunt).LowSpan := EB_LowSpan.text;
    (TheItem as TOptimumShunt).LowRBridge := EB_LowRbridge.text;
    (TheItem as TOptimumShunt).LowRmod := EB_LowRMod.text;
    (TheItem as TOptimumShunt).HighSpan := EB_HighSpan.text;
    (TheItem as TOptimumShunt).HighRBridge := EB_HighRBridge.text;
    (TheItem as TOptimumShunt).HighRmod := EB_HighRMod.text;
    (TheItem as TOptimumShunt).AmbientSpan := EB_AmbientSpan.text;
    (TheItem as TOptimumShunt).AmbientRBridge := EB_AmbientRBridge.text;
    (TheItem as TOptimumShunt).AmbientRmod := EB_AmbientRMod.text;
    (TheItem as TOptimumShunt).RShunt := St_RShunt.caption;
    (TheItem as TOptimumShunt).SpanLow := ST_LowSpan.caption;
    (TheItem as TOptimumShunt).SpanAmbient := ST_AmbientSpan.caption;
    (TheItem as TOptimumShunt).SpanHigh := ST_HighSpan.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.CompDlgShowing = true then
  begin
    CompensationDlg.close;
  end;
end;

