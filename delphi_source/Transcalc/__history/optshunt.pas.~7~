    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AmbientRMod.setfocus;
    EB_AmbientRMod.clearselection;
    exit;
  end;
  { ..checking to see if HighTemperature Span is valid }
  EditStrings := EB_HighSpan.text;
  val(EditStrings, TheHighSpan, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighSpan.setfocus;
    EB_HighSpan.clearselection;
    exit;
  end
  else if (TheHighSpan < MinSpan) or (TheHighSpan > MaxSpan) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_MV, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_HighSpan, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinSpan, ffFixed, 8, 3);
    StrMax := floattostrf(MaxSpan, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighSpan.setfocus;
    EB_HighSpan.clearselection;
    exit;
  end;
  { ..checking to see if High RBridge is valid }
  EditStrings := EB_HighRBridge.text;
  val(EditStrings, TheHighRBridge, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRBridge.setfocus;
    EB_HighRBridge.clearselection;
    exit;
  end
  else if (TheHighRBridge < MinRBridge) or (TheHighRBridge > MaxRBridge) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_HighRBridge, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinRBridge, ffFixed, 8, 3);
    StrMax := floattostrf(MaxRBridge, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRBridge.setfocus;
    EB_HighRBridge.clearselection;
    exit;
  end;
  { ..checking to see if High RMod is valid }
  EditStrings := EB_HighRMod.text;
  val(EditStrings, TheHighRMod, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRMod.setfocus;
    EB_HighRMod.clearselection;
    exit;
  end
  else if (TheHighRMod < MinRMod) or (TheHighRMod > MaxRMod) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_HighRMod, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinRMod, ffFixed, 8, 3);
    StrMax := floattostrf(MaxRMod, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRMod.setfocus;
    EB_HighRMod.clearselection;
    exit;
  end;
  if (TheLowSpan > TheAmbientSpan) then
  begin
    { ..display message telling user the low span must be lower than ambient span }
    LoadString(hinstance, ID_SZ_LowOutAmbientOut, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    IsThereAnError := true;
    EB_AmbientSpan.setfocus;
    exit;
  end;
  if (TheAmbientSpan > TheHighSpan) then
  begin
    { ..display message telling user the ambient span must be lower than high span }
    LoadString(hinstance, ID_SZ_AmbientOutHighOut, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    IsThereAnError := true;
    EB_HighSpan.setfocus;
    exit;
  end;
  ExceptionRaised := false;
  { ...placing values in arrays for easier calculations }
  S[0] := TheLowSpan;
  Rm[0] := TheLowRMod;
  Rb[0] := TheLowRBridge;
  S[1] := TheAmbientSpan;
  Rm[1] := TheAmbientRMod;
  Rb[1] := TheAmbientRBridge;
  S[2] := TheHighSpan;
  Rm[2] := TheHighRMod;
  Rb[2] := TheHighRBridge;
  { ...set up first equation }
  for i := 0 to 2 do
  begin
    try
      A[i] := S[i] * Rb[i];
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      B[i] := Rm[i] * A[i];
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      C[i] := Rm[i] + Rb[i];
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      D[i] := Rm[i] * Rb[i];
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
  end;
  { Calculate Quadratic Solutions }
  try
    F := A[0] * C[2] - A[2] * C[0];
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    G := B[0] * C[2] + A[0] * D[2] - B[2] * C[0] - A[2] * D[0];
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    H := B[0] * D[2] - B[2] * D[0];
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    M := Sqr(G) - (4 * F * H);
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  if ((M > 0) or (F <> 0)) then
  begin
    try
      Rs0 := (-G + Sqrt(M)) / (2 * F);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if (Rs0 > 0.0) then
    begin
      try
        ARShunt[2] := (-G - Sqrt(M)) / (2 * F);
      except
        on EMathError do
        begin
          LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
            sizeof(ErrorMsg));
          LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
            sizeof(ErrorCaption));
          Button := Application.MessageBox(ErrorMsg, ErrorCaption,
            mb_OK or mb_IconExclamation);
          ExceptionRaised := true;
          exit;
        end;
      end;
    end
    else
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    for i := 0 to 2 do
    begin
      try
        S[i] := (Rs0 * A[i] + B[i]) / (Rs0 * C[i] + D[i]);
      except
        on EMathError do
        begin
          LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
            sizeof(ErrorMsg));
          LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
            sizeof(ErrorCaption));
          Button := Application.MessageBox(ErrorMsg, ErrorCaption,
            mb_OK or mb_IconExclamation);
          ExceptionRaised := true;
          exit;
        end;
      end;
    end;
    try
      D0 := 100 * (S[0] - S[1]) / S[1];
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      D1 := 100 * (S[1] - S[1]) / S[1];
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      D2 := 100 * (S[2] - S[1]) / S[1];
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if (Rs0 >= 0) then
    begin
      TheRShunt := floattostrf(Rs0, ffFixed, 4, 1);
      St_RShunt.caption := TheRShunt;
      TheSpanLow := floattostrf(S[0], ffFixed, 6, 5);
      ST_LowSpan.caption := TheSpanLow;
      TheSpanAmbient := floattostrf(S[1], ffFixed, 6, 5);
      ST_AmbientSpan.caption := TheSpanAmbient;
      TheSpanHigh := floattostrf(S[2], ffFixed, 6, 5);
      ST_HighSpan.caption := TheSpanHigh;
    end
    else
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end
  else
  begin
    LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    exit;
  end;
end;

