(***********************************************************************)
{TOptShuntC1220Form.ReCalculate}
procedure TOptShuntC1220Form.ReCalculate;
const
  {FOIL SQUARES - SEE JRW's B.S.}
  S1  = 1.6;
  S2  = 2.9;
  S3  = 2.5;
  S4  = 1.0;
  S5  = 1.3;
  S6  = 3.5;
  S7  = 2.0;
  S8  = 1.0;
  S9  = 19.2;
  S10 = 2.0;
  S11 = 2.0;
  S12 = 42.0;
  S13 = 19.5;
  S14 = 19.5;
  S15 = 41.2;
  S16 = 85.4;
  S17 = 2.0;
  S18 = 3.0;
  S19 = 41.2;
  S20 = 393.7;
  S21 = 25;
  S22 = 1.5;
  S23 = 1.5;
  TOTALSQUARES = 440.0;
var
  ErrorMsg      : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption  : array[0..MAXERRORLENGTH-1] of char;
  ErrorAnd      : array[0..MAXERRORLENGTH-1] of char;
  ErrorUnit     : array[0..MAXERRORLENGTH-1] of char;
  cs            : array[0..255] of char;
  EditStrings   : string;
  s             : string;
  StrMsg        : string;
  StrUnit       : string;
  StrAnd        : string;
  C             : RealType;
  CFA           : RealType;
  CSA           : RealType;
  CB            : RealType;
  CFC           : RealType;
  CSC           : RealType;
  Squares       : RealType;
  Rtotal        : RealType;
  RStart        : RealType;
  OhmsPerSquare : RealType;
  code          : Integer;
  Button        : integer;
begin
  OhmsPerSquare := 0.0 ;
  { Read Starting Resistance}
  s := EB_StartingRes.text;
  val(s, Rstart, code);
  if code <> 0 then begin
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes.caption := '';
    exit;
  end
  else if (Rstart < 16) or (RStart > 24) then begin
    LoadString(hinstance, ID_SZ_WrongResistor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    EditStrings := StrMsg + ' ' + '16.0' + ' ' + StrAnd + ' ' + '24.0' + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes.caption := '';
    exit;
  end;
  if RStart > 0 then begin
    OhmsPerSquare := Rstart/TOTALSQUARES;
  end;
  {Calculate Ladder First "A"}
  C  := (C1220OptShuntResist.FA1.IsCut / S3) + (1 / (2 * S7 + S6));
  C  := (C1220OptShuntResist.FA2.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.FA3.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.FA4.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.FA5.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.FA6.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.FA7.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.FA8.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.FA9.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  CFA := (C1220OptShuntResist.FA10.IsCut / S10) + (1 / (2 * S2 + 1/C));
  {Calculate Ladder Second "A"}
  C  := (C1220OptShuntResist.SA1.IsCut / S3) + (1 / (2 * S7 + S6));
  C  := (C1220OptShuntResist.SA2.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.SA3.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.SA4.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.SA5.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.SA6.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.SA7.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.SA8.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C1220OptShuntResist.SA9.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  CSA := (C1220OptShuntResist.SA10.IsCut / S10) + (1 / (2 * S2 + 1/C));
  {Calculate Ladder "B"}
  C  := (C1220OptShuntResist.B1.IsCut / S10) + (1 / S12);
  C  := (C1220OptShuntResist.B2.IsCut / S11) + (1 / (S9 + S13 + 1/C));
  C  := (C1220OptShuntResist.B3.IsCut / S10) + (1 / (S9 + S13 + 1/C));
  CB := (C1220OptShuntResist.B4.IsCut / S18) + (1 / (S9 + S14 + 1/C));
  {Calculate Ladder First "C"}
  C  := (C1220OptShuntResist.FC1.IsCut / S17) + (1 / S16);
  C  := (C1220OptShuntResist.FC2.IsCut / S18) + (1 / (S15 + S19 + 1/C));
  CFC  := C;
  {Calculate Ladder Second "C"}
  C  := (C1220OptShuntResist.SC1.IsCut / S17) + (1 / S16);
  C  := (C1220OptShuntResist.SC2.IsCut / S18) + (1 / (S15 + S19 + 1/C));
  CSC := C;
  { Calculate total resistance}
  Squares := 1/CFA + 1/CSA + 1/CB + 1/CFC + 1/CSC + S20 + S8 + S8 + S8 + S8 +
             S4 + S21 + S22 + S1 + S23;
  RTotal := OhmsPerSquare * Squares;
  {Display}
  if RTotal > 0 then begin
//    Str(Rtotal:7:1, s);
    s := format('%7.1f',[Rtotal]) ;
    StrPcopy(cs,s);
    ST_CalculatedRes.caption := s;
  end
  else
    ST_CalculatedRes.caption := s;
end;

