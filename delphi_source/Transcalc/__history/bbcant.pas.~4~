(***********************************************************************)
{TCantileverBBFrm.FormActivate}
procedure TCantileverBBFrm.FormActivate(Sender: TObject);
var
  EditStrings  : string;
  i            : integer;
  TheItem      : TacStreamable;
begin
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TCantileverBeam then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  {...placing the object in appropiate edit boxes}
  if TheItem <> nil then begin
    EB_AppliedLoad.text  := (TheItem as TCantileverBeam).AppliedLoad;
    EB_BeamWidth.text := (TheItem as TCantileverBeam).BeamWidth;
    EB_Thickness.text := (TheItem as TCantileverBeam).Thickness;
    EB_MomentArm.text := (TheItem as TCantileverBeam).MomentArm;
    EB_Modulus.text := (TheItem as TCantileverBeam).Modulus;
    EB_GageLength.text := (TheItem as TCantileverBeam).GageLength;
    EB_GageFactor.text := (TheItem as TCantileverBeam).GageFactor;
    ST_AvgStrain.caption := (TheItem as TCantileverBeam).AvgStrain;
    ST_Gradient.caption := (TheItem as TCantileverBeam).Gradient;
    ST_FullBridgeSpan.caption := (TheItem as TCantileverBeam).FullSpan;
  end;
  {...setting old value in case of cancel clicked}
  Old_AppliedLoad := EB_AppliedLoad.text;
  Old_BeamWidth := EB_BeamWidth.text;
  Old_Thickness := EB_Thickness.text;
  Old_MomentArm := EB_MomentArm.text;
  Old_Modulus := EB_Modulus.text;
  Old_GageLength := EB_GageLength.text;
  Old_GageFactor := EB_GageFactor.text;
  Old_AvgStrain := ST_AvgStrain.caption;
  Old_Gradient := ST_Gradient.caption;
  Old_FullSpan := ST_FullBridgeSpan.caption;
end;

(***********************************************************************)
{TCantileverBBFrm.BN_OKClick}
procedure TCantileverBBFrm.BN_OKClick(Sender: TObject);
var
  TheItem : TACStreamable;
  Windowhdl : hwnd;
  i       : integer;
  j       : integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = True then begin
    exit;
  end;
  MainForm.DesignChosen := true;
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TCantileverBeam then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  {...placing the object in appropiate edit boxes}
  if TheItem = nil then begin
    {...setting the object fields and add the object to log}
    CantBeamObject := TCantileverBeam.create;
    CantBeamObject.AppliedLoad := EB_AppliedLoad.text;
    CantBeamObject.BeamWidth := EB_BeamWidth.text;
    CantBeamObject.Thickness := EB_Thickness.text;
    CantBeamObject.MomentArm := EB_MomentArm.text;
    CantBeamObject.Modulus := EB_Modulus.text;
    CantBeamObject.GageLength := EB_GageLength.text;
    CantBeamObject.GageFactor := EB_GageFactor.text;
    CantBeamObject.AvgStrain :=  ST_AvgStrain.caption;
    CantBeamObject.Gradient  := ST_Gradient.caption;
    CantBeamObject.FullSpan := ST_FullBridgeSpan.caption;
    MainForm.AddToLog(CantBeamObject);
    j := 0;
    {...placing the object string in the outline}
    repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Design Verification') or (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, CantBeamObject.GetAsString);
  end
  else begin
    (TheItem as TCantileverBeam).AppliedLoad := EB_AppliedLoad.text;
    (TheItem as TCantileverBeam).BeamWidth := EB_BeamWidth.text;
    (TheItem as TCantileverBeam).Thickness := EB_Thickness.text;
    (TheItem as TCantileverBeam).MomentArm := EB_MomentArm.text;
    (TheItem as TCantileverBeam).Modulus := EB_Modulus.text;
    (TheItem as TCantileverBeam).GageLength := EB_GageLength.text;
    (TheItem as TCantileverBeam).GageFactor := EB_GageFactor.text;
    (TheItem as TCantileverBeam).AvgStrain :=  ST_AvgStrain.caption;
    (TheItem as TCantileverBeam).Gradient  := ST_Gradient.caption;
    (TheItem as TCantileverBeam).FullSpan := ST_FullBridgeSpan.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.DesignDlgShowing = True then begin
    DesignDlg.close;
  end;
end;

