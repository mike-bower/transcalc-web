(* ********************************************************************* *)
{ TRndHollowColFrm.CalculateAxialStrain }
function TRndHollowColFrm.CalculateAxialStrain: RealType;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH - 1] of char;
  Numerator: RealType;
  Denominator: RealType;
  AxialResult: RealType;
  Button: integer;
begin
  AxialResult := 0.0;
  ExceptionRaised := false;
  Numerator := -(Load / ((Pi * sqr(Outside / 2)) - (Pi * sqr(Inside / 2))));
  Denominator := Elasticity;
  try
    AxialResult := (Numerator / Denominator) * 1E6;
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_NoAxialStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateAxialStrain := AxialResult;
end;

(* ********************************************************************* *)
{ TRndHollowColFrm.CalculateTransverseStrain }
function TRndHollowColFrm.CalculateTransverseStrain: RealType;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH - 1] of char;
  FirstTerm: RealType;
  SecondTerm: RealType;
  TransverseResult: RealType;
  Button: integer;
begin
  TransverseResult := 0.0;
  ExceptionRaised := false;
  FirstTerm := AxialE;
  SecondTerm := -(Ratio);
  try
    TransverseResult := FirstTerm * SecondTerm;
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_NoTransverseStrain, ErrorMsg,
        sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateTransverseStrain := TransverseResult;
end;

(* ********************************************************************* *)
{ TRndHollowColFrm.CalculateFullSpan }
function TRndHollowColFrm.CalculateFullSpan: RealType;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH - 1] of char;
  Numerator: RealType;
  Denominator: RealType;
  SpanResult: RealType;
  Button: integer;
begin
  SpanResult := 0.0;
  ExceptionRaised := false;
  Numerator := (-2 * AxialE) + (2 * TransverseE);
  Denominator := 4;
  try
    SpanResult := (Factor * (Numerator / Denominator)) * 1E-3;
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_NoFullSpan, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateFullSpan := SpanResult;
end;

(* ********************************************************************* *)
{ TRndHollowColFrm.FormCreate }
procedure TRndHollowColFrm.FormCreate(Sender: TObject);
var
  LoadUnit: array [0 .. MAXTEXTLENGTH - 1] of char;
  DimensionUnit: array [0 .. MAXTEXTLENGTH - 1] of char;
  ModulusUnit: array [0 .. MAXTEXTLENGTH - 1] of char;
begin
  { ...deciding whether to use Std or SI units on form }
  if MainForm.UnitsAreUS = true then
  begin
    LoadString(hinstance, ID_SZ_USLBF, LoadUnit, sizeof(LoadUnit));
    LoadString(hinstance, ID_SZ_Inches, DimensionUnit, sizeof(DimensionUnit));
    LoadString(hinstance, ID_SZ_PSI, ModulusUnit, sizeof(ModulusUnit));
  end
  else
  begin
    LoadString(hinstance, ID_SZ_N, LoadUnit, sizeof(LoadUnit));
    LoadString(hinstance, ID_SZ_MM, DimensionUnit, sizeof(DimensionUnit));
    LoadString(hinstance, ID_SZ_GPa, ModulusUnit, sizeof(ModulusUnit));
  end;
  { ...placing units on the form }
  ST_LoadUnit.caption := LoadUnit;
  ST_InsideUnit.caption := DimensionUnit;
  ST_OutsideUnit.caption := DimensionUnit;
  ST_ModulusUnit.caption := ModulusUnit;
  Font.Name := 'MS Sans Serif';
  Font.Size := 8;
end;

(* ********************************************************************* *)
{ TRndHollowColFrm.BN_ComputeClick }
procedure TRndHollowColFrm.BN_ComputeClick(Sender: TObject);
const
  MINAPPLIEDLOAD_US = 0.0000;
  MAXAPPLIEDLOAD_US = 500000;
  MININSIDEDIAMETER_US = 0.00;
  MAXINSIDEDIAMETER_US = 50.0;
  MINOUTSIDEDIAMETER_US = 0.020;
  MAXOUTSIDEDIAMETER_US = 50;
  MINPOISSON_US = 0.1;
  MAXPOISSON_US = 0.4;
  MINMODULUS_US = 5000000;
  MAXMODULUS_US = 50000000;
  MINGAGEFACTOR_US = 1.0;
  MAXGAGEFACTOR_US = 5.0;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH] of char;
  ErrorUnit: array [0 .. MAXERRORLENGTH] of char;
  ErrorAnd: array [0 .. MAXERRORLENGTH] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH] of char;
  StrUnit: string;
  StrAnd: string;
  StrMsg: string;
  StrMin: string;
  strMax: string;
  EditStrings: string;
  MinAppliedLoad: RealType;
  MaxAppliedLoad: RealType;
  MinInside: RealType;
  MaxInside: RealType;
  MinOutside: RealType;
  MaxOutside: RealType;
  MinPoisson: RealType;
  MaxPoisson: RealType;
  MinModulus: RealType;
  MaxModulus: RealType;
  MinGageFactor: RealType;
  MaxGageFactor: RealType;
  ErrorCode: integer;
  Button: integer;
begin
  { ...Determining which units to use std. or si for min and max values }
  if MainForm.UnitsAreUS = true then
  begin
    MinAppliedLoad := MINAPPLIEDLOAD_US;
    MaxAppliedLoad := MAXAPPLIEDLOAD_US;
    MinInside := MININSIDEDIAMETER_US;
    MaxInside := MAXINSIDEDIAMETER_US;
    MinOutside := MINOUTSIDEDIAMETER_US;
    MaxOutside := MAXOUTSIDEDIAMETER_US;
    MinPoisson := MINPOISSON_US;
    MaxPoisson := MAXPOISSON_US;
    MinModulus := MINMODULUS_US;
    MaxModulus := MAXMODULUS_US;
    MinGageFactor := MINGAGEFACTOR_US;
    MaxGageFactor := MAXGAGEFACTOR_US;
  end
  else
  begin
    MinAppliedLoad := Lbf_To_N(MINAPPLIEDLOAD_US);
    MaxAppliedLoad := Lbf_To_N(MAXAPPLIEDLOAD_US);
    MinInside := Inches_To_mm(MININSIDEDIAMETER_US);
    MaxInside := Inches_To_mm(MAXINSIDEDIAMETER_US);
    MinOutside := Inches_To_mm(MINOUTSIDEDIAMETER_US);
    MaxOutside := Inches_To_mm(MAXOUTSIDEDIAMETER_US);
    MinPoisson := MINPOISSON_US;
    MaxPoisson := MAXPOISSON_US;
    MinModulus := PSI_To_GPa(MINMODULUS_US);
    MaxModulus := PSI_To_GPa(MAXMODULUS_US);
    MinGageFactor := MINGAGEFACTOR_US;
    MaxGageFactor := MAXGAGEFACTOR_US;
  end;
  ST_Axial.caption := '';
  ST_Transverse.caption := '';
  ST_FullSpan.caption := '';
  { ...checking Applied Force to see if valid }
  IsThereAnError := false;
  EditStrings := EB_AppliedLoad.text;
  val(EditStrings, Load, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AppliedLoad.setfocus;
    EB_AppliedLoad.clearselection;
    exit;
  end
  else if (Load < MinAppliedLoad) or (Load > MaxAppliedLoad) then
  begin
    IsThereAnError := true;
    if MainForm.UnitsAreUS = true then
    begin
      LoadString(hinstance, ID_SZ_USLBF, ErrorUnit, sizeof(ErrorMsg));
    end
    else
    begin
      LoadString(hinstance, ID_SZ_N, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_AppliedLoad, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinAppliedLoad, ffFixed, 8, 3);
    strMax := floattostrf(MaxAppliedLoad, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AppliedLoad.setfocus;
    EB_AppliedLoad.clearselection;
    exit;
  end;
  { ...checking to see if Inside Diameter is valid }
  EditStrings := EB_InsideDiameter.text;
  val(EditStrings, Inside, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_InsideDiameter.setfocus;
    EB_InsideDiameter.clearselection;
    exit;
  end
  else if (Inside < MinInside) or (Inside > MaxInside) then
  begin
    IsThereAnError := true;
    if MainForm.UnitsAreUS = true then
    begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else
    begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_InsideDiameter, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinInside, ffFixed, 8, 3);
    strMax := floattostrf(MaxInside, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_InsideDiameter.setfocus;
    EB_InsideDiameter.clearselection;
    exit;
  end;
  { ...checking to see if Outside Diameter is valid }
  EditStrings := EB_OutsideDiameter.text;
  val(EditStrings, Outside, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_OutsideDiameter.setfocus;
    EB_OutsideDiameter.clearselection;
    exit;
  end
  else if (Outside < MinOutside) or (Outside > MaxOutside) then
  begin
    IsThereAnError := true;
    if MainForm.UnitsAreUS = true then
    begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else
    begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_OutsideDiameter, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinOutside, ffFixed, 8, 3);
    strMax := floattostrf(MaxOutside, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_OutsideDiameter.setfocus;
    EB_OutsideDiameter.clearselection;
    exit;
  end;
  { ...checking to see if Poisson is valid }
  EditStrings := EB_Poisson.text;
  val(EditStrings, Ratio, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Poisson.setfocus;
    EB_Poisson.clearselection;
    exit;
  end
  else if (Ratio < MinPoisson) or (Ratio > MaxPoisson) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_Poisson, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinPoisson, ffFixed, 8, 3);
    strMax := floattostrf(MaxPoisson, ffFixed, 8, 2);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Poisson.setfocus;
    EB_Poisson.clearselection;
    exit;
  end;
  { ...checking to see if Modulus value is valid }
  EditStrings := EB_Modulus.text;
  val(EditStrings, Elasticity, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Modulus.setfocus;
    EB_Modulus.clearselection;
    exit;
  end
  else if (Elasticity < MinModulus) or (Elasticity > MaxModulus) then
  begin
    IsThereAnError := true;
    if MainForm.UnitsAreUS = true then
    begin
      LoadString(hinstance, ID_SZ_PSI, ErrorUnit, sizeof(ErrorMsg));
    end
    else
    begin
      LoadString(hinstance, ID_SZ_GPa, ErrorUnit, sizeof(ErrorMsg));
