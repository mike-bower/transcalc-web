{ TRndHollowColFrm.BN_OKClick }
procedure TRndHollowColFrm.BN_OKClick(Sender: TObject);
var
  TheItem: TacStreamable;
  i: integer;
  j: integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = true then
  begin
    exit;
  end;
  MainForm.DesignChosen := true;
  { getting item from object if there is one }
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TRoundHollowCol then
    begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.FLog.Count);
  { if there is an object, then placing values in editboxes }
  if TheItem = nil then
  begin
    { ...creating and placing values in object }
    RoundHollowColObject := TRoundHollowCol.create;
    RoundHollowColObject.AppliedLoad := EB_AppliedLoad.text;
    RoundHollowColObject.InsideDiameter := EB_InsideDiameter.text;
    RoundHollowColObject.OutsideDiameter := EB_OutsideDiameter.text;
    RoundHollowColObject.Poisson := EB_Poisson.text;
    RoundHollowColObject.Modulus := EB_Modulus.text;
    RoundHollowColObject.GageFactor := EB_GageFactor.text;
    RoundHollowColObject.AxialStrain := ST_Axial.caption;
    RoundHollowColObject.TransverseStrain := ST_Transverse.caption;
    RoundHollowColObject.FullSpan := ST_FullSpan.caption;
    MainForm.AddToLog(RoundHollowColObject);
    j := 0;
    { ...placing string associated with object in the outline }
    repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Design Verification') or
      (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, RoundHollowColObject.GetAsString);
  end
  else
  begin
    (TheItem as TRoundHollowCol).AppliedLoad := EB_AppliedLoad.text;
    (TheItem as TRoundHollowCol).InsideDiameter := EB_InsideDiameter.text;
    (TheItem as TRoundHollowCol).OutsideDiameter := EB_OutsideDiameter.text;
    (TheItem as TRoundHollowCol).Poisson := EB_Poisson.text;
    (TheItem as TRoundHollowCol).Modulus := EB_Modulus.text;
    (TheItem as TRoundHollowCol).GageFactor := EB_GageFactor.text;
    (TheItem as TRoundHollowCol).AxialStrain := ST_Axial.caption;
    (TheItem as TRoundHollowCol).TransverseStrain := ST_Transverse.caption;
    (TheItem as TRoundHollowCol).FullSpan := ST_FullSpan.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.DesignDlgShowing = true then
  begin
    DesignDlg.close;
  end;
end;

