{TMainForm.Design1Click}
procedure TMainForm.Design1Click(Sender: TObject);
var
  ErrorMsg     : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption : array[0..MAXERRORLENGTH-1] of char;
  QuestionMark : array[0..MAXTEXTLENGTH-1] of char;
  EditStrings  : string;
  TheText      : string;
  StrMsg       : string;
  StrUnit      : string;
  TheObject    : TacStreamable;
  Button       : integer;
  ChildIndex   : integer;
begin
  TheObject := nil;
  if XCalcOutline.items[1].HasItems = true then begin
    ChildIndex := XCalcOutline.Items[1].GetFirstChild;
    TheText := XCalcOutline.items[ChildIndex].Text;
    LoadString(hinstance, ID_SZ_DeleteDesign, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_Question, QuestionMark, sizeof(QuestionMark));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(QuestionMark);
    EditStrings := StrMsg + ' ' + TheText + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    Button := Application.MessageBox(Errormsg, ErrorCaption, mb_YesNo or MB_ICONQUESTION);
    if Button = idYes then begin
      TheObject := MainForm.FLog.AtName(TheText);
      XCalcOutline.Items[ChildIndex].destroy;
      DeleteFromLog(TheObject);
      Application.CreateForm(TDesignDlg, DesignDlg);
      DesignDlg.showmodal;
    end
    else begin
      TheObject := MainForm.FLog.AtName(TheText);
      if TheObject is TacStreamable then begin
        TheObject.ShowTheForm;
      end
    end;
  end
  else begin
    Application.CreateForm(TDesignDlg, DesignDlg);
    DesignDlg.showmodal;
  end;
end;

