  ErrorCaption : array[0..MAXERRORLENGTH-1] of char;
  TheItem      : TACStreamable;
  TheWindow    : HWnd;
  Msg          : String;
  i            : integer;
  j            : integer;
  Button       : integer;
  ChildIndex   : integer;
  USUnits      : boolean;
  TheUnit      : integer;
begin
  if IsDirty = true then begin
    LoadString(hinstance, ID_SZ_DoYouWantToSave, ErrorMsg, sizeof(ErrorMsg));
    Msg := strpas(ErrorMsg);
    Msg := Msg + ' ' + SaveFileName + '?';
    strpcopy(ErrorMsg, Msg);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_YesNoCancel or MB_IconQuestion);
    if Button = idYes then begin
      if IsNewFile = true then begin
        SaveProjectAs1Click(Sender);
      end
      else begin
        SaveProject1Click(Sender);
      end;
    end
    else if Button = IdCancel then begin
      exit;
    end;
  end;
  if OpenDialog1.Execute then begin
    if Length(OpenDialog1.FileName) <> 0 then begin
      SaveFileName :=  OpenDialog1.FileName;
      with XCalcOutline do begin
        ChildIndex := Items[1].GetFirstChild;
        if ChildIndex <> -1 then begin
          Items[ChildIndex].destroy;
        end;
        repeat
        ChildIndex := Items[2].GetFirstChild;
        if ChildIndex <> -1 then begin
          Items[ChildIndex].destroy;
        end;
        until (ChildIndex = -1);
      end;
      FLogStream.Free;
      FLog.Free;
      FLog := TLog.create(TheItems, true);
      FLogStream := TLogStream.Create(SaveFileName);
      ReadLog;
      {..getting Units from file}
      TheItem := nil;
      i := 0;
      Repeat
        if MainForm.FLog.AtIndex(i) is TMainObject then begin
         TheItem := MainForm.FLog.AtIndex(i);
        end;
        inc(i);
      until (TheItem <> nil) or (i > MainForm.Flog.Count);
      if TheItem <> nil then begin
        TheUnit := (TheItem as TMainObject).UnitString;
        if TheUnit = 1 then begin
          USUnits := true;
        end
        else begin
          USUnits := false;
        end;
        if (UnitsAreUS <> USUnits) then begin
          LoadString(hinstance, ID_SZ_WrongUnits, ErrorMsg, sizeof(ErrorMsg));
          LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
