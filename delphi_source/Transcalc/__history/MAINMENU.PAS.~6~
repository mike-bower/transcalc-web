  WindowsBuffer : array[0..MAXDIRLENGTH-1] of char;
  WindowsString : string;
  MsgStr        : string;
  Button        : integer;
  sName, sVers: string;
  IniPath : string ;
  IniFile : tIniFile ;

begin
  IniPath := tPath.Combine( tPath.Combine(system.IOUtils.TPath.GetPublicPath(),'Micro-Measurements'),'xcalc') ;
  IniPath := tPath.Combine( IniPath, 'xcalc.ini') ;
  IniFile := tIniFile.Create(IniPath);
  sName:='';
  sVers:=ReadVerInfo(Application.ExeName, sName);
  Self.Caption:=sName+' (v'+sVers+')';
  Application.OnHint:= ShowHint;
  {...geting units from INI file}
  cs := iniFile.ReadString('Units', 'Units', 'US');
  if cs = 'US' then begin
    UnitsAreUS := true;
  end
  else begin
    UnitsAreUS := false;
  end;
  IsNewFile := true;
  {...placing filename on title bar of mainform}
  IsDirty := false;
//  MainForm.Caption := 'TransCalc  ';
  FLog := TLog.create(TheItems, true);
  Font.Name := 'MS Sans Serif';
  Font.Size := 8;
  DesignChosen := false;
  DesignDlgShowing := false;
  CompDlgShowing := false;
