(***********************************************************************)
{TMainForm.SaveProject1Click}
procedure TMainForm.SaveProject1Click(Sender: TObject);
var
  TheItem : TACStreamable;
  i       : integer;
begin
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    if FLog.AtIndex(i) is TMainObject then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > Flog.Count);
  {...if there is an object, then placing values in edit boxes}
  if TheItem = nil then begin
    {...creating and placing values in object}
    if  UnitsAreUS = true then begin
      MainObject := TMainObject.create;
      MainObject.UnitString := 1;
    end
    else begin
      MainObject := TMainObject.create;
      MainObject.UnitString := 0;
    end;
    AddToLog(MainObject);
  end
  else begin
    {...creating and placing values in object}
    if  UnitsAreUS = true then begin
      (TheItem as TMainObject).UnitString := 1;
    end
    else begin
      (TheItem as TMainObject).UnitString := 0;
    end;
  end;
  if IsNewFile = false then begin
    FLogStream := TLogStream.Create(SaveFileName);
    SaveLog;
    IsNewFile := false;
    IsDirty := false;
  end
  else begin
    SaveProjectAs1Click(Sender);
  end;
  MainForm.Caption := 'TransCalc  ' + SaveFileName;
end;

