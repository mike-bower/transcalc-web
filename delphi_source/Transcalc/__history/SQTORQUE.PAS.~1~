(***********************************************************************)
{TSqTorqueShftFrm.FormActivate}
procedure TSqTorqueShftFrm.FormActivate(Sender: TObject);
var
  EditStrings  : string;
  i            : integer;
  TheItem      : TacStreamable;
begin
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TSqrTorque then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  {...if there is an object, them placing values in edit boxes}
  if TheItem <> nil then begin
    EB_AppliedTorque.text := (TheItem as TSqrTorque).AppliedTorque;
    EB_Width.text := (TheItem as TSqrTorque).Width;
    EB_Poisson.text := (TheItem as TSqrTorque).Poisson;
    EB_Modulus.text := (TheItem as TSqrTorque).Modulus;
    EB_GageLength.text := (TheItem as TSqrTorque).GageLength;
    EB_GageFactor.text := (TheItem as TSqrTorque).GageFactor;
    ST_Average.caption := (TheItem as TSqrTorque).Average;
    ST_Gradient.caption := (TheItem as TSqrTorque).Gradient;
    ST_FullSpan.caption := (TheItem as TSqrTorque).FullSpan;
  end;
  {...placing initial values in old variables in case cancel clicked}
  Old_AppliedTorque := EB_AppliedTorque.text;
  Old_Width := EB_Width.text;
  Old_Poisson := EB_Poisson.text;
  Old_Modulus := EB_Modulus.text;
  Old_GageLength := EB_GageLength.text;
  Old_GageFactor := EB_GageFactor.text;
  Old_Average := ST_Average.caption;
  Old_Gradient := ST_Gradient.caption;
  Old_FullSpan := ST_FullSpan.caption;
end;

(***********************************************************************)
{TSqTorqueShftFrm.BN_OKClick}
procedure TSqTorqueShftFrm.BN_OKClick(Sender: TObject);
var
  TheItem : TacStreamable;
  i       : integer;
  j       : integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = True then begin
    exit;
  end;
  MainForm.DesignChosen := true;
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TSqrTorque then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  {...if there is an object, them placing values in edit boxes}
  if TheItem = nil then begin
    {...creating object and placing values in the object}
    SqrTorqueObject := TSqrTorque.create;
    SqrTorqueObject.AppliedTorque := EB_AppliedTorque.text;
    SqrTorqueObject.Width := EB_Width.text;
    SqrTorqueObject.Poisson := EB_Poisson.text;
    SqrTorqueObject.Modulus := EB_Modulus.text;
    SqrTorqueObject.GageLength := EB_GageLength.text;
    SqrTorqueObject.GageFactor := EB_GageFactor.text;
    SqrTorqueObject.Average := ST_Average.caption;
    SqrTorqueObject.Gradient := ST_Gradient.caption;
    SqrTorqueObject.FullSpan := ST_FullSpan.caption;
    MainForm.AddToLog(SqrTorqueObject);
    j := 0;
    {...placing string associated with object in outline}
    repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Design Verification') or (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, SqrTorqueObject.GetAsString);
  end
  else begin
    (TheItem as TSqrTorque).AppliedTorque := EB_AppliedTorque.text;
    (TheItem as TSqrTorque).Width := EB_Width.text;
    (TheItem as TSqrTorque).Poisson := EB_Poisson.text;
    (TheItem as TSqrTorque).Modulus := EB_Modulus.text;
    (TheItem as TSqrTorque).GageLength := EB_GageLength.text;
    (TheItem as TSqrTorque).GageFactor := EB_GageFactor.text;
    (TheItem as TSqrTorque).Average := ST_Average.caption;
    (TheItem as TSqrTorque).Gradient := ST_Gradient.caption;
    (TheItem as TSqrTorque).FullSpan := ST_FullSpan.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.DesignDlgShowing = True then begin
    DesignDlg.close;
  end;
end;

