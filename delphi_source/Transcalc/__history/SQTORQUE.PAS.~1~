(***********************************************************************)
{TSqTorqueShftFrm.CalculateMinStrain}
function TSqTorqueShftFrm.CalculateMinStrain: RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  Numerator      : RealType;
  Denominator    : RealType;
  MinResult      : RealType;
  Button         : integer;
begin
  MinResult := 0.0 ;
  ExceptionRaised := false;
  Numerator := (Length/2) * 0.707;
  Denominator := TorqueWidth/2;
  try
    MinResult := sqrt(-(sqr((Numerator/Denominator) * MaxE)) + sqr(MaxE));
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoMinStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateMinStrain := MinResult;
end;

(***********************************************************************)
{TSqTorqueShftFrm.CalculateMaxStrain}
function TSqTorqueShftFrm.CalculateMaxStrain: RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  MaxStress      : RealType;
  ShearMod       : RealType;
  Numerator      : RealType;
  Denominator    : RealType;
  MaxResult      : RealType;
  Button         : integer;
begin
  MaxResult := 0.0 ;
  ExceptionRaised := false;
  ShearMod := Elasticity/(2 * (1 + Ratio));
  MaxStress := Torque/(0.22 * (TorqueWidth * TorqueWidth * TorqueWidth));
  Numerator := MaxStress;
  Denominator := ShearMod;
  try
    MaxResult := (Numerator/Denominator)* 0.5 * 1e6 ;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoMaxStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateMaxStrain := MaxResult;
end;

(***********************************************************************)
{TSqTorqueShftFrm.CalculateAvgStrain}
function TSqTorqueShftFrm.CalculateAvgStrain: RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  Numerator      : RealType;
  Denominator    : RealType;
  AvgResult      : RealType;
  Button         : integer;
begin
  AvgResult := 0.0 ;
  ExceptionRaised := false;
  Numerator := MinE + MaxE;
  Denominator := 2;
  try
    AvgResult := Numerator/Denominator;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoAvgStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateAvgStrain := AvgResult;
end;

(***********************************************************************)
{TSqTorqueShftFrm.CalculateGradient}
function TSqTorqueShftFrm.CalculateGradient: RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  Numerator      : RealType;
  Denominator    : RealType;
  GradientResult : RealType;
  Button         : integer;
begin
  GradientResult := 0.0 ;
  ExceptionRaised := false;
  Numerator := MaxE - MinE;
  Denominator := MaxE;
  try
    GradientResult :=  (Numerator/Denominator){ * 100};
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoGradient, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateGradient := GradientResult * 100;
end;

(***********************************************************************)
{TSqTorqueShftFrm.CalculateFullSpan}
function TSqTorqueShftFrm.CalculateFullSpan: RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  FirstTerm      : RealType;
  SecondTerm     : RealType;
  SpanResult     : RealType;
  Button         : integer;
begin
  SpanResult := 0.0 ;
  ExceptionRaised := false;
  FirstTerm := Factor;
  SecondTerm := (2 * (AverageE * 2))/4;
  try
    SpanResult := (FirstTerm * SecondTerm) * 1e-3;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_NoFullSpan, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateFullSpan := SpanResult;
end;

(***********************************************************************)
{TSqTorqueShftFrm.FormCreate}
procedure TSqTorqueShftFrm.FormCreate(Sender: TObject);
var
  TorqueUnit    : array[0..MAXTEXTLENGTH-1] of char;
  DimensionUnit : array[0..MAXTEXTLENGTH-1] of char;
  ModulusUnit   : array[0..MAXTEXTLENGTH-1] of char;
begin
  {...determining whether to use Std. or Si units for form units}
  if MainForm.UnitsAreUS = true then begin
    LoadString(hinstance, ID_SZ_TorqueStd, TorqueUnit, sizeof(TorqueUnit));
    LoadString(hinstance, ID_SZ_Inches, DimensionUnit, sizeof(DimensionUnit));
    LoadString(hinstance, ID_SZ_PSI, ModulusUnit, sizeof(ModulusUnit));
  end
  else begin
    LoadString(hinstance, ID_SZ_TorqueMetric, TorqueUnit, sizeof(TorqueUnit));
    LoadString(hinstance, ID_SZ_MM, DimensionUnit, sizeof(DimensionUnit));
    LoadString(hinstance, ID_SZ_GPa, ModulusUnit, sizeof(ModulusUnit));
  end;
  {...placing form units on form}
  ST_TorqueUnit.caption := TorqueUnit;
  ST_WidthUnit.caption := DimensionUnit;
  ST_ModulusUnit.caption := ModulusUnit;
  ST_LengthUnit.caption := DimensionUnit;
  Font.Name := 'MS Sans Serif';
  Font.Size := 8;
end;

(***********************************************************************)
{TSqTorqueShftFrm.BN_ComputeClick}
procedure TSqTorqueShftFrm.BN_ComputeClick(Sender: TObject);
const
  MINAPPLIEDTORQUE_US      = 0.0000;
  MAXAPPLIEDTORQUE_US      = 500000;
  MINWIDTH_US              = 0.20;
  MAXWIDTH_US              = 20.0;
  MINPOISSON_US            = 0.1;
  MAXPOISSON_US            = 0.4;
  MINMODULUS_US            = 5000000;
  MAXMODULUS_US            = 50000000;
  MINGAGELENGTH_US         = 0.008;
  MAXGAGELENGTH_US         = 1;
  MINGAGEFACTOR_US         = 1.0;
  MAXGAGEFACTOR_US         = 5.0;
var
  ErrorMsg         : array[0..MAXERRORLENGTH] of char;
  ErrorUnit        : array[0..MAXERRORLENGTH] of char;
  ErrorAnd         : array[0..MAXERRORLENGTH] of char;
  ErrorCaption     : array[0..MAXERRORLENGTH] of char;
  StrUnit          : string;
  StrAnd           : string;
  StrMsg           : string;
  StrMin           : string;
  strMax           : string;
  EditStrings      : string;
  MinAppliedTorque : RealType;
  MaxAppliedTorque : RealType;
  MinWidth         : RealType;
  MaxWidth         : RealType;
  MinPoisson       : RealType;
  MaxPoisson       : RealType;
  MinModulus       : RealType;
  MaxModulus       : RealType;
  MinGageLength    : RealType;
  MaxGageLength    : RealType;
  MinGageFactor    : RealType;
  MaxGageFactor    : RealType;
  ErrorCode        : integer;
  Button           : integer;
begin
  {...Determining which values to use std. or si for min and max values}
  if MainForm.UnitsAreUS = True then begin
    MinAppliedTorque := MINAPPLIEDTORQUE_US;
    MaxAppliedTorque := MAXAPPLIEDTORQUE_US;
    MinWidth         := MINWIDTH_US;
    MaxWidth         := MAXWIDTH_US;
    MinPoisson       := MINPOISSON_US;
    MaxPoisson       := MAXPOISSON_US;
    MinModulus       := MINMODULUS_US;
    MaxModulus       := MAXMODULUS_US;
    MinGageLength    := MINGAGELENGTH_US;
    MaxGageLength    := MAXGAGELENGTH_US;
    MinGageFactor    := MINGAGEFACTOR_US;
    MaxGageFactor    := MAXGAGEFACTOR_US;
  end
  else begin
    MinAppliedTorque := MINAPPLIEDTORQUE_US * 0.11298;
    MaxAppliedTorque := MAXAPPLIEDTORQUE_US * 0.11298;
    MinWidth         := Inches_To_mm(MINWIDTH_US);
    MaxWidth         := Inches_To_mm(MAXWIDTH_US);
    MinPoisson       := MINPOISSON_US;
    MaxPoisson       := MAXPOISSON_US;
    MinModulus       := PSI_To_GPa(MINMODULUS_US);
    MaxModulus       := PSI_To_GPa(MAXMODULUS_US);
    MinGageLength    := Inches_To_mm(MINGAGELENGTH_US);
    MaxGageLength    := Inches_To_mm(MAXGAGELENGTH_US);
    MinGageFactor    := MINGAGEFACTOR_US;
    MaxGageFactor    := MAXGAGEFACTOR_US;
  end;
  ST_Average.caption := '';
  ST_Gradient.caption := '';
  ST_FullSpan.caption := '';
  {...checking Applied Torque to see if valid}
  IsThereAnError := False;
  EditStrings := EB_AppliedTorque.text;
  val(EditStrings, Torque, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AppliedTorque.setfocus;
    EB_AppliedTorque.clearselection;
    exit;
  end
  else if (Torque < MinAppliedTorque) or (Torque > MaxAppliedTorque) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_TorqueStd, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_TorqueMetric, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_AppliedTorque, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinAppliedTorque, ffFixed, 8, 3);
    StrMax := floattostrf(MaxAppliedTorque, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AppliedTorque.setfocus;
    EB_AppliedTorque.clearselection;
    exit;
  end;
  if MainForm.UnitsAreUS = false then begin
    Torque := Torque * 1000;
  end;
  {...checking Torque Width to see if valid}
  EditStrings := EB_Width.text;
  val(EditStrings, TorqueWidth, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Width.setfocus;
    EB_Width.clearselection;
    exit;
  end
  else if (TorqueWidth < MinWidth) or (TorqueWidth > MaxWidth) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_TorqueWidth, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinWidth, ffFixed, 8, 3);
    StrMax := floattostrf(MaxWidth, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Width.setfocus;
    EB_Width.clearselection;
    exit;
  end;
  {...checking to see if Poisson is valid}
  EditStrings := EB_Poisson.text;
  val(EditStrings, Ratio, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Poisson.setfocus;
    EB_Poisson.clearselection;
    exit;
  end
  else if (Ratio < MinPoisson) or (Ratio > MaxPoisson) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_Poisson, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinPoisson, ffFixed, 8, 3);
    StrMax := floattostrf(MaxPoisson, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Poisson.setfocus;
    EB_Poisson.clearselection;
    exit;
  end;
  {...checking to see if Modulus value is valid}
  EditStrings := EB_Modulus.text;
  val(EditStrings, elasticity, errorcode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Modulus.setfocus;
    EB_Modulus.clearselection;
    exit;
  end
  else if (elasticity < MinModulus) or (elasticity > MaxModulus) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_PSI, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_GPA, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_Modulus, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinModulus, ffFixed, 8, 3);
    StrMax := floattostrf(MaxModulus, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Modulus.setfocus;
    EB_Modulus.clearselection;
    exit;
  end;
  if MainForm.UnitsAreUS = false then begin
    Elasticity := Elasticity * 1000;
  end;
  {...checking to see if Gage Length is valid}
  EditStrings := EB_GageLength.text;
  val(EditStrings, length, errorcode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageLength.setfocus;
    EB_GageLength.clearselection;
    exit;
  end
  else if (length < MinGageLength) or (length > MaxGageLength) then begin
    IsThereAnError := True;
    if MainForm.UnitsAreUS = True then begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_GageLength, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinGageLength, ffFixed, 8, 3);
    StrMax := floattostrf(MaxGageLength, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageLength.setfocus;
    EB_GageLength.clearselection;
    exit;
  end;
  {...checking to see if Gage Factor is valid}
  EditStrings := EB_GageFactor.text;
  val(EditStrings, Factor, errorcode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageFactor.setfocus;
    EB_GageFactor.clearselection;
    exit;
  end
  else if (Factor < MinGageFactor) or (Factor > MaxGageFactor) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_GageFactor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinGageFactor, ffFixed, 8, 3);
    StrMax := floattostrf(MaxGageFactor, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageFactor.setfocus;
    EB_GageFactor.clearselection;
    exit;
  end;
 {...checking to make sure gage length is not greater than width/0.707}
  if Length > (TorqueWidth/0.707) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_GageLengthWidth, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageLength.setfocus;
    EB_GageLength.clearselection;
    exit;
  end;
  {...doing calculations}
  if IsThereAnError = False then begin
    {...Max Strain}
    MaxE := CalculateMaxStrain;
    if abs(MaxE) > 5000 then begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ST_Average.caption := '';
      ST_Gradient.caption := '';
      ST_FullSpan.caption := '';
      ModalResult := 0;
      exit;
    end;
    {...Min Strain}
    MinE := CalculateMinStrain;
    if abs(MinE) > 5000 then begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ST_Average.caption := '';
      ST_Gradient.caption := '';
      ST_FullSpan.caption := '';
      ModalResult := 0;
      exit;
    end;
    {...Average Strain}
    AverageE := CalculateAvgStrain;
    if abs(AverageE) < 5000 then begin
      if ExceptionRaised = false then begin
        AverageText := floattostrf(AverageE, ffFixed, 4, 0);
        ST_Average.caption := AverageText;
      end;
    end
    else begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ST_Average.caption := '';
      ST_Gradient.caption := '';
      ST_FullSpan.caption := '';
      ModalResult := 0;
      exit;
    end;
    {...Gradient}
    TheGradient := CalculateGradient;
    if ExceptionRaised = false then begin
      GradientText := floattostrf(TheGradient, ffFixed, 4, 1);
      ST_Gradient.caption := GradientText;
    end;
    {...Full Bridge Sensitivity}
    Sensitivity := CalculateFullSpan;
    if ExceptionRaised = false then begin
      SpanText := floattostrf(Sensitivity, ffFixed, 4, 3);
      ST_FullSpan.caption := SpanText;
    end;
    if abs(AverageE) > 1700 then begin
      LoadString(hinstance, ID_SZ_StrainExceeds1700, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ModalResult := 0;
    end;
  end;
end;

