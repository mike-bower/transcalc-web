(* ********************************************************************* *)
{ TRndSolidColFrm.BN_OKClick }
procedure TRndSolidColFrm.BN_OKClick(Sender: TObject);
var
  TheItem: TacStreamable;
  i: integer;
  j: integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = true then
  begin
    exit;
  end;
  MainForm.DesignChosen := true;
  { ...getting item from object if there is one }
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TRoundSolidCol then
    begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.FLog.Count);
  { ...if there is an object, then placing values in edit boxes }
  if TheItem = nil then
  begin
    { ...creating object and placing values in object }
    RoundSolidColObject := TRoundSolidCol.create;
    RoundSolidColObject.AppliedLoad := EB_AppliedLoad.text;
    RoundSolidColObject.Diameter := EB_Diameter.text;
    RoundSolidColObject.Poisson := EB_Poisson.text;
    RoundSolidColObject.Modulus := EB_Modulus.text;
    RoundSolidColObject.GageFactor := EB_GageFactor.text;
    RoundSolidColObject.AxialStrain := ST_Axial.caption;
    RoundSolidColObject.TransverseStrain := ST_Transverse.caption;
    RoundSolidColObject.FullSpan := ST_FullSpan.caption;
    MainForm.AddToLog(RoundSolidColObject);
    j := 0;
    { ...placing string associated with object in the outline }
    repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Design Verification') or
      (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, RoundSolidColObject.GetAsString);
  end
  else
  begin
    (TheItem as TRoundSolidCol).AppliedLoad := EB_AppliedLoad.text;
    (TheItem as TRoundSolidCol).Diameter := EB_Diameter.text;
    (TheItem as TRoundSolidCol).Poisson := EB_Poisson.text;
    (TheItem as TRoundSolidCol).Modulus := EB_Modulus.text;
    (TheItem as TRoundSolidCol).GageFactor := EB_GageFactor.text;
    (TheItem as TRoundSolidCol).AxialStrain := ST_Axial.caption;
    (TheItem as TRoundSolidCol).TransverseStrain := ST_Transverse.caption;
    (TheItem as TRoundSolidCol).FullSpan := ST_FullSpan.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.DesignDlgShowing = true then
  begin
    DesignDlg.close;
  end;
end;

