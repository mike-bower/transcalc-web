    EB_GageFactor.clearselection;
    exit;
  end
  else if (Factor < MinGageFactor) or (Factor > MaxGageFactor) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_GageFactor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinGageFactor, ffFixed, 8, 3);
    strMax := floattostrf(MaxGageFactor, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageFactor.setfocus;
    EB_GageFactor.clearselection;
    exit;
  end;
  { ...checking to make sure inside diameter is not greater than outside diameter }
  if Inside >= Outside then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_InsideTooBig, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_OutsideDiameter.setfocus;
    EB_OutsideDiameter.clearselection;
    exit;
  end;
  { ...doing calculations }
  if IsThereAnError = false then
  begin
    { ...Shear Strain }
    ShearE := CalculateShearStrain;
    { ...Transverse Strain }
    NormalE := CalculateNormalStrain;
    if abs(NormalE) < 5000 then
    begin
      if ExceptionRaised = false then
      begin
        NormalText := floattostrf(NormalE, ffFixed, 4, 0);
        ST_Normal.caption := NormalText;
      end;
    end
    else
    begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ST_Normal.caption := '';
      ST_FullSpan.caption := '';
      ModalResult := 0;
      exit;
    end;
    { ...Full Bridge Sensitivity }
    FullSensitivity := CalculateFullSpan;
    if ExceptionRaised = false then
    begin
      FullSpanText := floattostrf(FullSensitivity, ffFixed, 4, 3);
      ST_FullSpan.caption := FullSpanText;
    end;
    if abs(NormalE) > 1700 then
    begin
      LoadString(hinstance, ID_SZ_StrainExceeds1700, ErrorMsg,
        sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ModalResult := 0;
    end;
  end;
end;

