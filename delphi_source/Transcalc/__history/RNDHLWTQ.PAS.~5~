{ TRndHlwTorqueFrm.BN_OKClick }
procedure TRndHlwTorqueFrm.BN_OKClick(Sender: TObject);
var
  TheItem: TacStreamable;
  i: integer;
  j: integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = true then
  begin
    exit;
  end;
  MainForm.DesignChosen := true;
  { getting item from object if there is one }
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TRndHollowTorque then
    begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.FLog.Count);
  { ...if there is an object then placing values in edit boxes }
  if TheItem = nil then
  begin
    { ...creating and placing values in object }
    RndHollowTorqueObject := TRndHollowTorque.create;
    RndHollowTorqueObject.AppliedTorque := EB_AppliedTorque.text;
    RndHollowTorqueObject.InsideDiameter := EB_InsideDiameter.text;
    RndHollowTorqueObject.OutsideDiameter := EB_OutsideDiameter.text;
    RndHollowTorqueObject.Poisson := EB_Poisson.text;
    RndHollowTorqueObject.Modulus := EB_modulus.text;
    RndHollowTorqueObject.GageFactor := EB_GageFactor.text;
    RndHollowTorqueObject.Normal := ST_Normal.caption;
    RndHollowTorqueObject.FullSpan := ST_FullSpan.caption;
    MainForm.AddToLog(RndHollowTorqueObject);
    j := 0;
    { ...placing string associated with object in the outline }
    repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Design Verification') or
      (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, RndHollowTorqueObject.GetAsString);
  end
  else
  begin
    (TheItem as TRndHollowTorque).AppliedTorque := EB_AppliedTorque.text;
    (TheItem as TRndHollowTorque).InsideDiameter := EB_InsideDiameter.text;
    (TheItem as TRndHollowTorque).OutsideDiameter := EB_OutsideDiameter.text;
    (TheItem as TRndHollowTorque).Poisson := EB_Poisson.text;
    (TheItem as TRndHollowTorque).Modulus := EB_modulus.text;
    (TheItem as TRndHollowTorque).GageFactor := EB_GageFactor.text;
    (TheItem as TRndHollowTorque).Normal := ST_Normal.caption;
    (TheItem as TRndHollowTorque).FullSpan := ST_FullSpan.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.DesignDlgShowing = true then
  begin
    DesignDlg.close;
  end;
end;

