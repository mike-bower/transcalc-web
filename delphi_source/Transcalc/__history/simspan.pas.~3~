    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_LowRBridge.setfocus;
    EB_LowRBridge.clearselection;
    exit;
  end
  else if (TheLowRBridge < MinRBridge) or (TheLowRBridge > MaxRBridge) then begin
    IsThereAnError := True;
