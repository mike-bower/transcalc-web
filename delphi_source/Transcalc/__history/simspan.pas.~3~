(***********************************************************************)
{TSimultaneousSpan.AssignTo}
procedure TSimultaneousSpan.AssignTo(Dest: TPersistent);
begin
  if (Dest is TSimultaneousSpan) and (Self is Dest.ClassType) then begin
    inherited AssignTo(TLogItem(Dest));
    with Dest as TSimultaneousSpan do begin
    FLowSpan := self.FLowSpan;
    FLowRBridge := self.LowRBridge;
    FLowRmod := self.FLowRmod;
    FHighSpan := self.FHighSpan;
    FHighRBridge := self.HighRBridge;
    FHighRmod := self.FHighRMod;
    FAmbientSpan := self.FAmbientSpan;
    FAmbientRBridge := self.FAmbientRBridge;
    FAmbientRmod := self.AmbientRMod;
    FDesiredSpan := self.FDesiredSpan;
    FResistors := self.FResistors;
    FRshunt := self.FRShunt;
    FRMod := self.FRMod;
    FSpan := self.FSpan;
    TheString := self.TheString;
    end;
  end
  else begin
    inherited AssignTo(Dest);
  end;
end;

