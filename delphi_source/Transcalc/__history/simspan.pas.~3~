    SimultaneousSpan.AmbientRMod := EB_AmbientRMod.text;
    SimultaneousSpan.DesiredSpan := EB_DesiredSpan.text;
    SimultaneousSpan.RShunt := ST_RShunt.caption;
    SimultaneousSpan.RMod := ST_RMod.caption;
    SimultaneousSpan.Span := ST_Span.caption;
    MainForm.AddToLog(SimultaneousSpan);
    j := 0;
    {...placing object string in outline}
    Repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Circuit Refinements') or (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, SimultaneousSpan.GetAsString);
  end
  else begin
    (TheItem as TSimultaneousSpan).LowSpan := EB_LowSpan.text;
    (TheItem as TSimultaneousSpan).LowRBridge := EB_LowRBridge.text;
    (TheItem as TSimultaneousSpan).LowRMod := EB_LowRMod .text;
    (TheItem as TSimultaneousSpan).HighSpan := EB_HighSpan.text;
    (TheItem as TSimultaneousSpan).HighRBridge := EB_HighRBridge.text;
    (TheItem as TSimultaneousSpan).HighRMod := EB_HighRMod.text;
    (TheItem as TSimultaneousSpan).AmbientSpan := EB_AmbientSpan.text;
    (TheItem as TSimultaneousSpan).AmbientRBridge := EB_AmbientRBridge.text;
    (TheItem as TSimultaneousSpan).AmbientRMod := EB_AmbientRMod.text;
    (TheItem as TSimultaneousSpan).DesiredSpan := EB_DesiredSpan.text;
    (TheItem as TSimultaneousSpan).RShunt := ST_RShunt.caption;
    (TheItem as TSimultaneousSpan).RMod := ST_RMod.caption;
    (TheItem as TSimultaneousSpan).Span := ST_Span.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.CompDlgShowing = true then begin
    CompensationDlg.close;
  end;
end;

