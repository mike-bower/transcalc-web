    ModalResult := 0;
    EB_LowRMod.setfocus;
    EB_LowRMod.clearselection;
    exit;
  end
  else if (TheLowRMod < MinRMod) or (TheLowRMod > MaxRMod) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_LowRMod, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinRMod, ffFixed, 8, 3);
    StrMax := floattostrf(MaxRMod, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_LowRMod.setfocus;
    EB_LowRMod.clearselection;
    exit;
  end;
  {..checking to see if Ambient Temperature Span is valid}
  EditStrings := EB_AmbientSpan.text;
  val(EditStrings, TheAmbientSpan, ErrorCode);
