    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRBridge.setfocus;
    EB_HighRBridge.clearselection;
    exit;
  end
  else if (TheHighRBridge < MinRBridge) or (TheHighRBridge > MaxRBridge) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_HighRBridge, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinRBridge, ffFixed, 8, 3);
    StrMax := floattostrf(MaxRBridge, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRBridge.setfocus;
    EB_HighRBridge.clearselection;
    exit;
  end;
  {..checking to see if High RMod is valid}
  EditStrings := EB_HighRMod.text;
  val(EditStrings, TheHighRMod, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRMod.setfocus;
    EB_HighRMod.clearselection;
    exit;
  end
  else if (TheHighRMod < MinRMod) or (TheHighRMod > MaxRMod) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_HighRMod, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinRMod, ffFixed, 8, 3);
    StrMax := floattostrf(MaxRMod, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRMod.setfocus;
    EB_HighRMod.clearselection;
    exit;
  end;
  {..checking to see if Desired Span is valid}
  EditStrings := EB_DesiredSpan.text;
  val(EditStrings, TheDesiredSpan, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_DesiredSpan.setfocus;
    EB_DesiredSpan.clearselection;
    exit;
  end
  else if (TheDesiredSpan < MinSpan) or (TheDesiredSpan > MaxSpan) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_MV, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_HighSpan, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinSpan, ffFixed, 8, 3);
    StrMax := floattostrf(MaxSpan, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_DesiredSpan.setfocus;
    EB_DesiredSpan.clearselection;
    exit;
  end;
  if (TheLowSpan > TheAmbientSpan) then begin
    {..display message telling user the low span must be lower than ambient span}
    LoadString(hinstance, ID_SZ_LowOutAmbientOut, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    IsThereAnError := true;
    EB_AmbientSpan.setfocus;
    exit;
  end;                        
  if (TheAmbientSpan > TheHighSpan) then begin
    {..display message telling user the ambient span must be lower than high span}
    LoadString(hinstance, ID_SZ_AmbientOutHighOut, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    IsThereAnError := true;
    EB_HighSpan.setfocus;
    exit;
  end;
  {...error check to make sure desired span is less than all other spans}
  if (TheDesiredSpan >= TheLowSpan)  then begin
    LoadString(hinstance, ID_SZ_LowDesired, ErrorMsg, sizeof(ErrorCaption));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_DesiredSpan.setfocus;
    EB_DesiredSpan.clearselection;
    exit;
  end
  else if (TheDesiredSpan >= TheAmbientSpan) then begin
    LoadString(hinstance, ID_SZ_AmbientDesired, ErrorMsg, sizeof(ErrorCaption));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_DesiredSpan.setfocus;
    EB_DesiredSpan.clearselection;
    exit;
  end
  else if (TheDesiredSpan >= TheHighSpan) then begin
    LoadString(hinstance, ID_SZ_HighDesired, ErrorMsg, sizeof(ErrorCaption));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_DesiredSpan.setfocus;
    EB_DesiredSpan.clearselection;
    exit;
  end;
  {...calculation starts}
  E0 := TheLowSpan;
  E1 := TheAmbientSpan;
  E2 := TheHighSpan;
  Rb0 := TheLowRBridge;
  Rb1 := TheAmbientRBridge;
  Rb2 := TheHighRBridge;
  Rn1Rn0 := TheAmbientRMod/TheLowRMod;
  Rn1Rn2 := TheAmbientRMod/TheHighRMod;
  Q := TheDesiredSpan;
  if (E0 <> 0) and (E1 <> 0) and (E2 <> 0) and (Q <> 0) then begin
    {set up equation}
    {T0}
    try
      T0 := (Rb2 * (E2 - Q) - Rb0 * (E0 - Q));
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if (T0 = 0) then begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    {Z}
    try
      Z := (Rb1 * (E1 - Q) - Rb0 * (E0 - Q))/ T0;
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {T1}
    try
      T1 := Z * (Rn1Rn0 - Rn1Rn2);
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {T2}
    try
      T2 := Rn1Rn2 * (Rn1Rn0 -1);
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if T1 - T2 = 0.0 then begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    {RsRn1}
    try
      RsRn1 := (Rn1Rn0 - T1 - 1)/ (T1 - T2);
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {T3}
    try
      T3 := Rb1 * (E1 - Q) - Rb0 * (E0 - Q);
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {T4}
    try
      T4 := RsRn1 * (1 + Rn1Rn0);
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {T5}
    try
      T5 := Sqr(RsRn1) * Rn1Rn0;
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {T6}
    try
      T6 := Q * RsRn1 * (Rn1Rn0 - 1);
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {Shunt}
    try
      Shunt := (T3 * (1 + T4 + T5))/T6;
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {RMod}
    try
      Rmod1 := (Shunt / RsRn1);
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    {RSpan}
    try
      Span1 := (RB0 * (E0 - Q) / Q) - (Shunt / (1 + RsRn1 * Rn1Rn0));
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if Shunt < 0.0 then begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorCaption));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ModalResult := 0;
      ExceptionRaised := true;
      exit;
    end
    else begin
 //     str(Shunt:6:2, RShuntText);
      RShuntText := format('%6.2f',[Shunt]) ;
      ST_RShunt.caption := RShuntText;
    end;
    if RMod1 < 0.0 then begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorCaption));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ModalResult := 0;
      ExceptionRaised := true;
      exit;
    end
    else begin
  //    str(Rmod1:6:1, RModText);
      RModText := format('%6.1',[Rmod1]) ;
      ST_Rmod.caption := RModText;
    end;
    if Span1 < 0.0 then begin
      LoadString(hinstance, ID_SZ_DesiredSpanHigh, ErrorMsg, sizeof(ErrorCaption));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ModalResult := 0;
      EB_DesiredSpan.setfocus;
      EB_DesiredSpan.clearselection;
      exit;
    end
    else begin
  //    str(Span1:6:2, SpanText);
      SpanText := format('%6.2f',[Span1]) ;
      ST_Span.caption := SpanText;
    end;
  end
  else begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_LowSpanNoZero, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_LowSpan.setfocus;
    EB_LowSpan.clearselection;
    exit;
  end;
end;

