const
  MINSPAN_US    = -10;
  MAXSPAN_US    = 10;
  MINRBRIDGE_US = 50;
  MAXRBRIDGE_US = 10000;
  MINRMOD_US    = 0.001;
  MAXRMOD_US    = 1000;
var
  ErrorMsg            : array[0..MAXERRORLENGTH-1] of char;
  ErrorUnit           : array[0..MAXERRORLENGTH-1] of char;
  ErrorAnd            : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption        : array[0..MAXERRORLENGTH-1] of char;
  X                   : array[1..3] of RealType;
  StrUnit             : string;
  StrAnd              : string;
  StrMsg              : string;
  StrMin              : string;
  StrMax              : string;
  EditStrings         : string;
  IsThereAnError      : boolean;
  MinSpan             : RealType;
  MaxSpan             : RealType;
  MinRBridge          : RealType;
  MaxRBridge          : RealType;
  MinRMod             : RealType;
  MaxRMod             : RealType;
  E0, E1, E2          : RealType;
  Rn1Rn0, Rn1Rn2      : RealType;
  Rb0, Rb1, Rb2       : RealType;
  RsRn1               : RealType;
  Q                   : RealType;
  T0, T1, T2, T3, T4,
  T5, T6              : RealType;
  Rmod0, Rmod1, Rmod2 : RealType;
  Span1               : RealType;
  Shunt               : RealType;
  Z                   : RealType;
  ErrorCode           : integer;
  Button              : integer;
  code                : integer;
  index               : integer;
begin
  MinSpan := MINSPAN_US;
  MaxSpan := MAXSPAN_US;
  MinRBridge := MINRBRIDGE_US;
  MaxRBridge := MAXRBRIDGE_US;
  MinRMod := MINRMOD_US;
  MaxRMod := MAXRMOD_US;
  ST_RShunt.caption := '';
  ST_RMod.caption := '';
  ST_Span.caption := '';
  IsThereAnError := false;
  {..checking to see if LowTemperature Span is valid}
  EditStrings := EB_LowSpan.text;
  val(EditStrings, TheLowSpan, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_LowSpan.setfocus;
    EB_LowSpan.clearselection;
    exit;
  end
  else if (TheLowSpan < MinSpan) or (TheLowSpan > MaxSpan) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_MV, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_LowSpan, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinSpan, ffFixed, 8, 3);
    StrMax := floattostrf(MaxSpan, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_LowSpan.setfocus;
    EB_LowSpan.clearselection;
    exit;
  end;
  {..checking to see if Low RBridge is valid}
