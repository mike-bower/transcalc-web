(***********************************************************************)
{TZeroBalanceFrm.BN_ComputeClick}
procedure TZeroBalanceFrm.BN_ComputeClick(Sender: TObject);
const
  MINUNBALANCE   = -10;
  MAXUNBALANCE   = 10;
  MINRBRIDGE     = 50;
  MAXRBRIDGE     = 10000;
var
  ErrorMsg            : array[0..MAXERRORLENGTH-1] of char;
  ErrorUnit           : array[0..MAXERRORLENGTH-1] of char;
  ErrorAnd            : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption        : array[0..MAXERRORLENGTH-1] of char;
  StrUnit             : string;
  StrAnd              : string;
  StrMsg              : string;
  StrMin              : string;
  StrMax              : string;
  EditStrings         : string;
  ErrorCode           : integer;
  Button              : integer;
begin
  ST_Resistance.caption := '';
  ST_BridgeArm.caption := '';
  IsThereAnError := false;
  {..checking to see if UnBalance is valid}
  EditStrings := EB_Unbalance.text;
  val(EditStrings, UnBal, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Unbalance.setfocus;
    EB_Unbalance.clearselection;
    exit;
  end
  else if (UnBal < MINUNBALANCE) or (UnBal > MAXUNBALANCE) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_MV, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_Unbalance, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MINUNBALANCE, ffFixed, 8, 3);
    StrMax := floattostrf(MAXUNBALANCE, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Unbalance.setfocus;
    EB_Unbalance.clearselection;
    exit;
  end;
  {..checking to see if RBridge is valid}
  EditStrings := EB_RBridge.text;
  val(EditStrings, Bridge, ErrorCode);
  if ErrorCode <> 0 then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_RBridge.setfocus;
    EB_RBridge.clearselection;
    exit;
  end
  else if (Bridge < MINRBRIDGE) or (Bridge > MAXRBRIDGE) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_BridgeResist, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MINRBRIDGE, ffFixed, 8, 3);
    StrMax := floattostrf(MAXRBRIDGE, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_RBridge.setfocus;
    EB_RBridge.clearselection;
    exit;
  end;
  {...calculating Resistance value}
  if (UnBal = 0) then begin
    {..display message telling user the bridge is balanced, calculation not needed}
    LoadString(hinstance, ID_SZ_UnBalanceEqualZero, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    exit;
  end
  else begin
    ResistValue := CalculateResistance;
    ST_Resistance.caption := floattostrf(abs(ResistValue), ffFixed, 4, 2);
    ST_BridgeArm.caption := CalculateBridgeArm;
  end;
end;

(***********************************************************************)
{TZeroBalanceFrm.FormActivate}
procedure TZeroBalanceFrm.FormActivate(Sender: TObject);
var
  EditStrings : string;
  i           : integer;
  TheItem     : TacStreamable;
  TheItems    : string;
begin
  CB_WireType.itemindex := 0;
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  {...add 1st Wire Type to Combobox}
  TheItems := CB_WireType.items.strings[0];
  CB_WireType.items.delete(0);
  Wire := TWire.create;
  Wire.name := 'Constantan (A Alloy)';
  Wire.Resistivity := 294;
  Wire.TCR := 0.00004;
  CB_WireType.items.addobject(TheItems, Wire);
  {...add 2nd Wire Type to Combobox}
  TheItems := CB_WireType.items.strings[1];
  CB_WireType.items.delete(1);
  Wire := TWire.create;
  Wire.name := 'Manganin';
  Wire.Resistivity := 290;
  Wire.TCR := 0.000015;
  CB_WireType.items.addobject(TheItems, Wire);
  {...add 3rd Wire Type to Combobox}
  TheItems := CB_WireType.items.strings[2];
  CB_WireType.items.delete(2);
  Wire := TWire.create;
  Wire.name := 'Modified Karma (K Alloy)';
  Wire.Resistivity := 800;
  Wire.TCR := 0.00002;
  CB_WireType.items.addobject(TheItems, Wire);
  {...getting the object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    If MainForm.Flog.AtIndex(i) is TZeroBalance then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or ( i > MainForm.Flog.Count);
  {...If there is object, placing values in edit boxes}
  if TheItem <> nil then begin
    EB_UnBalance.text := (TheItem as TZeroBalance).UnBalance;
    EB_RBridge.text := (TheItem as TZeroBalance).RBridge;
    ST_Resistance.caption := (TheItem as TZeroBalance).Resistance;
    CB_WireType.ItemIndex := (TheItem as TZeroBalance).TheWireType;
    ST_ResistanceTCR.caption := (TheItem as TZeroBalance).ResistorTCR;
    ST_BridgeArm.caption := (TheITem as TZeroBalance).BridgeArm;
  end
  else begin
    CB_Wiretype.Itemindex := 0;
    CB_WireTypeChange(Sender);
  end;
  {...placing initial values in old variables in case cancel clicked}
  OldUnBalance := EB_UnBalance.text;
  OldRBridge := EB_RBridge.text;
  Old_Resistance := ST_Resistance.caption;
  Old_BridgeArm := ST_BridgeArm.caption;
end;

(***********************************************************************)
{TZeroBalanceFrm.BN_CancelClick}
procedure TZeroBalanceFrm.BN_CancelClick(Sender: TObject);
begin
  {...placing initialvalues in edit box}
  EB_Unbalance.text := OldUnBalance;
  EB_RBridge.text := OldRBridge;
  ST_Resistance.caption := Old_Resistance;
  ST_BridgeArm.caption := Old_BridgeArm;
  close;
end;

(***********************************************************************)
{TZeroBalanceFrm.BN_OKClick}
procedure TZeroBalanceFrm.BN_OKClick(Sender: TObject);
var
  TheItem : TacStreamable;
  i       : integer;
  j       : integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = True then begin
    exit;
  end;
  {...getting the object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    If MainForm.Flog.AtIndex(i) is TZeroBalance then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or ( i > MainForm.Flog.Count);
  {...If there is object, placing values in edit boxes}
  if TheItem = nil then begin
    {...placing values in object}
    ZeroBalanceObject := TZeroBalance.create;
    ZeroBalanceObject.UnBalance := EB_UnBalance.text;
    ZeroBalanceObject.RBridge := EB_RBridge.text;
    ZeroBalanceObject.TheWireType := CB_WireType.ItemIndex;
    ZeroBalanceObject.ResistorTCR := ST_ResistanceTCR.caption;
    ZeroBalanceObject.Resistance := ST_Resistance.caption;
    ZeroBalanceObject.BridgeArm := ST_BridgeArm.caption;
    MainForm.AddToLog(ZeroBalanceObject);
    j := 0;
    {...placing object string in outline}
    Repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Circuit Refinements') or (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, ZeroBalanceObject.GetAsString);
  end
  else begin
    (TheItem as TZeroBalance).UnBalance := EB_UnBalance.text;
    (TheItem as TZeroBalance).RBridge := EB_RBridge.text;
    (TheItem as TZeroBalance).TheWireType := CB_WireType.ItemIndex;
    (TheItem as TZeroBalance).ResistorTCR := ST_ResistanceTCR.caption;
    (TheItem as TZeroBalance).Resistance := ST_Resistance.caption;
    (TheItem as TZeroBalance).BridgeArm := ST_BridgeArm.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.CompDlgShowing = true then begin
    CompensationDlg.close;
  end;
end;

