(***********************************************************************)
{TZeroBalance.AssignTo}
procedure TZeroBalance.AssignTo(Dest: TPersistent);
begin
  if (Dest is TZeroBalance) and (Self is Dest.ClassType) then begin
    inherited AssignTo(TLogItem(Dest));
    with Dest as TZeroBalance do begin
      FUnbalance := self.FUnbalance;
      FRBridge := self.FRBridge;
      FWireType := self.FWireType;
      FResistorTCR := self.FResistorTCR;
      FResistors := self.FResistors;
      FResistance := self.FResistance;
      FBridgeArm := self.FBridgeArm;
      TheString := self.TheString;
    end;
  end
  else begin
    inherited AssignTo(Dest);
  end;
end;

(***********************************************************************)
{TZeroBalance.InitFields}
procedure TZeroBalance.InitFields;
begin
  inherited initfields;
end;

(***********************************************************************)
{TZeroBalance.SaveToStream}
procedure TZeroBalance.SaveToStream(Stream : TacObjStream);
begin
  inherited SaveToStream(Stream);
  Stream.SaveBuffer(FUnbalance, sizeof(shortstring));
  Stream.SaveBuffer(FRBridge, sizeof(shortstring));
  Stream.SaveBuffer(FWireType, sizeof(Int16));
  Stream.SaveBuffer(FResistorTCR, sizeof(shortstring));
  Stream.SaveBuffer(FResistors, sizeof(shortstring));
  Stream.SaveBuffer(FResistance, sizeof(shortstring));
  Stream.SaveBuffer(FBridgeArm, sizeof(shortstring));
  Stream.SaveBuffer(TheString, sizeof(shortstring));
end;

(***********************************************************************)
{TZeroBalance.ReadFromStream}
procedure TZeroBalance.ReadFromStream(Stream: TacObjStream);
begin
  inherited ReadFromStream(Stream);
  Stream.ReadBuffer(FUnbalance, sizeof(shortstring));
  Stream.ReadBuffer(FRBridge, sizeof(shortstring));
  Stream.ReadBuffer(FWireType, sizeof(Int16));
  Stream.ReadBuffer(FResistorTCR, sizeof(shortstring));
  Stream.ReadBuffer(FResistors, sizeof(shortstring));
  Stream.ReadBuffer(FResistance, sizeof(shortstring));
  Stream.ReadBuffer(FBridgeArm, sizeof(shortstring));
  Stream.ReadBuffer(TheString, sizeof(shortstring));
end;

