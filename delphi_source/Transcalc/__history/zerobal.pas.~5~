(***********************************************************************)
{TZeroBalanceFrm.Resistance}
function TZeroBalanceFrm.CalculateResistance: RealType;
var
  ResistanceValue : RealType;
begin
  ExceptionRaised := false;
  ResistanceValue := UnBal * 4.0 * Bridge * 1e-3;
  CalculateResistance := ResistanceValue;
end;

(***********************************************************************)
{TZeroBalanceFrm.BridgeArm}
function TZeroBalanceFrm.CalculateBridgeArm: String;
var
  BridgeArmText   : array[0..MAXERRORLENGTH-1] of char;
begin
  ExceptionRaised := false;
  if ResistValue > 0 then begin
    Loadstring(hinstance, ID_SZ_PMinusSMinus, BridgeArmText, sizeof(BridgeArmText));
  end
  else begin
    Loadstring(hinstance, ID_SZ_PPlusSMinus, BridgeArmText, sizeof(BridgeArmText));
  end;
  CalculateBridgeArm := BridgeArmText;
end;

