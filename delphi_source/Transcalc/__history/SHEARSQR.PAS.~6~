function TSqrShearWebFrm.CalculateSpan: RealType; {new 6/11/97 CSS}
var
  w  : realtype;
  F  : realtype;
  h  : realtype;
  d  : realtype;
  t  : realtype;
  E  : realtype;
  v  : realtype;
  Ao : realtype;
  id : realtype;
  x  : realtype;
  Term1 : realtype;
  Term2 : realtype;
  dh    : realtype;
  db    : realtype;
  dt    : realtype;
  dh2   : realtype;
  db2   : realtype;
  dt2   : realtype;
  Output : realtype;
  MaxStress : realtype;
  MaxStrain : realtype;
  GageFactor : realtype;
  Factor1 : realtype;
  Factor2 : realtype;
  Flange : realtype;
  i : realtype;
begin
  w  := shrWidth;
  F  := Load;
  h  := shrHeight;
  id  := TheWebHeight;
  t  := shrThickness;
  E  := Elasticity;
  v  := Ratio;
  GageFactor := Factor;
  {...Calculate Area of Section, Added CSS 12/1/97}
  d := id / 2;
  x := h / 2;
  Flange := (h - id) / 2;
  Factor1 := Flange * w * (d - Flange / 2);
  Factor2 := t * d * (d / 2);
  i := (w * Power(2*x, 3)) / 12 - (((w - t) * Power(2*d, 3)) / 12);
  MaxStress := (F * (Factor1 + Factor2)) / (i * t);
  MaxStrain := MaxStress / E * (2 * (1 + v)) * 1000000 / 2;
  Output := MaxStrain * GageFactor * 0.001;
  Result := Output;
end;

{TSqrShearWebFrm.Power}
function TSqrShearWebFrm.Power(Base: realtype; Exponent: realtype): double;
var
  i : integer;
begin
{Returns value calculated from Base^Exponent -- Added CSS 12/1/97}
  try
    Result := 0;
    if (Base <> 0) then begin
      if ((Base < 0) and (Exponent = Trunc(Exponent))) then begin
        Result := 1;
        for i := 1 to Abs(Trunc(Exponent)) do Result := Result * Base;
        if (Exponent < 0) then Result := 1 / Result;
      end
      else Result := exp(ln(Base) * Exponent);
    end;
  except
    Result := 0;
  end;
end;


(***********************************************************************)
(*--------------------------Removed MJB/CSS, 12/1/97

{ TSqrShearWebFrm.Min_Strain}
function TSqrShearWebFrm.Min_Strain : RealType;
var
  ErrorMsg       : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption   : array[0..MAXERRORLENGTH-1] of char;
  FirstTerm      : RealType;
  SecondTerm     : RealType;
  ThirdTerm      : RealType;
  StrainResult   : RealType;
  Button         : integer;
begin
  ExceptionRaised := false;
  try
    FirstTerm := (3/2) * (Load/(TheWebHeight * ShrThickness)) * ((1 + Ratio)/Elasticity);
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    SecondTerm := (ShrWidth/ShrThickness) * (sqr(ShrHeight)/sqr(TheWebHeight)- 1) +
                   1 - (4/(3 * sqr(TheWebHeight))) * ((0.7 * GLength * Glength * Glength)/
                   (0.7 * Glength));
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    ThirdTerm := (ShrWidth/ShrThickness) * (((ShrHeight * ShrHeight * ShrHeight)/
                  (TheWebHeight * TheWebHeight * TheWebHeight)) - 1) + 1;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  try
    StrainResult :=  (FirstTerm * (SecondTerm/ThirdTerm)) *1e6;
  except
    on EMathError do begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
  end;
  Min_Strain := StrainResult;
end;

