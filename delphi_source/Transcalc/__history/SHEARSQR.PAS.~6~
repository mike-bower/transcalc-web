{TSqrShearWebFrm.BN_OKClick}
procedure TSqrShearWebFrm.BN_OKClick(Sender: TObject);
var
  TheItem : TacStreamable;
  i       : integer;
  j       : integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = True then begin
    exit;
  end;
  MainForm.DesignChosen := true;
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TSqrShear then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  {...if there is an object them placing values in edit boxes}
  if TheItem = nil then begin
    {...creating and placing values in object}
    SqrShearObject := TSqrShear.create;
    SqrShearObject.AppliedLoad := EB_AppliedLoad.text;
    SqrShearObject.Width := EB_Width.text;
    SqrShearObject.BeamHeight := EB_Height.text;
    SqrShearObject.WebHeight := EB_WebHeight.text;
    SqrShearObject.Thickness := EB_Thickness.text;
    SqrShearObject.Poisson := EB_Poisson.text;
    SqrShearObject.Modulus := EB_Modulus.text;
{    SqrShearObject.GageLength := EB_GageLength.text;  ---Removed CSS 12/1/97}
    SqrShearObject.GageFactor := EB_GageFactor.text;
    SqrShearObject.AvgStrain :=  ST_Average.caption;
{    SqrShearObject.Gradient := ST_Gradient.caption;  ---Removed CSS 12/1/97}
    SqrShearObject.FullSpan := ST_FullSpan.caption;
    MainForm.AddToLog(SqrShearObject);
    j := 0;
    {...placing string associated with object in outline}
    repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Design Verification') or (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, SqrShearObject.GetAsString);
  end
