(* ********************************************************************* *)
{ TCutD012ptForm.Recalculate }
procedure TCutD012ptForm.Recalculate;
const
  { FOIL SQUARES - SEE CCP's Data Sheet }
  S1 = 23.8 / 10.0;
  S2 = 15.0 / 5.6;
  S3 = 23.8 / 5.0;
  S4 = 25.0 / 5.6;
  S5 = 25.0 / 5.6;
  S6 = 29.4 / 10.0;
  S7 = 20.0 / 17.0;
  S8 = 30.0 / 11.2;
  S9 = 17.6 / 10.0;
  S10 = 30.0 / 11.2;
  S11 = 18.4 / 10.0;
  S12 = 30.0 / 11.2;
  S13 = 1.85;
  S14 = 27.0 / 11.2;
  TOTALSQUARES = 17.855829278;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorAnd: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorUnit: array [0 .. MAXERRORLENGTH - 1] of char;
  cs: array [0 .. 255] of char;
  EditStrings: string;
  s: string;
  StrMsg: string;
  StrUnit: string;
  StrAnd: string;
  C: RealType;
  CA: RealType;
  CB: RealType;
  CC: RealType;
  Squares: RealType;
  Rtotal: RealType;
  RStart: RealType;
  OhmsPerSquare: RealType;
  code: integer;
  Button: integer;
begin
  OhmsPerSquare := 0.0;
  { Read Starting Resistance }
  s := EB_StartingRes.text;
  val(s, RStart, code);
  if code <> 0 then
  begin
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    RStart := 0;
    ST_CalculatedRes.caption := '';
    exit;
  end
  else if (RStart < 0.01) or (RStart > 10) then
  begin
    LoadString(hinstance, ID_SZ_WrongResistor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    EditStrings := StrMsg + ' ' + '0.01' + ' ' + StrAnd + ' ' + '10.0' + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    RStart := 0;
    ST_CalculatedRes.caption := '';
    exit;
  end;
  if RStart > 0 then
  begin
    OhmsPerSquare := RStart / TOTALSQUARES;
  end;
  { Calculate Ladder "A" }
  C := (D01Resistor.FA1.IsCut / S9) + (1 / (2 * S8 + S7));
  C := (D01Resistor.FA2.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  C := (D01Resistor.FA3.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  C := (D01Resistor.FA4.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  C := (D01Resistor.FA5.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  C := (D01Resistor.FA6.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  CA := (D01Resistor.FA7.IsCut / S9) + (1 / (2 * S14 + 1 / C));
  { Calculate Ladder "B" }
  C := (D01Resistor.FB1.IsCut / S3) + (1 / (2 * S2 + S1));
  C := (D01Resistor.FB2.IsCut / S3) + (1 / (2 * S4 + 1 / C));
  C := (D01Resistor.FB3.IsCut / S3) + (1 / (2 * S4 + 1 / C));
  C := (D01Resistor.FB4.IsCut / S3) + (1 / (2 * S4 + 1 / C));
  C := (D01Resistor.FB5.IsCut / S3) + (1 / (2 * S4 + 1 / C));
  C := (D01Resistor.FB6.IsCut / S3) + (1 / (2 * S4 + 1 / C));
  C := (D01Resistor.FB7.IsCut / S3) + (1 / (2 * S4 + 1 / C));
  C := (D01Resistor.FB8.IsCut / S3) + (1 / (2 * S4 + 1 / C));
  CB := (D01Resistor.FB9.IsCut / S6) + (1 / (2 * S5 + 1 / C));
  { Calculate Ladder "C" }
  C := (D01Resistor.FC1.IsCut / S9) + (1 / (2 * S8 + S7));
  C := (D01Resistor.FC2.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  C := (D01Resistor.FC3.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  C := (D01Resistor.FC4.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  C := (D01Resistor.FC5.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  C := (D01Resistor.FC6.IsCut / S9) + (1 / (2 * S10 + 1 / C));
  CC := (D01Resistor.FC7.IsCut / S9) + (1 / (2 * S14 + 1 / C));
  { Calculate total resistance }
  Squares := 1 / CA + 1 / CB + 1 / CC + 2 * (S11 + S12 + S13);
  Rtotal := OhmsPerSquare * Squares;
  { Display }
  if Rtotal > 0 then
  begin
    // Str(Rtotal:7:1, s);
    s := format('%7.1f', [Rtotal]);
    StrPCopy(cs, s);
    ST_CalculatedRes.caption := s;
  end
  else
    ST_CalculatedRes.caption := s;
end;

