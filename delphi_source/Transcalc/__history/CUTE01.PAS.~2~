(***********************************************************************)
{TE01AdjustmentFrm.Recalculate}
procedure TE01AdjustmentFrm.Recalculate;
const
  {FOIL SQUARES - SEE CCP's Data Sheet}
  {FOIL SQUARES - SEE CCP's Data Sheet}
  S1  = 2.38;
  S2  = 2.678571;
  S3  = 4.76;
  S4  = 4.464286;
  S5  = 4.464286;
  S6  = 2.94;
  S7  = 1.176471;
  S8  = 2.678571;
  S9  = 1.76;
  S10 = 2.678571;
  S11 = 1.84;
  S12 = 2.678571;
  S13 = 1.85;
  S14 = 2.410714;
  {NEW FOIL SQUARES FOR FOR E01 RESISTOR}
  S15 = 18;(*10.8697;*) {SHUNT}
  S16 = 2.12;
  S17 = 2.12;
  S18 = 0.4;
  S19 = 1.85;
  TOTALSQUARES = 11.407340954(*10.091476859*);
var
  ErrorMsg         : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption     : array[0..MAXERRORLENGTH-1] of char;
  ErrorAnd         : array[0..MAXERRORLENGTH-1] of char;
  ErrorUnit        : array[0..MAXERRORLENGTH-1] of char;
  cs               : array[0..255] of char;
  EditStrings      : string;
  s                : string;
  StrMsg           : string;
  StrUnit          : string;
  StrAnd           : string;
  Resist12         : RealType;
  Resist23         : RealType;
  TheDifference    : RealType;
  ErrorCode        : integer;
  C,
  CA,
  CB,
  CC,
  CD,
  CE,
  CF,
  Rp1,
  Rp2,
  Rs1,
  Squares,
  OhmsPerSquare :RealType;
  Rtotal,
  RStart   : real;
  code: Integer;
  Button : integer;
begin
  ohmspersquare := 0;
  {Calculate Ladder "A"}
  C  := (E01Resistor.A1.IsCut / S3) + (1 / (2 * S2 + S1));
  C  := (E01Resistor.A2.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.A3.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.A4.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.A5.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.A6.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.A7.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.A8.IsCut / S3) + (1 / (2 * S4 + 1/C));
  CA := (E01Resistor.A9.IsCut / S6) + (1 / (2 * S5 + 1/C));
  {Calculate Ladder "B"}
  C  := (E01Resistor.B1.IsCut / S9) + (1 / (2 * S8 + S7));
  C  := (E01Resistor.B2.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.B3.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.B4.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.B5.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.B6.IsCut / S9) + (1 / (2 * S10+ 1/C));
  CB := (E01Resistor.B7.IsCut / S9) + (1 / (2 * S14+ 1/C));
  {Calculate Ladder "C"}
  C  := (E01Resistor.C1.IsCut / S9) + (1 / (2 * S8 + S7));
  C  := (E01Resistor.C2.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.C3.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.C4.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.C5.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.C6.IsCut / S9) + (1 / (2 * S10+ 1/C));
  CC := (E01Resistor.C7.IsCut / S9) + (1 / (2 * S14+ 1/C));
  { Calculate total resistance}
  Rp1 := S13 + S12 + 1/CA + S11 + 1/CB + S16;
  Rp2 := S19 + S15;
  Rs1 := S17 + 1/CC + S18;
  if E01Resistor.G1.IsCut = 1 then
    Squares := ((Rp1 * Rp2) / (Rp1 + Rp2)) + Rs1
  else
    Squares := Rp1 + Rs1;
  { Read Starting Resistance}
  s := Eb_StartingRes12.Text;
  val(s,Rstart,code);
  if code <> 0 then begin
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes12.caption := '';
    exit;
  end
  else if (Rstart < 0.00) or (RStart > 0.50) then begin
    LoadString(hinstance, ID_SZ_E01WrongResistor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    EditStrings := StrMsg;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes12.caption := '';
    exit;
  end;
  OhmsPerSquare := Rstart / TOTALSQUARES;
  RTotal := OhmsPerSquare * Squares;
  {Display}
  if RTotal > 0 then
  begin
 //   Str(Rtotal:7:2, s);
    s  := format('%7.2f',[Rtotal]) ;
    st_CalculatedRes12.caption := s;
  end
  else
    st_CalculatedRes12.caption := '';
  {- - - - Right Side - side 2 - - - - -}
  { Read Starting Resistance}
  S := eb_StartingRes23.Text;
  val(s,Rstart,code);
  if code <> 0 then begin
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes23.caption := '';
    exit;
  end
  else if (Rstart < 0.00) or (RStart > 0.50) then begin
    LoadString(hinstance, ID_SZ_E01WrongResistor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    EditStrings := StrMsg;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes23.caption := '';
    exit;
  end;
  OhmsPerSquare := Rstart / TOTALSQUARES;
  {Calculate Ladder "F"}
  C  := (E01Resistor.F1.IsCut / S3) + (1 / (2 * S2 + S1));
  C  := (E01Resistor.F2.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.F3.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.F4.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.F5.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.F6.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.F7.IsCut / S3) + (1 / (2 * S4 + 1/C));
  C  := (E01Resistor.F8.IsCut / S3) + (1 / (2 * S4 + 1/C));
  CF := (E01Resistor.F9.IsCut / S6) + (1 / (2 * S5 + 1/C));
  {Calculate Ladder "E"}
  C  := (E01Resistor.E1.IsCut / S9) + (1 / (2 * S8 + S7));
  C  := (E01Resistor.E2.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.E3.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.E4.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.E5.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.E6.IsCut / S9) + (1 / (2 * S10+ 1/C));
  CE := (E01Resistor.E7.IsCut / S9) + (1 / (2 * S14+ 1/C));
  {Calculate Ladder "C"}
  C  := (E01Resistor.D1.IsCut / S9) + (1 / (2 * S8 + S7));
  C  := (E01Resistor.D2.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.D3.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.D4.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.D5.IsCut / S9) + (1 / (2 * S10+ 1/C));
  C  := (E01Resistor.D6.IsCut / S9) + (1 / (2 * S10+ 1/C));
  CD := (E01Resistor.D7.IsCut / S9) + (1 / (2 * S14+ 1/C));
  { Calculate total resistance}
  Rp1 := S13 + S12 + 1/CF + S11 + 1/CE + S16;
  Rp2 := S19 + S15;
  Rs1 := S17 + 1/CD + S18;
  if E01Resistor.G2.IsCut = 1 then
    Squares := ((Rp1 * Rp2) / (Rp1 + Rp2)) + Rs1
  else
    Squares := Rp1 + Rs1;
  RTotal := OhmsPerSquare * Squares;
  {Display}
  if RTotal > 0 then
  begin
//    Str(Rtotal:7:2, s);
    s  := format('%7.2f',[Rtotal]) ;
    st_CalculatedRes23.caption := s
  end
  else
    st_CalculatedRes23.Caption := '';
  val(ST_CalculatedRes12.caption, Resist12, ErrorCode);
  val(ST_CalculatedRes23.caption, Resist23, ErrorCode);
  TheDifference := abs(Resist12 - Resist23);
//  str(TheDifference:6:2, EditStrings);
  EditStrings := format('%6.2f',[TheDifference]) ;
  ST_Difference.caption := EditStrings;
end;

