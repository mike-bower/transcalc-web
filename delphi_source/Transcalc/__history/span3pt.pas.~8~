  else if (TheHighRBridge < MinRBridge) or (TheHighRBridge > MaxRBridge) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_HighRBridge, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
