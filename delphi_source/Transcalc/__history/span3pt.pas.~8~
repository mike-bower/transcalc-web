    EB_HighRmod.setfocus;
    EB_HighRmod.clearselection;
    exit;
  end
  else if (TheHighRMod < MinRMod) or (TheHighRMod > MaxRMod) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_HighRMod, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinRMod, ffFixed, 8, 3);
    StrMax := floattostrf(MaxRMod, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_HighRmod.setfocus;
    EB_HighRmod.clearselection;
    exit;
  end;
  if (TheLowSpan > TheAmbientSpan) then
  begin
    { ..display message telling user the low span must be lower than ambient span }
    LoadString(hinstance, ID_SZ_LowOutAmbientOut, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    IsThereAnError := true;
    EB_AmbientSpan.setfocus;
    exit;
  end;
  if (TheAmbientSpan > TheHighSpan) then
  begin
    { ..display message telling user the ambient span must be lower than high span }
    LoadString(hinstance, ID_SZ_AmbientOutHighOut, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    IsThereAnError := true;
    EB_HighSpan.setfocus;
    exit;
  end;
  E0 := TheLowSpan;
  E1 := TheAmbientSpan;
  E2 := TheHighSpan;
  Rb0 := TheLowRBridge;
  Rb1 := TheAmbientRBridge;
  Rb2 := TheHighRBridge;
  Rn0 := TheLowRMod / TheAmbientRMod;
  Rn1 := TheAmbientRMod / TheAmbientRMod;
  Rn2 := TheHighRMod / TheAmbientRMod;
  if (E0 <> 0) then
  begin
    { set up equation }
    try
      A := Rb1 * (E1 / E0 - 1) * (Rn2 / Rn0 - (E2 / E0) * (Rb2 / Rb0)) -
        ((Rn1 / Rn0)
        - (E1 / E0) * (Rb1 / Rb0)) * Rb2 * (E2 / E0 - 1);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      B := Rb1 * (E1 / E0 - 1) * (Rn1 / Rn0 + 1) *
        ((Rn2 / Rn0) - (E2 / E0) * (Rb2 / Rb0))
        + Rb1 * (E1 / E0 - 1) * (Rn2 / Rn0) * (1 - (E2 / E0) * (Rb2 / Rb0)) -
        ((Rn1 / Rn0)
        - (E1 / E0) * (Rb1 / Rb0)) * Rb2 * (E2 / E0 - 1) * (Rn2 / Rn0 + 1) - Rn1
        / Rn0
        * (1 - (E1 / E0) * (Rb1 / Rb0)) * Rb2 * (E2 / E0 - 1);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      C := Rb1 * (E1 / E0 - 1) * Rn1 / Rn0 *
        ((Rn2 / Rn0) - (E2 / E0) * (Rb2 / Rb0))
        + Rb1 * (E1 / E0 - 1) * (Rn1 / Rn0 + 1) * Rn2 / Rn0 * (1 - (E2 / E0) *
        (Rb2 / Rb0)) - (Rn1 / Rn0 - (E1 / E0) * (Rb1 / Rb0)) * Rb2 *
        (E2 / E0 - 1)
        * Rn2 / Rn0 - Rn1 / Rn0 * (1 - (E1 / E0) * (Rb1 / Rb0)) * Rb2 *
        (E2 / E0 - 1)
        * (Rn2 / Rn0 + 1);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      D := Rb1 * (E1 / E0 - 1) * Rn1 / Rn0 * Rn2 / Rn0 *
        (1 - (E2 / E0) * (Rb2 / Rb0))
        - Rn1 / Rn0 * (1 - (E1 / E0) * (Rb1 / Rb0)) * Rb2 * (E2 / E0 - 1) *
        Rn2 / Rn0;
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    { T1 }
    try
      T1 := (27.0 * Sqr(A) * Sqr(D) - 2.0 * A * C * (9.0 * B * D - 2.0 * Sqr(C))
        + Sqr(B) * (4.0 * B * D - Sqr(C)));
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    { T2 }
    try
      T2 := Cube(3.0 * A * C - Sqr(B));
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if T2 = 0.0 then
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    if (T1 / T2) < 0.0 then
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    { T3 }
    try
      T3 := Sqrt(T1 / T2);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    { T4 }
    try
      T4 := Sqr(B) - 3.0 * A * C;
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if T4 <= 0.0 then
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    try
      T4 := 9.0 * A * Sqrt(Cube(T4));
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if T3 * T4 = 0.0 then
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    { T5 }
    try
      T5 := Sqrt(3.0) * (27.0 * Sqr(A) * D - 9.0 * A * B * C + 2.0 * Cube(B));
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    { T6 }
    try
      T6 := ArcTan((T5 / (T4 * T3)));
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    { T7 }
    if (Sqr(B) - 3.0 * A * C) <= 0.0 then
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    try
      T7 := 2.0 * Sqrt(Sqr(B) - 3.0 * A * C);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    { T8 }
    try
      T8 := B / (3.0 * A);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    index := 0;
    try
      X[1] := (T7 * Cos((T6 / 3.0) - pi / 2.0)) / (3.0 * Abs(A)) - T8;
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if (X[1] > MINRATIO) and (X[1] < MAXRATIO) then
    begin
      index := 1;
    end;
    try
      X[2] := (T7 * Cos((T6 / 3.0) + pi / 6.0)) / (3.0 * Abs(A)) - T8;
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if index = 0 then
    begin
      if (X[2] > MINRATIO) and (X[2] < MAXRATIO) then
      begin
        index := 2;
      end;
    end
    else
    begin
      if (X[2] > MINRATIO) and (X[2] < MAXRATIO) and (X[2] < X[index]) then
      begin
        index := 2;
      end;
    end;
    try
      X[3] := (T7 * Cos((T6 / 3.0) + 5.0 * pi / 6.0)) / (3.0 * Abs(A)) - T8;
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    if index = 0 then
    begin
      if (X[3] > MINRATIO) and (X[3] < MAXRATIO) then
      begin
        index := 3;
      end;
    end
    else
    begin
      if (X[3] > MINRATIO) and (X[3] < MAXRATIO) and (X[3] < X[index]) then
      begin
        index := 3;
      end;
    end;
    if (index = 0) then
    begin
      LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
      exit;
    end;
    try
      Rmod0 := (Rb1 * (E1 / E0 - 1) * (Rn1 / Rn0 * (1 + 1 / X[index]) + X[index]
        + 1)) / (Rn1 / Rn0 * (X[index] + 1 - E1 / E0 * Rb1 / Rb0) - X[index] *
        E1 / E0 * Rb1 / Rb0);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      Rmod1 := Rmod0 * (Rn1 / Rn0);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      Rmod2 := Rmod0 * (Rn2 / Rn0);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      Shunt := Rmod0 * X[index];
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      rms0 := (Rmod0 * Shunt) / (Rmod0 + Shunt);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      rms1 := (Rmod1 * Shunt) / (Rmod1 + Shunt);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      rms2 := (Rmod2 * Shunt) / (Rmod2 + Shunt);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      Span1 := (E1 * Rb1) / (Rb1 + rms1);
    except
      on EMathError do
      begin
        LoadString(hinstance, ID_SZ_CompImpraticable, ErrorMsg,
          sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption,
          sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption,
          mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    // str(Shunt:6:2, RShuntText);
    RShuntText := format('%6.2f', [Shunt]);
    ST_Rshunt.caption := RShuntText;
    // str(Rmod1:6:1, RModText);
    RModText := format('%6.1f', [Rmod1]);
    ST_Rmod.caption := RModText;
    // str(Span1:6:5, SpanText);
    SpanText := format('%6.5f', [Span1]);
    ST_Span.caption := SpanText;
  end
  else
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_LowSpanNoZero, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_LowSpan.setfocus;
    EB_LowSpan.clearselection;
    exit;
  end;
end;

