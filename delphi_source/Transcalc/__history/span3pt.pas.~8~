  TheItem: TacStreamable;
  i: integer;
  j: integer;
begin
  { ...getting the object if there is one }
  TheItem := nil;
  i := 0;
  Repeat
    If MainForm.Flog.AtIndex(i) is TSpanvsTemp3pt then
    begin
      TheItem := MainForm.Flog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.Flog.Count);
  { ...if there is an object, then place values in edit boxes }
  if TheItem = nil then
  begin
    { ...placing values in object }
    SpanvsTemp3PtObject := TSpanvsTemp3pt.create;
    SpanvsTemp3PtObject.LowSpan := EB_LowSpan.text;
    SpanvsTemp3PtObject.LowRBridge := EB_LowRBridge.text;
    SpanvsTemp3PtObject.LowRmod := EB_LowRMod.text;
    SpanvsTemp3PtObject.HighSpan := EB_HighSpan.text;
    SpanvsTemp3PtObject.HighRBridge := EB_HighRBridge.text;
    SpanvsTemp3PtObject.HighRmod := EB_HighRmod.text;
    SpanvsTemp3PtObject.AmbientSpan := EB_AmbientSpan.text;
    SpanvsTemp3PtObject.AmbientRBridge := EB_AmbientRbridge.text;
    SpanvsTemp3PtObject.AmbientRmod := EB_AmbientRMod.text;
    SpanvsTemp3PtObject.RShunt := ST_Rshunt.caption;
    SpanvsTemp3PtObject.RMod := ST_Rmod.caption;
    SpanvsTemp3PtObject.Span := ST_Span.caption;
    MainForm.AddToLog(SpanvsTemp3PtObject);
    j := 0;
    { ...placing object string in outline }
    Repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Circuit Refinements') or
      (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, SpanvsTemp3PtObject.GetAsString);
  end
  else
  begin
    (TheItem as TSpanvsTemp3pt).LowSpan := EB_LowSpan.text;
    (TheItem as TSpanvsTemp3pt).LowRBridge := EB_LowRBridge.text;
    (TheItem as TSpanvsTemp3pt).LowRmod := EB_LowRMod.text;
    (TheItem as TSpanvsTemp3pt).HighSpan := EB_HighSpan.text;
    (TheItem as TSpanvsTemp3pt).HighRBridge := EB_HighRBridge.text;
    (TheItem as TSpanvsTemp3pt).HighRmod := EB_HighRmod.text;
    (TheItem as TSpanvsTemp3pt).AmbientSpan := EB_AmbientSpan.text;
    (TheItem as TSpanvsTemp3pt).AmbientRBridge := EB_AmbientRbridge.text;
    (TheItem as TSpanvsTemp3pt).AmbientRmod := EB_AmbientRMod.text;
    (TheItem as TSpanvsTemp3pt).RShunt := ST_Rshunt.caption;
    (TheItem as TSpanvsTemp3pt).RMod := ST_Rmod.caption;
    (TheItem as TSpanvsTemp3pt).Span := ST_Span.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.CompDlgShowing = true then
  begin
    CompensationDlg.close;
  end;
end;

