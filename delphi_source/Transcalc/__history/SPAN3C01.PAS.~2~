(***********************************************************************)
{TSpan3PtC01Form.ReCalculate}
procedure TSpan3PtC01Form.ReCalculate;
const
  {FOIL SQUARES - SEE JRW's B.S.}
  Ohm40S1  = 16.0/10.0;
  Ohm40S2  = 4.37;
  Ohm40S3  = 3.0;
  Ohm40S4  = 1.5/1.0;
  Ohm40S5  = 2.2;
  Ohm40S6  = 20.0/8.0;
  Ohm40S7  = 19.0/4.38{20.0/17.0};
  Ohm40S8  = 1.5/1.0;
  Ohm40S9  = 52.0;
  Ohm40S10 = 2.0;
  Ohm40S11 = 3.5;
  Ohm40S12 = 76.0;
  Ohm40S13 = 18.6;
  Ohm40S14 = 18.6;
  Ohm40S15 = 119.0;
  Ohm40S16 = 163.0;
  Ohm40S17 = 2.0;
  Ohm40S18 = 3.0;
  Ohm40S19 = 17.9;
  Ohm40S20 = 776.8;
  Ohm40S21 = 0;
  Ohm40S22 = 1.5;
  Ohm40S23 = 1.5;
  Ohm40TOTALSQUARES = 801.0;
  Ohm80S1  = 16.0/10.0;
  Ohm80S2  = 4.37 * 2.0;
  Ohm80S3  = 3.0;
  Ohm80S4  = 1.5/1.0;
  Ohm80S5  = 4.4;
  Ohm80S6  = 20.0/8.0;
  Ohm80S7  = (19.0/4.38) * 2.0;
  Ohm80S8  = 1.5/1.0;
  Ohm80S9  = 52.0 * 2.0;
  Ohm80S10 = 2.0;
  Ohm80S11 = 3.5;
  Ohm80S12 = 70.0 * 2.0;
  Ohm80S13 = 18.6 * 2.0;
  Ohm80S14 = 18.6 * 2.0;
  Ohm80S15 = 130 * 2.0;
  Ohm80S16 = 150.0 * 2.0;
  Ohm80S17 = 2.0;
  Ohm80S18 = 3.0;
  Ohm80S19 = 17.9 * 2.0;
  Ohm80S20 = 1575.4;
  Ohm80S21 = 0;
  Ohm80S22 = 1.5;
  Ohm80S23 = 1.5;
  Ohm80TOTALSQUARES = 1600.0;
var
  ErrorMsg      : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption  : array[0..MAXERRORLENGTH-1] of char;
  ErrorAnd      : array[0..MAXERRORLENGTH-1] of char;
  ErrorUnit     : array[0..MAXERRORLENGTH-1] of char;
  cs            : array[0..255] of char;
  EditStrings   : string;
  s             : string;
  StrMsg        : string;
  StrUnit       : string;
  StrAnd        : string;
  S1            : RealType;
  S2            : RealType;
  S3            : RealType;
  S4            : RealType;
  S5            : RealType;
  S6            : RealType;
  S7            : RealType;
  S8            : RealType;
  S9            : RealType;
  S10           : RealType;
  S11           : RealType;
  S12           : RealType;
  S13           : RealType;
  S14           : RealType;
  S15           : RealType;
  S16           : RealType;
  S17           : RealType;
  S18           : RealType;
  S19           : RealType;
  S20           : RealType;
  S21           : RealType;
  S22           : RealType;
  S23           : RealType;
  TotalSquares  : RealType;
  C             : RealType;
  CFA           : RealType;
  CSA           : RealType;
  CB            : RealType;
  CFC           : RealType;
  CSC           : RealType;
  Squares       : RealType;
  Rtotal        : RealType;
  RStart        : RealType;
  OhmsPerSquare : RealType;
  code          : Integer;
  Button        : integer;
begin
  { Read Starting Resistance}
  s := EB_StartingRes.text;
  val(s,Rstart,code);
  if code <> 0 then begin
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    Rstart := 0;
    ST_CalculatedRes.caption := '';
    exit;
  end;
  if (RStart >= 30) and (RStart <= 50) then begin
    S1 := Ohm40S1;
    S2 := Ohm40S2;
    S3 := Ohm40S3;
    S4 := Ohm40S4;
    S5 := Ohm40S5;
    S6 := Ohm40S6;
    S7 := Ohm40S7;
    S8 := Ohm40S8;
    S9 := Ohm40S9;
    S10 := Ohm40S10;
    S11 := Ohm40S11;
    S12 := Ohm40S12;
    S13 := Ohm40S13;
    S14 := Ohm40S14;
    S15 := Ohm40S15;
    S16 := Ohm40S16;
    S17 := Ohm40S17;
    S18 := Ohm40S18;
    S19 := Ohm40S19;
    S20 := Ohm40S20;
    S21 := Ohm40S21;
    S22 := Ohm40S22;
    S23 := Ohm40S23;
    TotalSquares := Ohm40TOTALSQUARES;
  end
  else if (RStart >= 60) and (RStart <= 110) then begin
    S1 := Ohm80S1;
    S2 := Ohm80S2;
    S3 := Ohm80S3;
    S4 := Ohm80S4;
    S5 := Ohm80S5;
    S6 := Ohm80S6;
    S7 := Ohm80S7;
    S8 := Ohm80S8;
    S9 := Ohm80S9;
    S10 := Ohm80S10;
    S11 := Ohm80S11;
    S12 := Ohm80S12;
    S13 := Ohm80S13;
    S14 := Ohm80S14;
    S15 := Ohm80S15;
    S16 := Ohm80S16;
    S17 := Ohm80S17;
    S18 := Ohm80S18;
    S19 := Ohm80S19;
    S20 := Ohm80S20;
    S21 := Ohm80S21;
    S22 := Ohm80S22;
    S23 := Ohm80S23;
    TotalSquares := Ohm80TOTALSQUARES;
  end
  else begin
    LoadString(hinstance, ID_SZ_WrongResistor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    EditStrings := StrMsg + ' ' + '30-50 or 60-110' + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    EB_StartingRes.setfocus;
    exit;
  end;
  if RStart > 0 then begin
    OhmsPerSquare := Rstart/TOTALSQUARES;
  end;
  {Calculate Ladder First "A"}
  C  := (C01Span3PtResist.FA1.IsCut / S3) + (1 / (2 * S7 + S6));
  C  := (C01Span3PtResist.FA2.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.FA3.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.FA4.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.FA5.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.FA6.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.FA7.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.FA8.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.FA9.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  CFA := (C01Span3PtResist.FA10.IsCut / S10) + (1 / (2 * S2 + 1/C));
  {Calculate Ladder Second "A"}
  C  := (C01Span3PtResist.SA1.IsCut / S3) + (1 / (2 * S7 + S6));
  C  := (C01Span3PtResist.SA2.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.SA3.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.SA4.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.SA5.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.SA6.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.SA7.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.SA8.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  C  := (C01Span3PtResist.SA9.IsCut / S3) + (1 / (2 * S5 + S3 + 1/C));
  CSA := (C01Span3PtResist.SA10.IsCut / S10) + (1 / (2 * S2 + 1/C));
  {Calculate Ladder "B"}
  C  := (C01Span3PtResist.B1.IsCut / S10) + (1 / S12);
  C  := (C01Span3PtResist.B2.IsCut / S11) + (1 / (S9 + S13 + 1/C));
  C  := (C01Span3PtResist.B3.IsCut / S10) + (1 / (S9 + S13 + 1/C));
  CB := (C01Span3PtResist.B4.IsCut / S18) + (1 / (S9 + S14 + 1/C));
  {Calculate Ladder First "C"}
  C  := (C01Span3PtResist.FC1.IsCut / S17) + (1 / S16);
  C  := (C01Span3PtResist.FC2.IsCut / S18) + (1 / (S15 + S19 + 1/C));
  CFC  := C;
  {Calculate Ladder Second "C"}
  C  := (C01Span3PtResist.SC1.IsCut / S17) + (1 / S16);
  C  := (C01Span3PtResist.SC2.IsCut / S18) + (1 / (S15 + S19 + 1/C));
  CSC := C;
  {Calculate total resistance}
  Squares := 1/CFA + 1/CSA + 1/CB + 1/CFC + 1/CSC + S20 + S8 + S8 + S8 + S8 +
             S4 + S21 + S22 + S1 + S23;
  RTotal := OhmsPerSquare * Squares;
  {Display}
  if RTotal > 0 then begin
//    Str(Rtotal:7:1, s);
    s := format('%7.1f',[Rtotal]) ;
    StrPcopy(cs,s);
    ST_CalculatedRes.caption := s;
  end
  else
    ST_CalculatedRes.caption := s;
end;

