    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_BridgeResistance.setfocus;
    EB_BridgeResistance.clearselection;
    exit;
  end
  else if (ResistBridge < MinBridgeResistance) or (ResistBridge > MaxBridgeResistance) then begin
    IsThereAnError := True;
    LoadString(hinstance, ID_SZ_Ohms, ErrorUnit, sizeof(ErrorUnit));
    LoadString(hinstance, ID_SZ_BridgeResist, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorAnd));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinBridgeResistance, ffFixed, 8, 3);
    StrMax := floattostrf(MaxBridgeResistance, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + StrMax + ' ' + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_BridgeResistance.setfocus;
    EB_BridgeResistance.clearselection;
    exit;
  end;
  {...calculating Resistance value}
  if (LowTemp >= HighTemp) then begin
    {..display message telling user the low temp must be lower than high temp}
    LoadString(hinstance, ID_SZ_LowTempHighTemp, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    ExceptionRaised := true;
    IsThereAnError := true;
    EB_HighTemperature.setfocus;
    exit;
  end;
  if MainForm.UnitsAreUS = true then begin
    if ((HighTemp - LowTemp) > 0) and ((HighTemp - LowTemp) < 50) then begin
      LoadString(hinstance, ID_SZ_TempDiff50F, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    end;
  end
  else begin
    if ((HighTemp - LowTemp) > -18) and ((HighTemp - LowTemp) < 10) then begin
      LoadString(hinstance, ID_SZ_TempDiff10C, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
    end;
  end;
  if IsThereAnError = false then begin
    ResistValue := CalculateResistance;
    if ExceptionRaised = False then begin
      if HighOut = LowOut then begin
        ST_Resistance.caption := '0.0';
      end
      else begin
        ST_Resistance.caption := floattostrf(abs(ResistValue), ffFixed, 6, 2);
        if (abs(ResistValue)  > 0.5) then begin
          RB_Wire.checked := true;
          RB_E01Resistor.enabled := false;
        end
        else begin
          RB_E01Resistor.enabled := true;
          RB_E01Resistor.checked := true;
        end;
      end;
    end;
    ST_BridgeArm.caption := CalculateBridgeArm;
  end;
end;

(***********************************************************************)
{TZeroVsTempDlg.FormActivate}
procedure TZeroVsTempDlg.FormActivate(Sender: TObject);
var
  EditStrings : string;
  i           : integer;
  TheItem     : TacStreamable;
  TheItems    : string;
begin
  CB_WireType.itemindex := 0;
  {getting item from object if there is one}
  TheItem := nil;
  i := 0;
  {...add 1st Wire Type to Combobox}
  TheItems := CB_WireType.items.strings[0];
  CB_WireType.items.delete(0);
  Wire := TWire.create;
  Wire.name := 'Balco';
  Wire.Resistivity := 120;
  Wire.TCR := 0.25;
  CB_WireType.items.addobject(TheItems, Wire);
  {...add 2nd Wire Type to Combobox}
  TheItems := CB_WireType.items.strings[1];
  CB_WireType.items.delete(1);
  Wire := TWire.create;
  Wire.name := 'Copper';
  Wire.Resistivity := 10.371;
  Wire.TCR := 0.22;
  CB_WireType.items.addobject(TheItems, Wire);
  {...add 3rd Wire Type to Combobox}
  TheItems := CB_WireType.items.strings[2];
  CB_WireType.items.delete(2);
  Wire := TWire.create;
  Wire.name := 'Nickel, pure';
  Wire.Resistivity := 45;
  Wire.TCR := 0.33;
  CB_WireType.items.addobject(TheItems, Wire);
  {...getting the object if there is one}
  TheItem := nil;
  i := 0;
  Repeat
    If MainForm.Flog.AtIndex(i) is TZeroVsTemp then begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or ( i > MainForm.Flog.Count);
  {...if there is an object, then place values in edit boxes}
  if TheItem <> nil then begin
    EB_LowTemperature.text := (TheItem as TZeroVsTemp).LowTemperature;
    EB_LowOutput.text := (TheItem as TZeroVsTemp).LowOutput;
    EB_HighTemperature.text := (TheItem as TZeroVsTemp).HighTemperature;
    EB_HighOutput.text := (TheItem as TZeroVsTemp).HighOutput;
    CB_WireType.ItemIndex := (TheItem as TZeroVsTemp).TheWireType;
    if CB_WireType.ItemIndex = 1 then begin
      RB_E01Resistor.enabled := true;
      RB_Wire.checked  := true;
    end
    else begin
      RB_E01Resistor.enabled := false;
      RB_Wire.checked  := true;
    end;
    ST_ResistanceTCR.caption := (TheItem as TZeroVsTemp).ResistorTCR;
    EB_BridgeResistance.text := (TheItem as TZeroVsTemp).BridgeResist;
    ST_Resistance.caption := (TheItem as TZeroVsTemp).Resistance;
    ST_BridgeArm.caption := (TheITem as TZeroVsTemp).BridgeArm;
  end
  else begin
    CB_Wiretype.Itemindex := 1;
    CB_WireTypeChange(Sender);
  end;
  {...placing value in old value in case cancel clicked}
  OldLowTemp := EB_LowTemperature.text;
  OldLowOut := EB_LowOutput.text;
  OldHighTemp := EB_HighTemperature.text;
  OldHighOut := EB_HighOutput.text;
  OldResistTCR := ST_ResistanceTCR.caption;
  OldBridgeResist :=  EB_BridgeResistance.text;
  Old_Resistance := ST_Resistance.caption;
  Old_BridgeArm := ST_BridgeArm.caption;
end;

