(***********************************************************************)
{TZeroVsTempDlg.Resistance}
function TZeroVsTempDlg.CalculateResistance: RealType;
var
  ErrorMsg        : array[0..MAXERRORLENGTH-1] of char;
  ErrorCaption    : array[0..MAXERRORLENGTH-1] of char;
  DiffInTemp      : RealType;
  DiffInSpan      : RealType;
  ResistanceValue : RealType;
  Button          : integer;
begin
  result := 0.0 ;
  ExceptionRaised := false;
  DiffInTemp := HighTemp - LowTemp;
  DiffInSpan := HighOut - LowOut;
  if (DiffInTemp <> 0) and (DiffInSpan <> 0) then begin
    ResistanceValue := DiffInSpan * 4.0 * ResistBridge * 1e-3;
    try
      ResistanceValue := ResistanceValue / DiffInTemp;
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    try
      ResistanceValue := ResistanceValue / (ResistTCR/100);
    except
      on EMathError do begin
        LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
        LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
        Button := Application.MessageBox(ErrorMsg, ErrorCaption, mb_OK or mb_IconExclamation);
        ExceptionRaised := true;
        exit;
      end;
    end;
    CalculateResistance := ResistanceValue;
  end;
end;

(***********************************************************************)
{TZeroVsTempDlg.BridgeArm}
function TZeroVsTempDlg.CalculateBridgeArm: String;
var
  BridgeArmText   : array[0..MAXERRORLENGTH-1] of char;
begin
  ExceptionRaised := false;
  if ResistValue > 0 then begin
    Loadstring(hinstance, ID_SZ_ZTPMinusSMinus, BridgeArmText, sizeof(BridgeArmText));
  end
  else begin
    Loadstring(hinstance, ID_SZ_ZTPPlusSMinus, BridgeArmText, sizeof(BridgeArmText));
  end;
  CalculateBridgeArm := BridgeArmText;
end;

