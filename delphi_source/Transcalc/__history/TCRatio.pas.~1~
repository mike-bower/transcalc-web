unit Tcratio;

interface

uses                  
  SysUtils, WinTypes, WinProcs, Messages, Classes, Graphics, Controls,
  StdCtrls, ExtCtrls, Forms, Mask, Buttons, INIfiles;

type
  TForm1 = class(TForm)
    cb_SensorType: TComboBox;
    GroupBox1: TGroupBox;
    Label1: TLabel;
    Label2: TLabel;
    Label3: TLabel;
    GroupBox2: TGroupBox;
    rb_US: TRadioButton;
    rb_SI: TRadioButton;
    GroupBox3: TGroupBox;
    Label4: TLabel;
    st_Rtl: TLabel;
    Label6: TLabel;
    st_Rta: TLabel;
    Label8: TLabel;
    st_Rth: TLabel;
    bn_Compute: TBitBtn;
    bn_Close: TBitBtn;
    GroupBox4: TGroupBox;
    EB_TLow: TEdit;
    EB_TAmbient: TEdit;
    EB_THigh: TEdit;
    BN_Help: TBitBtn;
