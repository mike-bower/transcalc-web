(* ********************************************************************* *)
{ TRndSldTorqueFrm.BN_OKClick }
procedure TRndSldTorqueFrm.BN_OKClick(Sender: TObject);
var
  TheItem: TacStreamable;
  i: integer;
  j: integer;
begin
  BN_ComputeClick(Sender);
  if IsThereAnError = true then
  begin
    exit;
  end;
  MainForm.DesignChosen := true;
  { getting item from object if there is one }
  TheItem := nil;
  i := 0;
  Repeat
    if MainForm.FLog.AtIndex(i) is TRndSolidTorque then
    begin
      TheItem := MainForm.FLog.AtIndex(i);
    end;
    inc(i);
  until (TheItem <> nil) or (i > MainForm.FLog.Count);
  { ...if there is an object, then placing values in edit boxes }
  if TheItem = nil then
  begin
    { ...creating and placing values in object }
    RndSolidTorqueObject := TRndSolidTorque.create;
    RndSolidTorqueObject.AppliedTorque := EB_AppliedTorque.text;
    RndSolidTorqueObject.Diameter := EB_Diameter.text;
    RndSolidTorqueObject.Poisson := EB_Poisson.text;
    RndSolidTorqueObject.Modulus := EB_Modulus.text;
    RndSolidTorqueObject.GageFactor := EB_GageFactor.text;
    RndSolidTorqueObject.Normal := ST_NormalStrain.caption;
    RndSolidTorqueObject.FullSpan := ST_FullSpan.caption;
    MainForm.AddToLog(RndSolidTorqueObject);
    j := 0;
    { ...placing string associated with object in outline }
    repeat
      inc(j);
    until (MainForm.XCalcOutline.Items[j].text = 'Design Verification') or
      (j > MainForm.XCalcOutline.ItemCount);
    MainForm.XCalcOutline.AddChild(j, RndSolidTorqueObject.GetAsString);
  end
  else
  begin
    (TheItem as TRndSolidTorque).AppliedTorque := EB_AppliedTorque.text;
    (TheItem as TRndSolidTorque).Diameter := EB_Diameter.text;
    (TheItem as TRndSolidTorque).Poisson := EB_Poisson.text;
    (TheItem as TRndSolidTorque).Modulus := EB_Modulus.text;
    (TheItem as TRndSolidTorque).GageFactor := EB_GageFactor.text;
    (TheItem as TRndSolidTorque).Normal := ST_NormalStrain.caption;
    (TheItem as TRndSolidTorque).FullSpan := ST_FullSpan.caption;
  end;
  MainForm.IsDirty := true;
  close;
  if MainForm.DesignDlgShowing = true then
  begin
    DesignDlg.close;
  end;
end;

