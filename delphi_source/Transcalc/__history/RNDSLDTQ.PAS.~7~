(* ********************************************************************* *)
{ TRndSldTorqueFrm.CalculateNormalStrain }
function TRndSldTorqueFrm.CalculateNormalStrain: RealType;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH - 1] of char;
  Numerator: RealType;
  Denominator: RealType;
  NormalResult: RealType;
  Button: integer;
begin
  NormalResult := 0.0;
  ExceptionRaised := false;
  Numerator := ShearE;
  Denominator := 2;
  try
    NormalResult := Numerator / Denominator;
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_NoNormalStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateNormalStrain := NormalResult;
end;

(* ********************************************************************* *)
{ TRndSldTorqueFrm.CalculateShearStrain }
function TRndSldTorqueFrm.CalculateShearStrain: RealType;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH - 1] of char;
  PolarMoment: RealType;
  Numerator: RealType;
  Denominator: RealType;
  ShearResult: RealType;
  Button: integer;
begin
  ShearResult := 0.0;
  ExceptionRaised := false;
  PolarMoment := (Pi * ((TorqueDiameter / 2) * (TorqueDiameter / 2) *
    (TorqueDiameter / 2) *
    (TorqueDiameter / 2))) / 2;
  Numerator := (Torque * (TorqueDiameter / 2)) / PolarMoment;
  Denominator := Elasticity / (2 * (1 + Ratio));
  try
    ShearResult := (Numerator / Denominator) * 1E6;
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_NoShearStrain, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateShearStrain := ShearResult;
end;

(* ********************************************************************* *)
{ TRndSldTorqueFrm.CalculateFullSpan }
function TRndSldTorqueFrm.CalculateFullSpan: RealType;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH - 1] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH - 1] of char;
  FirstTerm: RealType;
  SecondTerm: RealType;
  SpanResult: RealType;
  Button: integer;
begin
  SpanResult := 0.0;
  ExceptionRaised := false;
  FirstTerm := Factor;
  SecondTerm := (2 * ShearE) / 4;
  try
    SpanResult := (FirstTerm * SecondTerm) * 1E-3;
  except
    on EMathError do
    begin
      LoadString(hinstance, ID_SZ_NoFullSpan, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ExceptionRaised := true;
    end;
  end;
  CalculateFullSpan := SpanResult;
end;

(* ********************************************************************* *)
{ TRndSldTorqueFrm.FormCreate }
procedure TRndSldTorqueFrm.FormCreate(Sender: TObject);
var
  TorqueUnit: array [0 .. MAXTEXTLENGTH - 1] of char;
  DimensionUnit: array [0 .. MAXTEXTLENGTH - 1] of char;
  ModulusUnit: array [0 .. MAXTEXTLENGTH - 1] of char;
begin
  { ...determining whether to use Std. or SI as form units }
  if MainForm.UnitsAreUS = true then
  begin
    LoadString(hinstance, ID_SZ_TorqueStd, TorqueUnit, sizeof(TorqueUnit));
    LoadString(hinstance, ID_SZ_Inches, DimensionUnit, sizeof(DimensionUnit));
    LoadString(hinstance, ID_SZ_PSI, ModulusUnit, sizeof(ModulusUnit));
  end
  else
  begin
    LoadString(hinstance, ID_SZ_TorqueMetric, TorqueUnit, sizeof(TorqueUnit));
    LoadString(hinstance, ID_SZ_MM, DimensionUnit, sizeof(DimensionUnit));
    LoadString(hinstance, ID_SZ_GPa, ModulusUnit, sizeof(ModulusUnit));
  end;
  { ...placing units on form }
  ST_TorqueUnit.caption := TorqueUnit;
  ST_DiameterUnit.caption := DimensionUnit;
  ST_modulusUnit.caption := ModulusUnit;
  Font.Name := 'MS Sans Serif';
  Font.Size := 8;
end;

(* ********************************************************************* *)
{ TRndSldTorqueFrm.BN_ComputeClick }
procedure TRndSldTorqueFrm.BN_ComputeClick(Sender: TObject);
const
  MINAPPLIEDTORQUE_US = 0.0000;
  MAXAPPLIEDTORQUE_US = 500000;
  MINDIAMETER_US = 0.20;
  MAXDIAMETER_US = 20.0;
  MINPOISSON_US = 0.1;
  MAXPOISSON_US = 0.4;
  MINMODULUS_US = 5000000;
  MAXMODULUS_US = 50000000;
  MINGAGEFACTOR_US = 1.0;
  MAXGAGEFACTOR_US = 5.0;
var
  ErrorMsg: array [0 .. MAXERRORLENGTH] of char;
  ErrorUnit: array [0 .. MAXERRORLENGTH] of char;
  ErrorAnd: array [0 .. MAXERRORLENGTH] of char;
  ErrorCaption: array [0 .. MAXERRORLENGTH] of char;
  StrUnit: string;
  StrAnd: string;
  StrMsg: string;
  StrMin: string;
  strMax: string;
  EditStrings: string;
  MinAppliedTorque: RealType;
  MaxAppliedTorque: RealType;
  MinDiameter: RealType;
  MaxDiameter: RealType;
  MinPoisson: RealType;
  MaxPoisson: RealType;
  MinModulus: RealType;
  MaxModulus: RealType;
  MinGageFactor: RealType;
  MaxGageFactor: RealType;
  ErrorCode: integer;
  Button: integer;
begin
  { ...Determining which units to use std. or si for min and max values }
  if MainForm.UnitsAreUS = true then
  begin
    MinAppliedTorque := MINAPPLIEDTORQUE_US;
    MaxAppliedTorque := MAXAPPLIEDTORQUE_US;
    MinDiameter := MINDIAMETER_US;
    MaxDiameter := MAXDIAMETER_US;
    MinPoisson := MINPOISSON_US;
    MaxPoisson := MAXPOISSON_US;
    MinModulus := MINMODULUS_US;
    MaxModulus := MAXMODULUS_US;
    MinGageFactor := MINGAGEFACTOR_US;
    MaxGageFactor := MAXGAGEFACTOR_US;
  end
  else
  begin
    MinAppliedTorque := MINAPPLIEDTORQUE_US * 0.11298;
    MaxAppliedTorque := MAXAPPLIEDTORQUE_US * 0.11298;
    MinDiameter := Inches_To_mm(MINDIAMETER_US);
    MaxDiameter := Inches_To_mm(MAXDIAMETER_US);
    MinPoisson := MINPOISSON_US;
    MaxPoisson := MAXPOISSON_US;
    MinModulus := PSI_To_GPa(MINMODULUS_US);
    MaxModulus := PSI_To_GPa(MAXMODULUS_US);
    MinGageFactor := MINGAGEFACTOR_US;
    MaxGageFactor := MAXGAGEFACTOR_US;
  end;
  ST_NormalStrain.caption := '';
  ST_FullSpan.caption := '';
  { ...checking Applied Torque to see if valid }
  IsThereAnError := false;
  EditStrings := EB_AppliedTorque.text;
  val(EditStrings, Torque, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AppliedTorque.setfocus;
    EB_AppliedTorque.clearselection;
    exit;
  end
  else if (Torque < MinAppliedTorque) or (Torque > MaxAppliedTorque) then
  begin
    IsThereAnError := true;
    if MainForm.UnitsAreUS = true then
    begin
      LoadString(hinstance, ID_SZ_TorqueStd, ErrorUnit, sizeof(ErrorMsg));
    end
    else
    begin
      LoadString(hinstance, ID_SZ_TorqueMetric, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_AppliedTorque, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinAppliedTorque, ffFixed, 8, 3);
    strMax := floattostrf(MaxAppliedTorque, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_AppliedTorque.setfocus;
    EB_AppliedTorque.clearselection;
    exit;
  end;
  if MainForm.UnitsAreUS = false then
  begin
    Torque := Torque * 1000;
  end;
  { ...checking Diameter to see if valid }
  EditStrings := EB_Diameter.text;
  val(EditStrings, TorqueDiameter, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Diameter.setfocus;
    EB_Diameter.clearselection;
    exit;
  end
  else if (TorqueDiameter < MinDiameter) or (TorqueDiameter > MaxDiameter) then
  begin
    IsThereAnError := true;
    if MainForm.UnitsAreUS = true then
    begin
      LoadString(hinstance, ID_SZ_Inches, ErrorUnit, sizeof(ErrorMsg));
    end
    else
    begin
      LoadString(hinstance, ID_SZ_MM, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_Diameter, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinDiameter, ffFixed, 8, 3);
    strMax := floattostrf(MaxDiameter, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Diameter.setfocus;
    EB_Diameter.clearselection;
    exit;
  end;
  { ...checking to see if Poisson is valid }
  EditStrings := EB_Poisson.text;
  val(EditStrings, Ratio, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Poisson.setfocus;
    EB_Poisson.clearselection;
    exit;
  end
  else if (Ratio < MinPoisson) or (Ratio > MaxPoisson) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_Poisson, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinPoisson, ffFixed, 8, 3);
    strMax := floattostrf(MaxPoisson, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Poisson.setfocus;
    EB_Poisson.clearselection;
    exit;
  end;
  { ...checking to see if Modulus value is valid }
  EditStrings := EB_Modulus.text;
  val(EditStrings, Elasticity, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Modulus.setfocus;
    EB_Modulus.clearselection;
    exit;
  end
  else if (Elasticity < MinModulus) or (Elasticity > MaxModulus) then
  begin
    IsThereAnError := true;
    if MainForm.UnitsAreUS = true then
    begin
      LoadString(hinstance, ID_SZ_PSI, ErrorUnit, sizeof(ErrorMsg));
    end
    else
    begin
      LoadString(hinstance, ID_SZ_GPa, ErrorUnit, sizeof(ErrorMsg));
    end;
    LoadString(hinstance, ID_SZ_Modulus, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrUnit := strpas(ErrorUnit);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinModulus, ffFixed, 8, 3);
    strMax := floattostrf(MaxModulus, ffFixed, 8, 3);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax + ' '
      + StrUnit;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_Modulus.setfocus;
    EB_Modulus.clearselection;
    exit;
  end;
  if MainForm.UnitsAreUS = false then
  begin
    Elasticity := Elasticity * 1000;
  end;
  { ...checking to see if Gage Factor is valid }
  EditStrings := EB_GageFactor.text;
  val(EditStrings, Factor, ErrorCode);
  if ErrorCode <> 0 then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_NotValidNo, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageFactor.setfocus;
    EB_GageFactor.clearselection;
    exit;
  end
  else if (Factor < MinGageFactor) or (Factor > MaxGageFactor) then
  begin
    IsThereAnError := true;
    LoadString(hinstance, ID_SZ_GageFactor, ErrorMsg, sizeof(ErrorMsg));
    LoadString(hinstance, ID_SZ_And, ErrorAnd, sizeof(ErrorMsg));
    StrMsg := strpas(ErrorMsg);
    StrAnd := strpas(ErrorAnd);
    StrMin := floattostrf(MinGageFactor, ffFixed, 8, 3);
    strMax := floattostrf(MaxGageFactor, ffFixed, 8, 1);
    EditStrings := StrMsg + ' ' + StrMin + ' ' + StrAnd + ' ' + strMax;
    StrPCopy(ErrorMsg, EditStrings);
    LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
    Button := Application.MessageBox(ErrorMsg, ErrorCaption,
      mb_OK or mb_IconExclamation);
    ModalResult := 0;
    EB_GageFactor.setfocus;
    EB_GageFactor.clearselection;
    exit;
  end;
  { ...doing calculations }
  if IsThereAnError = false then
  begin
    { ...Shear Strain }
    ShearE := CalculateShearStrain;
    { ...Normal Strain }
    NormalE := CalculateNormalStrain;
    if abs(NormalE) < 5000 then
    begin
      if ExceptionRaised = false then
      begin
        NormalText := floattostrf(NormalE, ffFixed, 4, 0);
        ST_NormalStrain.caption := NormalText;
      end;
    end
    else
    begin
      LoadString(hinstance, ID_SZ_Impratical, ErrorMsg, sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ST_NormalStrain.caption := '';
      ST_FullSpan.caption := '';
      ModalResult := 0;
      exit;
    end;
    { ...Full Bridge Sensitivity }
    FullSensitivity := CalculateFullSpan;
    if ExceptionRaised = false then
    begin
      FullSpanText := floattostrf(FullSensitivity, ffFixed, 4, 3);
      ST_FullSpan.caption := FullSpanText;
    end;
    if abs(NormalE) > 1700 then
    begin
      LoadString(hinstance, ID_SZ_StrainExceeds1700, ErrorMsg,
        sizeof(ErrorMsg));
      LoadString(hinstance, ID_SZ_ErrorMsg, ErrorCaption, sizeof(ErrorCaption));
      Button := Application.MessageBox(ErrorMsg, ErrorCaption,
        mb_OK or mb_IconExclamation);
      ModalResult := 0;
    end;
  end;
end;

(* ********************************************************************* *)
{ TRndSldTorqueFrm.BN_CancelClick }
procedure TRndSldTorqueFrm.BN_CancelClick(Sender: TObject);
begin
  EB_AppliedTorque.text := Old_AppliedTorque;
  EB_Diameter.text := Old_Diameter;
  EB_Poisson.text := Old_Poisson;
  EB_Modulus.text := Old_Modulus;
  EB_GageFactor.text := Old_GageFactor;
  ST_NormalStrain.caption := Old_Normal;
  ST_FullSpan.caption := Old_FullSpan;
