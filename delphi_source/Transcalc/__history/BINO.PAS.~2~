  Answer         : RealType;
  SpanResult     : RealType;
  Button         : integer;
begin
  SpanResult := 0;
  ExceptionRaised := false;
  try
       SpanResult := EAvg * Factor * 1e-3;
(* removed mjb
    SpanResult := ((abs(EAvgA) + abs(EAvgB) + abs(EAvgC) + abs(EAvgD))/4) * Factor * 1e-3;}
*)
  except
