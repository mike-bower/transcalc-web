  {...calculating g (Beam Hole Distance) for the calculations}
  BeamHoleDist := (Height/2) - (HoleRadius + MinThick);
  {...checking to make sure 2G + 2R is not greater than Height}
  if  (2 * BeamHoleDist + 2 * HoleRadius) >= Height then begin
    IsThereAnError := True;
